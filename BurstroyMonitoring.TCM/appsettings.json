{
  "AppSettings": {
    "Title": "ТЦУ-М"
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Database=sensordb;Username=postgres;Password=12345678"
   },
   "Jwt": {
    "Key": "ThisIsMyVeryLongSecretKeyForJwtAuthentication1234567890ThatShouldBeAtLeast32Characters",
    "Issuer": "BurstroyMonitoring.TCM",
    "Audience": "BurstroyMonitoring.TCMUsers",
    "ExpireDays": 1
  },
  "Serilog": {
    "Using": ["Serilog.Sinks.Console", "Serilog.Sinks.File"],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/log-tcm-.log",
          "rollingInterval": "Day",
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": ["FromLogContext"]
  }
}