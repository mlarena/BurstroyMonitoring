@model BurstroyMonitoring.Data.Models.VwMueksDataFull

@{
    ViewData["Title"] = "Подробности о данных MUEKS";
}

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-10 col-lg-8">
            <div class="card shadow-sm">
                <div class="card-header bg-info text-white py-2 d-flex justify-content-between align-items-center">
                    <h1 class="h5 mb-0">Подробности о данных MUEKS</h1>
                    <span class="badge bg-light text-dark">ID: @Model.MueksDataId</span>
                </div>
                <div class="card-body p-0">
                    <table class="table table-sm mb-0">
                        <tbody>
                            <tr class="table-light"><th colspan="2" class="ps-3 py-2">Основная информация</th></tr>
                            <tr>
                                <th class="ps-3" style="width: 40%;">Дата и время получения</th>
                                <td class="ps-3">@(Model.ReceivedAt?.ToLocalTime().ToString("dd.MM.yyyy HH:mm:ss") ?? "—")</td>
                            </tr>
                            <!-- <tr>
                                <th class="ps-3">Метка времени данных</th>
                                <td class="ps-3">@(Model.DataTimestamp?.ToString("dd.MM.yyyy HH:mm:ss") ?? "—")</td>
                            </tr> -->
                            <tr>
                                <th class="ps-3">Серийный номер</th>
                                <td class="ps-3 fw-bold">@Model.SerialNumber</td>
                            </tr>
                            <tr>
                                <th class="ps-3">Конечная точка</th>
                                <td class="ps-3">@Model.EndpointName</td>
                            </tr>
                            <tr>
                                <th class="ps-3">Тип датчика</th>
                                <td class="ps-3">@Model.SensorTypeName</td>
                            </tr>
                            <tr>
                                <th class="ps-3">Пост мониторинга</th>
                                <td class="ps-3">@Model.PostName @(Model.PostIsMobile == true ? "(Мобильный)" : "")</td>
                            </tr>
                            @if (!string.IsNullOrEmpty(Model.PostAddress)) {
                            <tr>
                                <th class="ps-3">Адрес поста</th>
                                <td class="ps-3 small">@Model.PostAddress</td>
                            </tr>
                            }
                            <tr>
                                <th class="ps-3 text-primary">Температура бокса</th>
                                <td class="ps-3 fw-bold text-primary">@(Model.TemperatureBox?.ToString("F1") ?? "—")°C</td>
                            </tr>
                            <tr>
                                <th class="ps-3 text-success">Напряжение АКБ</th>
                                <td class="ps-3 fw-bold text-success">@(Model.VoltageAkb?.ToString("F1") ?? "—")V</td>
                            </tr>
                            <tr>
                                <th class="ps-3">Видимость</th>
                                <td class="ps-3 fw-bold">@(Model.VisibleRange?.ToString("F0") ?? "—") м</td>
                            </tr>
                            <tr>
                                <th class="ps-3">Статус двери</th>
                                <td class="ps-3">
                                    @if (Model.DoorStatus == 1) { <span class="badge bg-danger fw-normal">Открыта</span> }
                                    else if (Model.DoorStatus == 0) { <span class="badge bg-success fw-normal">Закрыта</span> }
                                    else { <span class="text-muted">—</span> }
                                </td>
                            </tr>

                            <tr class="table-light"><th colspan="2" class="ps-3 py-2">Электропитание и тех. данные</th></tr>
                            <tr>
                                <th class="ps-3">Питание 12B (вход)</th>
                                <td class="ps-3 small">@(Model.VoltagePowerIn12B?.ToString("F1") ?? "—")V</td>
                            </tr>
                            <tr>
                                <th class="ps-3">Выход 12B (U/I)</th>
                                <td class="ps-3 small">@(Model.VoltageOut12B?.ToString("F1") ?? "—")V / @(Model.CurrentOut12B?.ToString("F2") ?? "—")A</td>
                            </tr>
                            <tr>
                                <th class="ps-3">Выход 48B (I)</th>
                                <td class="ps-3 small">@(Model.CurrentOut48B?.ToString("F2") ?? "—")A</td>
                            </tr>
                            <tr>
                                <th class="ps-3">Ток АКБ</th>
                                <td class="ps-3 small">@(Model.CurrentAkb?.ToString("F2") ?? "—")A</td>
                            </tr>
                            <tr>
                                <th class="ps-3">Вт·ч АКБ</th>
                                <td class="ps-3 small">@(Model.WattHoursAkb?.ToString("F0") ?? "—")</td>
                            </tr>
                            <tr>
                                <th class="ps-3">Датчик 220B</th>
                                <td class="ps-3 small">@Model.Sensor220B</td>
                            </tr>
                            <tr>
                                <th class="ps-3">TDS (H/Val)</th>
                                <td class="ps-3 small">@Model.TdsH / @Model.TdsTds</td>
                            </tr>
                            <tr>
                                <th class="ps-3">Ткоса (T1/T3)</th>
                                <td class="ps-3 small">@Model.TkosaT1 / @Model.TkosaT3</td>
                            </tr>
                            <tr>
                                <th class="ps-3">Температура грунта (Owen CH1)</th>
                                <td class="ps-3 small">@(Model.OwenCh1?.ToString("F2") ?? "—")°C</td>
                            </tr>
                            <tr>
                                <th class="ps-3">Температура грунта (Owen CH2)</th>
                                <td class="ps-3 small">@(Model.OwenCh2?.ToString("F2") ?? "—")°C</td>
                            </tr>

                            <tr class="table-light"><th colspan="2" class="ps-3 py-2">Параметры датчика</th></tr>                            <tr>
                                <th class="ps-3">Координаты</th>
                                <td class="ps-3 small">@(Model.SensorLatitude?.ToString("F6") ?? "—"), @(Model.SensorLongitude?.ToString("F6") ?? "—")</td>
                            </tr>
                            <tr>
                                <th class="ps-3">Последняя активность</th>
                                <td class="ps-3 small">@(Model.LastActivityUtc?.ToString("dd.MM.yyyy HH:mm:ss") ?? "—")</td>
                            </tr>
                            <tr>
                                <th class="ps-3">Статус датчика</th>
                                <td class="ps-3">
                                    @if (Model.SensorIsActive == true) { <span class="badge bg-success fw-normal">Активен</span> }
                                    else { <span class="badge bg-secondary fw-normal">Неактивен</span> }
                                </td>
                            </tr>
                            <tr>
                                <th class="ps-3">URL API</th>
                                <td class="ps-3 small text-break">@Model.SensorUrl</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
                <div class="card-footer bg-light py-2">
                    <a href="javascript:history.back()" class="btn btn-outline-secondary btn-sm">Назад</a>
                </div>
            </div>
        </div>
    </div>
</div>
