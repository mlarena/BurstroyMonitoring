@model IEnumerable<BurstroyMonitoring.Data.Models.WorkerConfigEditViewModel>
@{
    ViewData["Title"] = "Настройки Worker'ов";
}

<div class="container-fluid">
    <h1 class="h3 mb-3">@ViewData["Title"]</h1>
    
    <!-- Сообщения об успехе/ошибке -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show py-2 small mb-3" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close py-2" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-warning alert-dismissible fade show py-2 small mb-3" role="alert">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close py-2" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- Таблица конфигураций -->
    <div class="table-responsive shadow-sm rounded">
        <table class="table table-sm table-hover table-striped align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th style="width: 20%;">Ключ</th>
                    <th style="width: 25%;">Значение</th>
                    <th style="width: 10%;">Тип</th>
                    <th style="width: 25%;">Описание</th>
                    <th style="width: 15%;">Изменено</th>
                    <th style="width: 5%;">Статус</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="small fw-bold">@item.Key</td>
                        <td>
                            <form asp-action="Edit" method="post" class="m-0">
                                <input type="hidden" name="id" value="@item.Id" />
                                @Html.AntiForgeryToken()
                                
                                @if (item.IsBoolean)
                                {
                                    <select name="value" class="form-select form-select-sm" onchange="this.form.submit()">
                                        <option value="true" selected="@(item.Value == "true")">true</option>
                                        <option value="false" selected="@(item.Value == "false")">false</option>
                                    </select>
                                }
                                else if (item.IsInteger)
                                {
                                    <input type="number" name="value" value="@item.Value" 
                                           class="form-control form-control-sm" 
                                           onblur="if(this.value.trim() !== '@item.Value') this.form.submit()" />
                                }
                                else if (item.IsDecimal)
                                {
                                    <input type="number" step="0.01" name="value" value="@item.Value" 
                                           class="form-control form-control-sm" 
                                           onblur="if(this.value.trim() !== '@item.Value') this.form.submit()" />
                                }
                                else if (item.IsJson)
                                {
                                    <button type="button" class="btn btn-outline-secondary btn-sm w-100" 
                                            onclick="editJson(@item.Id, '@item.Key', '@Html.Raw(item.Value.Replace("'", "\\'"))')">
                                        JSON
                                    </button>
                                    <input type="hidden" id="json-@item.Id" name="value" value="@item.Value" />
                                }
                                else
                                {
                                    <input type="text" name="value" value="@item.Value" 
                                           class="form-control form-control-sm" 
                                           onblur="if(this.value.trim() !== '@item.Value') this.form.submit()" />
                                }
                            </form>
                        </td>
                        <td><span class="badge bg-light text-dark border fw-normal">@item.DataType</span></td>
                        <td class="small text-muted">@item.Description</td>
                        <td class="small">
                            <div class="fw-bold">@item.ModifiedBy</div>
                            <div class="text-muted" style="font-size: 0.75rem;">@item.LastModified.ToString("dd.MM.yyyy HH:mm")</div>
                        </td>
                        <td class="text-center">
                            @if (item.IsActive)
                            {
                                <span class="text-success">✓</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Модальное окно для редактирования JSON -->
<div class="modal fade" id="jsonModal" tabindex="-1" aria-labelledby="jsonModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content shadow">
            <div class="modal-header bg-light py-2">
                <h5 class="modal-title h6" id="jsonModalLabel">Редактирование JSON</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-2">
                <textarea id="jsonEditor" class="form-control form-control-sm font-monospace" rows="15" style="font-size: 0.85rem;"></textarea>
                <div id="jsonError" class="alert alert-danger py-1 small mt-2 mb-0" style="display: none;"></div>
            </div>
            <div class="modal-footer py-1">
                <button type="button" class="btn btn-outline-secondary btn-sm" data-bs-dismiss="modal">Отмена</button>
                <button type="button" class="btn btn-primary btn-sm" onclick="saveJson()">Сохранить</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let editingJsonId = null;
        let originalJsonValue = null;
        let bsModal = null;

        document.addEventListener('DOMContentLoaded', function() {
            bsModal = new bootstrap.Modal(document.getElementById('jsonModal'));
        });
        
        function editJson(id, key, value) {
            editingJsonId = id;
            originalJsonValue = value;
            
            try {
                const parsed = JSON.parse(value);
                document.getElementById('jsonEditor').value = JSON.stringify(parsed, null, 2);
            } catch {
                document.getElementById('jsonEditor').value = value;
            }
            
            document.getElementById('jsonError').style.display = 'none';
            bsModal.show();
        }
        
        function saveJson() {
            const jsonText = document.getElementById('jsonEditor').value;
            
            try {
                JSON.parse(jsonText);
                document.getElementById(`json-${editingJsonId}`).value = jsonText;
                const form = document.querySelector(`form input[value="${editingJsonId}"]`).closest('form');
                form.submit();
            } catch (error) {
                const errorDiv = document.getElementById('jsonError');
                errorDiv.textContent = 'Ошибка JSON: ' + error.message;
                errorDiv.style.display = 'block';
            }
        }
    </script>
}