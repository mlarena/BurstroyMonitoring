@model BurstroyMonitoring.Data.Models.VwIwsDataFull

@{
    ViewData["Title"] = "Подробности о данных IWS";
}

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-10 col-lg-8">
            <div class="card shadow-sm">
                <div class="card-header bg-info text-white py-2 d-flex justify-content-between align-items-center">
                    <h1 class="h5 mb-0">Подробности о данных IWS</h1>
                    <span class="badge bg-light text-dark">ID: @Model.IwsDataId</span>
                </div>
                <div class="card-body p-0">
                    <table class="table table-sm mb-0">
                        <tbody>
                            <tr class="table-light"><th colspan="2" class="ps-3 py-2">Основная информация</th></tr>
                            <tr>
                                <th class="ps-3" style="width: 40%;">Дата получения</th>
                                <td class="ps-3">@(Model.ReceivedAt?.ToString("dd.MM.yyyy HH:mm:ss") ?? "—")</td>
                            </tr>
                            <tr>
                                <th class="ps-3">Серийный номер</th>
                                <td class="ps-3 fw-bold">@Model.SerialNumber</td>
                            </tr>
                            <tr>
                                <th class="ps-3">Конечная точка</th>
                                <td class="ps-3">@Model.EndpointName</td>
                            </tr>
                            <tr>
                                <th class="ps-3 text-primary">Температура / Влажность</th>
                                <td class="ps-3 fw-bold text-primary">
                                    @(Model.EnvironmentTemperature?.ToString("F1") ?? "—")°C / @(Model.HumidityPercentage?.ToString("F0") ?? "—")%
                                </td>
                            </tr>
                            <tr>
                                <th class="ps-3">Давление</th>
                                <td class="ps-3">
                                    @(Model.PressureHpa?.ToString("F0") ?? "—") гПа 
                                    <span class="text-muted small">(@(Model.PressureMmhg?.ToString("F1") ?? "—") мм рт.ст.)</span>
                                </td>
                            </tr>
                            <tr>
                                <th class="ps-3">Ветер</th>
                                <td class="ps-3">
                                    @(Model.WindSpeed?.ToString("F1") ?? "—") м/с, @(Model.WindDirection?.ToString("F0") ?? "—")°
                                </td>
                            </tr>
                            <tr>
                                <th class="ps-3">Осадки</th>
                                <td class="ps-3">
                                    @{
                                        string type = Model.PrecipitationType switch {
                                            0 => "Нет", 1 => "Дождь", 2 => "Снег", 3 => "Смешанные", _ => "—"
                                        };
                                    }
                                    <span class="badge bg-light text-dark border fw-normal">@type</span>
                                    <span class="ms-2 small">@(Model.PrecipitationIntensity?.ToString("F1") ?? "0") мм/ч</span>
                                </td>
                            </tr>
                            <tr>
                                <th class="ps-3">Статус</th>
                                <td class="ps-3">
                                    @if (Model.StatusOk == 1) { <span class="badge bg-success fw-normal">OK</span> }
                                    else { <span class="badge bg-danger fw-normal">Ошибка</span> }
                                </td>
                            </tr>
                        </tbody>
                    </table>

                    <div class="collapse" id="additionalFields">
                        <table class="table table-sm mb-0 border-top">
                            <tbody>
                                <tr class="table-light"><th colspan="2" class="ps-3 py-2">Технические данные</th></tr>
                                <tr>
                                    <th class="ps-3" style="width: 40%;">Точка росы</th>
                                    <td class="ps-3 small">@(Model.DewPoint?.ToString("F1") ?? "—")°C</td>
                                </tr>
                                <tr>
                                    <th class="ps-3">CO2 Level</th>
                                    <td class="ps-3 small">@(Model.CO2Level?.ToString("F0") ?? "—") ppm</td>
                                </tr>
                                <tr>
                                    <th class="ps-3">Напряжение питания</th>
                                    <td class="ps-3 small">@(Model.SupplyVoltage?.ToString("F1") ?? "—")V</td>
                                </tr>
                                <tr>
                                    <th class="ps-3">Координаты (GPS)</th>
                                    <td class="ps-3 small">@Model.IwsLatitude, @Model.IwsLongitude (@Model.Altitude м)</td>
                                </tr>
                                <tr>
                                    <th class="ps-3">Спутники (KSP)</th>
                                    <td class="ps-3 small">@Model.KspValue</td>
                                </tr>
                                <tr>
                                    <th class="ps-3">Крен / Тангаж</th>
                                    <td class="ps-3 small">@Model.RollAngle° / @Model.PitchAngle°</td>
                                </tr>
                                <tr>
                                    <th class="ps-3">URL API</th>
                                    <td class="ps-3 small text-break">@Model.SensorUrl</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
                <div class="card-footer bg-light d-flex justify-content-between py-2">
                    <a href="javascript:history.back()" class="btn btn-outline-secondary btn-sm">Назад</a>
                    <button class="btn btn-outline-info btn-sm" type="button" data-bs-toggle="collapse" data-bs-target="#additionalFields">
                        Тех. данные
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>
