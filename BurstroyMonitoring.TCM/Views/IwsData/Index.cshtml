@model IEnumerable<BurstroyMonitoring.Data.Models.VwIwsDataFull>

@{
    ViewData["Title"] = "Данные IWS";

    string GetWindDirection(decimal? degrees) {
        if (!degrees.HasValue) return "—";
        double d = (double)degrees.Value;
        if (d >= 337.5 || d < 22.5) return "С";
        if (d >= 22.5 && d < 67.5) return "СВ";
        if (d >= 67.5 && d < 112.5) return "В";
        if (d >= 112.5 && d < 157.5) return "ЮВ";
        if (d >= 157.5 && d < 202.5) return "Ю";
        if (d >= 202.5 && d < 247.5) return "ЮЗ";
        if (d >= 247.5 && d < 292.5) return "З";
        if (d >= 292.5 && d < 337.5) return "СЗ";
        return "—";
    }
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1 class="h3 mb-0">Данные IWS</h1>
        <div class="d-flex gap-2 align-items-center">
            <div class="form-check form-switch me-2">
                <input class="form-check-input" type="checkbox" role="switch" id="autoRefresh">
                <label class="form-check-label small" for="autoRefresh">Автообновление</label>
            </div>
            <a href="@Url.Action("DataViewer")" class="btn btn-outline-primary btn-sm">Просмотр и экспорт</a>
        </div>
    </div>

    <!-- Поиск и фильтры -->
    <div class="card mb-3 shadow-sm">
        <div class="card-body py-2">
            <form method="get" class="row g-2 align-items-center">
                <div class="col-auto flex-grow-1 position-relative">
                    <input type="text" name="search" value="@ViewBag.Search" 
                           placeholder="Поиск по S/N, названию точки..." 
                           class="form-control form-control-sm" 
                           id="searchInput" autocomplete="off" list="searchList" />
                    <datalist id="searchList"></datalist>
                </div>
                <div class="col-auto">
                    <button type="submit" class="btn btn-primary btn-sm">Найти</button>
                    <a href="@Url.Action("Index")" class="btn btn-outline-secondary btn-sm">Сбросить</a>
                </div>
            </form>
        </div>
    </div>

    <!-- Пагинация сверху -->
    <div class="mb-2">
        @await Html.PartialAsync("_Pagination")
    </div>

    <!-- Таблица данных -->
    <div class="table-responsive shadow-sm rounded">
        <table class="table table-sm table-hover table-striped align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <!-- <th>
                        <a href="@Url.Action("Index", new { 
                            page = ViewBag.Page, 
                            pageSize = ViewBag.PageSize, 
                            search = ViewBag.Search,
                            sortBy = "IwsDataId",
                            sortDesc = ViewBag.SortBy == "IwsDataId" ? !ViewBag.SortDesc : true
                        })" class="text-decoration-none text-dark">
                            ID @(ViewBag.SortBy == "IwsDataId" ? (ViewBag.SortDesc ? "▼" : "▲") : "")
                        </a>
                    </th> -->
                    <th>Дата</th>
                    <th>S/N</th>
                     <th>Наименование датчика</th>
                    <th>Темп.</th>
                    <th>Влажн.</th>
                    <th>Давл.</th>
                    <th>Скорость ветра</th>
                    <th>Направление</th>
                    <th>Осадки</th>
                    <th class="text-end">Детали</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <!-- <td class="small text-muted">@item.IwsDataId</td> -->
                        <td class="text-nowrap small">@item.ReceivedAt?.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
                        <td class="fw-bold small">@item.SerialNumber</td>
                        <td class="text-truncate small" style="max-width: 150px;" title="@item.EndpointName">@item.EndpointName</td>
                        <td>
                            @if (item.EnvironmentTemperature.HasValue)
                            {
                                <span>@item.EnvironmentTemperature.Value.ToString("F1")°C</span>
                            }
                            else
                            {
                                <span class="text-muted small">—</span>
                            }
                        </td>
                        <td>
                            @if (item.HumidityPercentage.HasValue)
                            {
                                <span>@item.HumidityPercentage.Value.ToString("F0")%</span>
                            }
                            else
                            {
                                <span class="text-muted small">—</span>
                            }
                        </td>
                        <td>
                            @if (item.PressureHpa.HasValue)
                            {
                                <span>@item.PressureHpa.Value.ToString("F0") гПа</span>
                            }
                            else
                            {
                                <span class="text-muted small">—</span>
                            }
                        </td>
                        <td>
                            @if (item.WindSpeed.HasValue)
                            {
                                <span>@item.WindSpeed.Value.ToString("F1") м/с</span>
                            }
                            else
                            {
                                <span class="text-muted small">—</span>
                            }
                        </td>
                        <td>
                            @if (item.WindDirection.HasValue)
                            {
                                <span title="@item.WindDirection.Value.ToString("F0")°">
                                    @GetWindDirection(item.WindDirection) (@item.WindDirection.Value.ToString("F0")°)
                                </span>
                            }
                            else
                            {
                                <span class="text-muted small">—</span>
                            }
                        </td>
                        <td>
                            @{
                                string type = item.PrecipitationType switch {
                                    0 => "Нет",
                                    51 => "Морось",
                                    96 => "Дождь",
                                    103 => "Лед. дождь",
                                    105 => "Снег с дож.",
                                    112 => "Снег",
                                    144 => "Град",
                                    255 => "Неизв.",
                                    _ => "—"
                                };
                            }
                            <span title="Код: @item.PrecipitationType">@type</span>
                        </td>                        <td class="text-end">
                            <a asp-action="Details" asp-route-id="@item.IwsDataId" 
                               class="btn btn-outline-secondary btn-sm py-0 px-2" title="Детали">
                                📊
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Пагинация снизу -->
    <div class="mt-3">
        @await Html.PartialAsync("_Pagination")
    </div>

    <!-- Информация о количестве записей -->
    <div class="mt-2 small text-muted text-end">
        Показано @(((ViewBag.Page - 1) * ViewBag.PageSize) + 1)-@Math.Min(ViewBag.Page * ViewBag.PageSize, ViewBag.TotalCount) 
        из @ViewBag.TotalCount записей
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('searchInput').addEventListener('input', async function() {
            const term = this.value;
            const datalist = document.getElementById('searchList');
            
            if (term.length < 1) {
                datalist.innerHTML = '';
                return;
            }

            try {
                const controller = window.location.pathname.split('/')[1];
                const response = await fetch(`/${controller}/Autocomplete?term=${encodeURIComponent(term)}`);
                const suggestions = await response.json();
                
                datalist.innerHTML = '';
                suggestions.forEach(item => {
                    const option = document.createElement('option');
                    option.value = item;
                    datalist.appendChild(option);
                });
            } catch (error) {
                console.error('Error fetching autocomplete suggestions:', error);
            }
        });
    </script>
    <script src="~/js/autoRefresh.js"></script>
}