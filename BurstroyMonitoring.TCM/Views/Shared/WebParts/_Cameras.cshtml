@using BurstroyMonitoring.Data.Models
@model List<Camera>

<div class="d-flex flex-column h-100">
    <div class="d-flex justify-content-between align-items-center mb-2">
        <span class="small text-muted">Камер: <strong>@Model.Count</strong></span>
        <a asp-controller="Cameras" asp-action="Index" class="btn btn-outline-primary btn-sm">
            <i class="bi bi-box-arrow-up-right"></i> Открыть
        </a>
    </div>
    @if (!Model.Any())
    {
        <div class="d-flex flex-column align-items-center justify-content-center flex-grow-1 text-center">
            <i class="bi bi-camera-video-off text-muted" style="font-size: 2.5rem;"></i>
            <p class="text-muted small mt-2">Нет добавленных камер</p>
        </div>
    }
    else
    {
        <div class="table-responsive flex-grow-1" style="overflow-y: auto;">
            <table class="table table-sm table-hover mb-0">
                <thead class="table-light sticky-top">
                    <tr>
                        <th>Название</th>
                        <th>Адрес</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var cam in Model)
                    {
                        <tr>
                            <td class="fw-semibold">@cam.Name</td>
                            <td class="text-muted small text-truncate" style="max-width:150px;">@cam.InstallationLocation</td>
                            <td>
                                <a asp-controller="Cameras" asp-action="Details" asp-route-id="@cam.Id"
                                   class="btn btn-outline-secondary btn-sm py-0 px-1">
                                    <i class="bi bi-eye"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
