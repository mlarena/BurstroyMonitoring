@using BurstroyMonitoring.Data.Models
@model List<MonitoringPost>

<div class="d-flex flex-column h-100">
    <div class="d-flex justify-content-between align-items-center mb-2">
        <span class="small text-muted">Всего: <strong>@Model.Count</strong></span>
        <a asp-controller="MonitoringPosts" asp-action="Index" class="btn btn-outline-primary btn-sm">
            <i class="bi bi-box-arrow-up-right"></i> Открыть
        </a>
    </div>
    <div class="table-responsive flex-grow-1" style="overflow-y: auto;">
        <table class="table table-sm table-hover mb-0">
            <thead class="table-light sticky-top">
                <tr>
                    <th>Название</th>
                    <th class="text-center">Датчики</th>
                    <th class="text-center">Статус</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr><td colspan="3" class="text-center text-muted py-3">Нет постов</td></tr>
                }
                @foreach (var post in Model)
                {
                    <tr>
                        <td>
                            <a asp-controller="MonitoringPosts" asp-action="Details" asp-route-id="@post.Id" class="text-decoration-none fw-semibold">
                                @post.Name
                            </a>
                            @if (post.IsMobile)
                            {
                                <span class="badge bg-info ms-1" style="font-size:0.65rem;">моб.</span>
                            }
                        </td>
                        <td class="text-center">
                            <span class="badge bg-primary">@(post.Sensors?.Count ?? 0)</span>
                        </td>
                        <td class="text-center">
                            @if (post.IsActive)
                            {
                                <span class="text-success"><i class="bi bi-circle-fill" style="font-size:0.6rem;"></i></span>
                            }
                            else
                            {
                                <span class="text-danger"><i class="bi bi-circle" style="font-size:0.6rem;"></i></span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
