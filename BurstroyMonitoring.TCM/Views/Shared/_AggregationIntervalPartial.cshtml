@model dynamic
@{
    var prefix = Model?.Prefix ?? "";
    // Убираем OutlineColor, используем фиксированный класс
    var activeInterval = Model?.ActiveInterval ?? "hour";
}

<div class="d-flex align-center aggregation-interval-control" 
     data-prefix="@prefix" 
     data-active-interval="@activeInterval"
     style="gap: var(--spacing-sm);">
    <i class="fas fa-chart-line text-secondary" style="font-size: 14px;"></i>
    <span class="text-secondary" style="margin-right: var(--spacing-sm); font-size: 14px;">Агрегация:</span>
    
    <div class="btn-group aggregation-btn-group" role="group" style="display: flex; gap: 2px;">
        <button type="button" 
                class="button button--sm button--secondary aggregation-btn @(activeInterval == "raw" ? "active" : "")" 
                data-interval="raw"
                data-prefix="@prefix"
                style="border-radius: var(--radius-small) 0 0 var(--radius-small);"
                title="Все данные без группировки (Raw data)">
            Все
        </button>
        <button type="button" 
                class="button button--sm button--secondary aggregation-btn @(activeInterval == "tenminutes" ? "active" : "")" 
                data-interval="tenminutes"
                data-prefix="@prefix"
                style="border-radius: 0;"
                title="Усреднение по 10 минутам">
            10 мин
        </button>
        <button type="button" 
                class="button button--sm button--secondary aggregation-btn @(activeInterval == "hour" ? "active" : "")" 
                data-interval="hour"
                data-prefix="@prefix"
                style="border-radius: 0 var(--radius-small) var(--radius-small) 0;"
                title="Усреднение по часам">
            По часам
        </button>
    </div>
</div>