<!DOCTYPE html>
<html lang="ru">
@{
    System.Threading.Thread.CurrentThread.CurrentCulture =
        System.Globalization.CultureInfo.GetCultureInfo("ru-RU");
    System.Threading.Thread.CurrentThread.CurrentUICulture =
        System.Globalization.CultureInfo.GetCultureInfo("ru-RU");
}
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Мониторинг датчиков</title>
    <!-- Bootstrap 5.3 CSS -->
    <link rel="stylesheet" href="~/css/bootstrap.min.css" asp-append-version="true" />
     <link rel="stylesheet" href="~/css/font/bootstrap-icons.css" asp-append-version="true" >
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @RenderSection("Styles", required: false)
</head>
<body class="d-flex flex-column min-vh-100">
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-primary shadow-sm py-1">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">ТЦУ-М</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Home" ? "active" : "")" asp-controller="Home" asp-action="Index">Главная</a>
                        </li>
                        
                        <li class="nav-item dropdown">
                            @{
                                var currentController = ViewContext.RouteData.Values["Controller"]?.ToString();
                                var isDictionariesActive = new[] { "MonitoringPosts", "SensorTypes", "Sensors", "WorkerConfiguration" }.Contains(currentController);
                            }
                            <a class="nav-link dropdown-toggle @(isDictionariesActive ? "active" : "")" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                Справочники
                            </a>
                            <ul class="dropdown-menu shadow">
                                <li><a class="dropdown-item @(currentController == "MonitoringPosts" ? "active" : "")" asp-controller="MonitoringPosts" asp-action="Index">Посты мониторинга</a></li>
                                <li><a class="dropdown-item @(currentController == "SensorTypes" ? "active" : "")" asp-controller="SensorTypes" asp-action="Index">Типы датчиков</a></li>
                                <li><a class="dropdown-item @(currentController == "Sensors" ? "active" : "")" asp-controller="Sensors" asp-action="Index">Датчики</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item @(currentController == "WorkerConfiguration" ? "active" : "")" asp-controller="WorkerConfiguration" asp-action="Index">Настройки</a></li>
                            </ul>
                        </li>

                        <li class="nav-item dropdown">
                            @{
                                var dataControllers = new[] { "MueksData", "IwsData", "DspdData", "DovData", "DustData" };
                                var isDataActive = dataControllers.Contains(currentController);
                            }
                            <a class="nav-link dropdown-toggle @(isDataActive ? "active" : "")" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                Данные
                            </a>
                            <ul class="dropdown-menu shadow">
                                <li><a class="dropdown-item @(currentController == "MueksData" ? "active" : "")" asp-controller="MueksData" asp-action="Index">MUEKS</a></li>
                                <li><a class="dropdown-item @(currentController == "IwsData" ? "active" : "")" asp-controller="IwsData" asp-action="Index">IWS</a></li>
                                <li><a class="dropdown-item @(currentController == "DspdData" ? "active" : "")" asp-controller="DspdData" asp-action="Index">DSPD</a></li>
                                <li><a class="dropdown-item @(currentController == "DovData" ? "active" : "")" asp-controller="DovData" asp-action="Index">DOV</a></li>
                                <li><a class="dropdown-item @(currentController == "DustData" ? "active" : "")" asp-controller="DustData" asp-action="Index">DUST</a></li>
                            </ul>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link @(currentController == "SensorResults" ? "active" : "")" asp-controller="SensorResults" asp-action="Index">Результаты</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(currentController == "GraphsAndCharts" ? "active" : "")" asp-controller="GraphsAndCharts" asp-action="Index">Графики</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(currentController == "MonitoringMap" ? "active" : "")" asp-controller="MonitoringMap" asp-action="Index">Карта</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(currentController == "Cameras" ? "active" : "")" asp-controller="Cameras" asp-action="Index">Камеры</a>
                        </li>

                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item dropdown border-start ms-lg-2 ps-lg-2">
                                <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    Админ
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end shadow">
                                    <li><a class="dropdown-item @(currentController == "SensorErrors" ? "active" : "")" asp-controller="SensorErrors" asp-action="Index">Ошибки</a></li>
                                    <li><a class="dropdown-item @(currentController == "Admin" ? "active" : "")" asp-controller="Admin" asp-action="Index">Пользователи</a></li>
                                    <li><a class="dropdown-item @(currentController == "Audit" ? "active" : "")" asp-controller="Audit" asp-action="Index">Аудит</a></li>
                                </ul>
                            </li>
                        }
                    </ul>
                    
                    <div class="d-flex align-items-center gap-3">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <span class="navbar-text text-light small d-none d-xl-inline">@User.Identity.Name</span>
                            <form asp-controller="Auth" asp-action="Logout" method="post" class="m-0">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-outline-light btn-sm">Выйти</button>
                            </form>
                        }
                        <button id="theme-toggle" class="btn btn-sm btn-outline-light border-0 fs-5" title="Переключить тему">
                            ...
                        </button>
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <main class="flex-grow-1 container-fluid py-3">
        @RenderBody()
    </main>

    <footer class="footer mt-auto py-2 bg-body-tertiary border-top">
        <div class="container-fluid text-center">
            <span class="text-muted small">&copy; @DateTime.Now.Year - BurstroyMonitoring.TCM</span>
        </div>
    </footer>
    
    <script src="/js/lib/jquery.min.js"></script>
    <script src="/js/lib/bootstrap.bundle.min.js"></script>
    <script src="/js/lib/jquery.validate.min.js"></script>
    <script src="/js/lib/jquery.validate.unobtrusive.min.js"></script>
    <script src="/js/site.js" asp-append-version="true"></script>
    <script src="/js/coordinateValidation.js" asp-append-version="true"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>