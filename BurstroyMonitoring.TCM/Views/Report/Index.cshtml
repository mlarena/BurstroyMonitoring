@model BurstroyMonitoring.Data.Models.ViewModels.SensorSelectionViewModel

@{
    ViewData["Title"] = "Сводные отчеты";
}

@section Styles {
    <link rel="stylesheet" href="~/lib/flatpickr/flatpickr.min.css">
}

<div class="container-fluid">
    <h1 class="h3 mb-3">Сводные отчеты</h1>
    
    <div class="card mb-3 shadow-sm">
        <div class="card-body py-2">
            <form id="reportForm" class="row g-2 align-items-end">
                @Html.AntiForgeryToken()
                <div class="col-md-4">
                    <label for="monitoringPostSelect" class="form-label small fw-bold mb-1">Пост мониторинга</label>
                    <select id="monitoringPostSelect" class="form-select form-select-sm" 
                            asp-for="SelectedMonitoringPostId" 
                            asp-items="Model.MonitoringPosts">                           
                    </select>
                </div>
                <div id="dateRangeControls" class="col-md-5 d-none">
                    <div class="row g-2">
                        <div class="col-md-4">
                            <label for="startDate" class="form-label small fw-bold mb-1">Дата начала</label>
                            <input type="text" id="startDate" class="form-control form-control-sm bg-white" placeholder="Выберите дату" readonly />
                        </div>
                        <div class="col-md-4">
                            <label for="endDate" class="form-label small fw-bold mb-1">Дата окончания</label>
                            <input type="text" id="endDate" class="form-control form-control-sm bg-white" placeholder="Выберите дату" readonly />
                        </div>
                        <div class="col-md-4">
                            <label for="intervalSelect" class="form-label small fw-bold mb-1">Интервал</label>
                            <select id="intervalSelect" class="form-select form-select-sm">
                                <option value="10">10 мин</option>
                                <option value="30">30 мин</option>
                                <option value="60">1 час</option>
                            </select>
                        </div>
                    </div>
                </div>
                <div id="submitControl" class="col-md-3 d-none">
                    <div class="btn-group btn-group-sm w-100">
                        <button type="button" id="btnGenerateReport" class="btn btn-primary">Сформировать</button>
                        <button type="button" class="btn btn-success" onclick="exportReport('excel')" title="Экспорт в Excel">
                            <i class="bi bi-file-earmark-excel"></i>
                        </button>
                        <button type="button" class="btn btn-secondary" onclick="exportReport('csv')" title="Экспорт в CSV">
                            <i class="bi bi-file-earmark-spreadsheet"></i>
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>
    <div id="reportContent" class="mt-4">
        <!-- Здесь будет отображаться контент отчета -->
        <div class="alert alert-info">
            Выберите пост мониторинга для формирования отчета.
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/lib/flatpickr/flatpickr.min.js"></script>
    <script src="~/lib/flatpickr/ru.js"></script>
    <script>
        $(document).ready(function () {
            // Установка дат по умолчанию
            const today = new Date();
            const thirtyDaysAgo = new Date();
            thirtyDaysAgo.setDate(today.getDate() - 30);

            // Инициализация Flatpickr с русской локализацией
            const flatpickrConfig = {
                locale: "ru",
                dateFormat: "Y-m-d", // Передаем в ISO формате для надежности парсинга
                altInput: true,      // Пользователь видит красивый формат
                altFormat: "d.m.Y",  // Формат для отображения пользователю
                allowInput: true,
                disableMobile: "true"
            };

            const startPicker = flatpickr("#startDate", {
                ...flatpickrConfig,
                defaultDate: thirtyDaysAgo
            });

            const endPicker = flatpickr("#endDate", {
                ...flatpickrConfig,
                defaultDate: today
            });

            $('#monitoringPostSelect').change(function () {
                var postId = $(this).val();
                if (postId) {
                    // Показываем контролы даты и кнопку
                    $('#dateRangeControls').removeClass('d-none');
                    $('#submitControl').removeClass('d-none');
                    $('#reportContent').html('<div class="alert alert-info">Настройте даты и нажмите "Сформировать".</div>');
                } else {
                    // Скрываем контролы
                    $('#dateRangeControls').addClass('d-none');
                    $('#submitControl').addClass('d-none');
                    $('#reportContent').html('<div class="alert alert-info">Выберите пост мониторинга для формирования отчета.</div>');
                }
            });

            $('#btnGenerateReport').click(function () {
                const postId = $('#monitoringPostSelect').val();
                const startDate = $('#startDate').val();
                const endDate = $('#endDate').val();
                const interval = $('#intervalSelect').val();

                if (!postId) return;

                $('#reportContent').html('<div class="text-center mt-5"><div class="spinner-border text-primary" role="status"><span class="visually-hidden">Загрузка...</span></div><p class="mt-2">Формирование отчета...</p></div>');
                
                $.get('/Report/GetReportData', { postId, startDate, endDate, intervalMinutes: interval }, function(data) {
                    console.log('[Report] Данные от сервера:', data);
                    
                    if (!data.rows || data.rows.length === 0) {
                        $('#reportContent').html('<div class="alert alert-warning">Нет данных за выбранный период.</div>');
                        return;
                    }

                    // Группируем колонки по датчикам (для двухуровневого заголовка)
                    const sensorGroups = [];
                    const sensorToFields = {};
                    
                    data.columns.forEach(col => {
                        const parts = col.split('|');
                        const sensor = parts[0];
                        const field = parts[1];
                        
                        if (!sensorToFields[sensor]) {
                            sensorToFields[sensor] = [];
                            sensorGroups.push(sensor);
                        }
                        sensorToFields[sensor].push(field);
                    });

                    console.log('[Report] Группы датчиков:', sensorGroups);
                    console.log('[Report] Поля по датчикам:', sensorToFields);

                    let tableHtml = `
                        <div class="report-table-container mt-3">
                            <div class="top-scrollbar" style="overflow-x: auto; overflow-y: hidden; height: 20px;">
                                <div class="top-scrollbar-content" style="height: 20px;"></div>
                            </div>
                            
                            <div class="table-responsive main-table-scroll" style="overflow-x: auto;">
                                <table class="table table-sm table-bordered table-hover small mb-0">
                                    <thead class="table-light">
                                        <tr>
                                            <th rowspan="2" class="align-middle text-center">Время</th>
                                            ${sensorGroups.map(s => `<th colspan="${sensorToFields[s].length}" class="text-center">${s}</th>`).join('')}
                                        </tr>
                                        <tr>
                                            ${sensorGroups.map(s => sensorToFields[s].map(f => `<th class="text-center">${f}</th>`).join('')).join('')}
                                        </tr>
                                    </thead>
                                    <tbody>
                                        ${data.rows.map(row => `
                                            <tr>
                                                <td class="text-nowrap">${row.time}</td>
                                                ${data.columns.map(col => `<td class="text-center">${row.values[col] || '-'}</td>`).join('')}
                                            </tr>
                                        `).join('')}
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    `;
                    $('#reportContent').html(tableHtml);

                    // Синхронизация скроллбаров
                    const $topScroll = $('.top-scrollbar');
                    const $mainScroll = $('.main-table-scroll');
                    const $table = $mainScroll.find('table');

                    // Устанавливаем ширину внутреннего блока верхнего скролла равной ширине таблицы
                    $('.top-scrollbar-content').width($table.width());

                    $topScroll.on('scroll', function() {
                        $mainScroll.scrollLeft($topScroll.scrollLeft());
                    });

                    $mainScroll.on('scroll', function() {
                        $topScroll.scrollLeft($mainScroll.scrollLeft());
                    });

                }).fail(function(err) {
                    $('#reportContent').html('<div class="alert alert-danger">Ошибка при загрузке данных: ' + (err.responseJSON?.error || 'Неизвестная ошибка') + '</div>');
                });
            });
        });

        function exportReport(format) {
            const postId = $('#monitoringPostSelect').val();
            const startDate = $('#startDate').val();
            const endDate = $('#endDate').val();
            const interval = $('#intervalSelect').val();

            if (!postId) return;

            const tempForm = document.createElement('form');
            tempForm.method = 'POST';
            tempForm.action = '/Report/ExportReport';
            
            const params = { postId, startDate, endDate, intervalMinutes: interval, format };
            for (const key in params) {
                const input = document.createElement('input');
                input.type = 'hidden'; input.name = key; input.value = params[key];
                tempForm.appendChild(input);
            }

            // Добавляем Anti-Forgery Token
            const token = document.querySelector('input[name="__RequestVerificationToken"]');
            if (token) {
                const tokenInput = document.createElement('input');
                tokenInput.type = 'hidden'; tokenInput.name = '__RequestVerificationToken'; tokenInput.value = token.value;
                tempForm.appendChild(tokenInput);
            }
            
            document.body.appendChild(tempForm);
            tempForm.submit();
            document.body.removeChild(tempForm);
        }
    </script>
}
