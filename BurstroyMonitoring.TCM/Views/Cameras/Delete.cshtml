@model BurstroyMonitoring.Data.Models.Camera
@{
    ViewData["Title"] = "Удалить камеру";
}

<div class="container-fluid">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm border-danger">
                <div class="card-header bg-danger text-white py-3">
                    <h1 class="h5 mb-0">Подтверждение удаления</h1>
                </div>
                <div class="card-body">
                    <p class="lead">Вы уверены, что хотите удалить камеру <strong>@Model.Name</strong>?</p>
                    <div class="alert alert-warning small">
                        <i class="bi bi-exclamation-triangle me-2"></i>
                        Это действие также удалит все связанные снимки из базы данных. Файлы на диске останутся.
                    </div>
                    
                    <dl class="row small mt-4">
                        <dt class="col-sm-4">URL потока</dt>
                        <dd class="col-sm-8 text-truncate">@Model.RtspUrl</dd>
                        
                        <dt class="col-sm-4">Пост</dt>
                        <dd class="col-sm-8">@(Model.MonitoringPost?.Name ?? "Не указан")</dd>
                    </dl>

                    <form asp-action="Delete">
                        <input type="hidden" asp-for="Id" />
                        <div class="mt-4 pt-3 border-top d-flex gap-2">
                            <button type="submit" class="btn btn-danger">Удалить навсегда</button>
                            <a asp-action="Index" class="btn btn-outline-secondary">Отмена</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
