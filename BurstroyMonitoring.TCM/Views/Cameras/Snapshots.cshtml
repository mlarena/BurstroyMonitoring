@model IEnumerable<BurstroyMonitoring.Data.Models.Snapshot>
@{
    ViewData["Title"] = "Архив снимков";
}

@section Styles {
    <link rel="stylesheet" href="~/lib/flatpickr/flatpickr.min.css">
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0">Архив снимков</h1>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a asp-action="Index">Камеры</a></li>
                <li class="breadcrumb-item active">Снимки</li>
            </ol>
        </nav>
    </div>

    <!-- Фильтры -->
    <div class="card shadow-sm mb-4">
        <div class="card-body py-2">
            <form method="get" class="row g-2 align-items-end">
                <div class="col-auto">
                    <label class="form-label small fw-bold mb-1">Камера</label>
                    <select name="cameraId" class="form-select form-select-sm" asp-items="ViewBag.Cameras" style="width: auto; min-width: 200px;">
                        <option value="">Все камеры</option>
                    </select>
                </div>
                <div class="col-auto">
                    <label class="form-label small fw-bold mb-1">С даты</label>
                    <input type="text" id="from" name="from" class="form-control form-control-sm bg-white" style="width: 160px;" value="@(ViewBag.From is DateTime fromDate ? fromDate.ToString("yyyy-MM-dd HH:mm") : Context.Request.Query["from"])" placeholder="Выберите дату" readonly />
                </div>
                <div class="col-auto">
                    <label class="form-label small fw-bold mb-1">По дату</label>
                    <input type="text" id="to" name="to" class="form-control form-control-sm bg-white" style="width: 160px;" value="@(ViewBag.To is DateTime toDate ? toDate.ToString("yyyy-MM-dd HH:mm") : Context.Request.Query["to"])" placeholder="Выберите дату" readonly />
                </div>
                <div class="col-auto d-flex gap-2 align-items-center">
                    <button type="submit" class="btn btn-primary btn-sm">Применить</button>
                    <button type="submit" asp-action="DownloadSnapshots" class="btn btn-success btn-sm" title="Выгрузить снимки в ZIP">
                        <i class="bi bi-file-earmark-zip"></i> Выгрузить
                    </button>
                    <div class="form-check form-switch mb-0 ms-2" title="Автоматически обновлять страницу каждые 30 секунд">
                        <input class="form-check-input" type="checkbox" id="autoRefreshCheck">
                        <label class="form-check-label small" for="autoRefreshCheck">Автообновление</label>
                    </div>
                    <a asp-action="Snapshots" class="btn btn-outline-secondary btn-sm">Сброс</a>
                </div>
            </form>
        </div>
    </div>

    <!-- Верхняя пагинация -->
    @if (ViewBag.TotalPages > 1)
    {
        <div class="d-flex justify-content-between align-items-center mb-3">
            <div class="small text-muted">
                Страница @ViewBag.CurrentPage из @ViewBag.TotalPages
            </div>
            <nav aria-label="Top Page navigation">
                <ul class="pagination pagination-sm mb-0">
                    <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                        <a class="page-link" asp-action="Snapshots" 
                           asp-route-page="@(ViewBag.CurrentPage - 1)" 
                           asp-route-cameraId="@ViewBag.CameraId" 
                           asp-route-from="@ViewBag.From" 
                           asp-route-to="@ViewBag.To">Назад</a>
                    </li>
                    
                    @{
                        int currentPage = ViewBag.CurrentPage;
                        int totalPages = ViewBag.TotalPages;
                        int startPage = Math.Max(1, currentPage - 2);
                        int endPage = Math.Min(totalPages, currentPage + 2);
                    }

                    @if (startPage > 1)
                    {
                        <li class="page-item">
                            <a class="page-link" asp-action="Snapshots" asp-route-page="1" asp-route-cameraId="@ViewBag.CameraId" asp-route-from="@ViewBag.From" asp-route-to="@ViewBag.To">1</a>
                        </li>
                        @if (startPage > 2)
                        {
                            <li class="page-item disabled"><span class="page-link">...</span></li>
                        }
                    }

                    @for (int i = startPage; i <= endPage; i++)
                    {
                        <li class="page-item @(i == currentPage ? "active" : "")">
                            <a class="page-link" asp-action="Snapshots" 
                               asp-route-page="@i" 
                               asp-route-cameraId="@ViewBag.CameraId" 
                               asp-route-from="@ViewBag.From" 
                               asp-route-to="@ViewBag.To">@i</a>
                        </li>
                    }

                    @if (endPage < totalPages)
                    {
                        @if (endPage < totalPages - 1)
                        {
                            <li class="page-item disabled"><span class="page-link">...</span></li>
                        }
                        <li class="page-item">
                            <a class="page-link" asp-action="Snapshots" asp-route-page="@totalPages" asp-route-cameraId="@ViewBag.CameraId" asp-route-from="@ViewBag.From" asp-route-to="@ViewBag.To">@totalPages</a>
                        </li>
                    }

                    <li class="page-item @(ViewBag.CurrentPage == ViewBag.TotalPages ? "disabled" : "")">
                        <a class="page-link" asp-action="Snapshots" 
                           asp-route-page="@(ViewBag.CurrentPage + 1)" 
                           asp-route-cameraId="@ViewBag.CameraId" 
                           asp-route-from="@ViewBag.From" 
                           asp-route-to="@ViewBag.To">Вперед</a>
                    </li>
                </ul>
            </nav>
        </div>
    }

    <!-- Сетка снимков -->    <div class="row row-cols-2 row-cols-md-3 row-cols-lg-5 g-3">
        @foreach (var snap in Model)
        {
            <div class="col">
                <div class="card h-100 shadow-sm border-0 overflow-hidden">
                    <div class="position-relative" style="padding-top: 56.25%;">
                        <img src="@snap.FilePath" 
                             class="position-absolute top-0 start-0 w-100 h-100 object-fit-cover" 
                             style="cursor: pointer;" 
                             onclick="showModal('@snap.FilePath', '@(snap.Camera?.Name ?? "Камера")', '@snap.CreatedAt.ToLocalTime()')" />
                    </div>
                    <div class="card-body p-2 bg-light">
                        <div class="small fw-bold text-truncate">@(snap.Camera?.Name ?? "Камера")</div>
                        <div class="text-muted" style="font-size: 0.75rem;">@snap.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm:ss")</div>
                    </div>
                </div>
            </div>
        }
    </div>

    <!-- Пагинация -->
    @if (ViewBag.TotalPages > 1)
    {
        <nav aria-label="Page navigation" class="mt-4">
            <ul class="pagination pagination-sm justify-content-center">
                <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                    <a class="page-link" asp-action="Snapshots" 
                       asp-route-page="@(ViewBag.CurrentPage - 1)" 
                       asp-route-cameraId="@ViewBag.CameraId" 
                       asp-route-from="@ViewBag.From" 
                       asp-route-to="@ViewBag.To">Назад</a>
                </li>

                @{
                    int cp = ViewBag.CurrentPage;
                    int tp = ViewBag.TotalPages;
                    int sp = Math.Max(1, cp - 2);
                    int ep = Math.Min(tp, cp + 2);
                }

                @if (sp > 1)
                {
                    <li class="page-item">
                        <a class="page-link" asp-action="Snapshots" asp-route-page="1" asp-route-cameraId="@ViewBag.CameraId" asp-route-from="@ViewBag.From" asp-route-to="@ViewBag.To">1</a>
                    </li>
                    @if (sp > 2)
                    {
                        <li class="page-item disabled"><span class="page-link">...</span></li>
                    }
                }

                @for (int i = sp; i <= ep; i++)
                {
                    <li class="page-item @(i == cp ? "active" : "")">
                        <a class="page-link" asp-action="Snapshots" 
                           asp-route-page="@i" 
                           asp-route-cameraId="@ViewBag.CameraId" 
                           asp-route-from="@ViewBag.From" 
                           asp-route-to="@ViewBag.To">@i</a>
                    </li>
                }

                @if (ep < tp)
                {
                    @if (ep < tp - 1)
                    {
                        <li class="page-item disabled"><span class="page-link">...</span></li>
                    }
                    <li class="page-item">
                        <a class="page-link" asp-action="Snapshots" asp-route-page="@tp" asp-route-cameraId="@ViewBag.CameraId" asp-route-from="@ViewBag.From" asp-route-to="@ViewBag.To">@tp</a>
                    </li>
                }

                <li class="page-item @(ViewBag.CurrentPage == ViewBag.TotalPages ? "disabled" : "")">
                    <a class="page-link" asp-action="Snapshots" 
                       asp-route-page="@(ViewBag.CurrentPage + 1)" 
                       asp-route-cameraId="@ViewBag.CameraId" 
                       asp-route-from="@ViewBag.From" 
                       asp-route-to="@ViewBag.To">Вперед</a>
                </li>
            </ul>
        </nav>
    }

    @if (!Model.Any())    {
        <div class="text-center py-5 text-muted">
            <i class="bi bi-image display-1 opacity-25"></i>
            <p class="mt-3">Снимков не найдено</p>
        </div>
    }
</div>

<!-- Модальное окно для просмотра -->
<div class="modal fade" id="imageModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content bg-dark border-0">
            <div class="modal-header border-0 text-white py-2">
                <h5 class="modal-title h6" id="modalTitle"></h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-0 text-center">
                <img id="modalImage" src="" class="img-fluid" />
            </div>
            <div class="modal-footer border-0 text-white-50 py-1">
                <small id="modalDate"></small>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/lib/flatpickr/flatpickr.min.js"></script>
    <script src="~/lib/flatpickr/ru.js"></script>
    <script>
        $(document).ready(function () {
            const flatpickrConfig = {
                locale: "ru",
                enableTime: true,
                time_24hr: true,
                dateFormat: "Y-m-d H:i",
                altInput: true,
                altFormat: "d.m.Y H:i",
                allowInput: true,
                disableMobile: "true"
            };

            flatpickr("#from", flatpickrConfig);
            flatpickr("#to", flatpickrConfig);

            // Логика автообновления
            const autoRefreshCheck = document.getElementById('autoRefreshCheck');
            const refreshInterval = 30000; // 30 секунд
            let refreshTimer;

            function startTimer() {
                refreshTimer = setTimeout(() => {
                    // Проверяем, не открыто ли модальное окно
                    const modalOpen = document.querySelector('.modal.show');
                    if (autoRefreshCheck.checked && !modalOpen) {
                        window.location.reload();
                    } else if (autoRefreshCheck.checked) {
                        // Если модалка открыта, попробуем еще раз через 10 секунд
                        startTimer();
                    }
                }, refreshInterval);
            }

            // Сохраняем состояние чекбокса в localStorage
            const savedState = localStorage.getItem('snapshotsAutoRefresh');
            if (savedState === 'true') {
                autoRefreshCheck.checked = true;
                startTimer();
            }

            autoRefreshCheck.addEventListener('change', function() {
                localStorage.setItem('snapshotsAutoRefresh', this.checked);
                if (this.checked) {
                    startTimer();
                } else {
                    clearTimeout(refreshTimer);
                }
            });
        });

        function showModal(src, title, date) {
            document.getElementById('modalImage').src = src;
            document.getElementById('modalTitle').innerText = title;
            document.getElementById('modalDate').innerText = date;
            new bootstrap.Modal(document.getElementById('imageModal')).show();
        }
    </script>
}
