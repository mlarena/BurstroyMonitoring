@{
    ViewData["Title"] = "Просмотр камеры";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a asp-action="Index">Камеры</a></li>
                <li class="breadcrumb-item active">Камера #@ViewBag.CameraId</li>
            </ol>
        </nav>
        <div class="btn-group btn-group-sm">
            <a asp-action="Edit" asp-route-id="@ViewBag.CameraId" class="btn btn-outline-secondary">Настройки</a>
            <a asp-action="Index" class="btn btn-outline-secondary">К списку</a>
        </div>
    </div>

    <div class="row g-3">
        <!-- Видеопоток и управление -->
        <div class="col-lg-8">
            <div class="card shadow-sm bg-dark text-white mb-3">
                <div class="card-header bg-transparent border-secondary py-2 d-flex justify-content-between align-items-center">
                    <h2 class="h6 mb-0"><i class="bi bi-broadcast me-2 text-danger"></i> Прямой эфир</h2>
                    <span class="badge bg-danger animate-pulse">REC</span>
                </div>
                <div class="card-body p-0 bg-black d-flex align-items-center justify-content-center" style="height: 450px;">
                    <div class="text-center opacity-50">
                        <i class="bi bi-camera-video display-1 mb-3"></i>
                        <p>Подключение к видеопотоку...</p>
                    </div>
                </div>
                <div class="card-footer bg-transparent border-secondary py-3">
                    <div class="d-flex justify-content-center gap-4">
                        <div class="ptz-controls">
                            <div class="d-grid gap-1" style="grid-template-columns: repeat(3, 40px);">
                                <div></div>
                                <button class="btn btn-sm btn-outline-light"><i class="bi bi-chevron-up"></i></button>
                                <div></div>
                                <button class="btn btn-sm btn-outline-light"><i class="bi bi-chevron-left"></i></button>
                                <button class="btn btn-sm btn-light text-dark"><i class="bi bi-dot"></i></button>
                                <button class="btn btn-sm btn-outline-light"><i class="bi bi-chevron-right"></i></button>
                                <div></div>
                                <button class="btn btn-sm btn-outline-light"><i class="bi bi-chevron-down"></i></button>
                                <div></div>
                            </div>
                        </div>
                        <div class="zoom-controls d-flex flex-column gap-2">
                            <button class="btn btn-sm btn-outline-light"><i class="bi bi-plus-lg"></i> Zoom</button>
                            <button class="btn btn-sm btn-outline-light"><i class="bi bi-dash-lg"></i> Zoom</button>
                        </div>
                        <div class="action-controls d-flex flex-column gap-2">
                            <button class="btn btn-sm btn-primary"><i class="bi bi-camera me-1"></i> Сделать снимок</button>
                            <button class="btn btn-sm btn-outline-warning"><i class="bi bi-arrow-clockwise me-1"></i> Перезагрузить</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Снимки и статистика -->
        <div class="col-lg-4">
            <div class="card shadow-sm mb-3">
                <div class="card-header bg-light py-2">
                    <h3 class="h6 mb-0">Последние снимки</h3>
                </div>
                <div class="card-body p-2">
                    <div class="row g-2">
                        @for (int i = 1; i <= 4; i++)
                        {
                            <div class="col-6">
                                <div class="position-relative border rounded overflow-hidden bg-light" style="height: 100px;">
                                    <i class="bi bi-image position-absolute top-50 start-50 translate-middle opacity-25 h3"></i>
                                    <div class="position-absolute bottom-0 start-0 w-100 bg-dark bg-opacity-50 text-white p-1" style="font-size: 0.65rem;">
                                        12:45:0@(i)
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                    <div class="d-grid mt-3">
                        <button class="btn btn-outline-primary btn-sm">Все снимки (142)</button>
                    </div>
                </div>
            </div>

            <div class="card shadow-sm">
                <div class="card-header bg-light py-2">
                    <h3 class="h6 mb-0">Информация</h3>
                </div>
                <div class="card-body p-0">
                    <table class="table table-sm mb-0 small">
                        <tbody>
                            <tr><th class="ps-3 bg-light" style="width: 40%;">Статус</th><td class="ps-3 text-success fw-bold">Онлайн</td></tr>
                            <tr><th class="ps-3 bg-light">Uptime</th><td class="ps-3">14д 05ч 22м</td></tr>
                            <tr><th class="ps-3 bg-light">Разрешение</th><td class="ps-3">1920x1080 (2MP)</td></tr>
                            <tr><th class="ps-3 bg-light">Битрейт</th><td class="ps-3">4.2 Mbps</td></tr>
                            <tr><th class="ps-3 bg-light">Кодек</th><td class="ps-3">H.265</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .animate-pulse {
        animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
    }
    @@keyframes pulse {
        0%, 100% { opacity: 1; }
        50% { opacity: .5; }
    }
</style>
