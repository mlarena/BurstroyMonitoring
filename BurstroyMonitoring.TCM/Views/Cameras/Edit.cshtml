@{
    ViewData["Title"] = "Настройки камеры";
}

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow-sm border-warning">
                <div class="card-header bg-warning text-dark py-2">
                    <h1 class="h5 mb-0">Настройки камеры #@ViewBag.CameraId</h1>
                </div>
                <div class="card-body p-3">
                    <form>
                        <div class="mb-3">
                            <label class="form-label small fw-bold">Название камеры</label>
                            <input type="text" class="form-control form-control-sm" value="Основной въезд" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label small fw-bold">Пост мониторинга</label>
                            <select class="form-select form-select-sm">
                                <option value="1" selected>Пост №1</option>
                                <option value="2">Пост №2</option>
                            </select>
                        </div>

                        <div class="row g-3 mb-3">
                            <div class="col-md-8">
                                <label class="form-label small fw-bold">IP адрес / URL потока</label>
                                <input type="text" class="form-control form-control-sm" value="192.168.1.101" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label small fw-bold">Порт</label>
                                <input type="number" class="form-control form-control-sm" value="554" />
                            </div>
                        </div>

                        <div class="mb-3">
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" role="switch" id="isActive" checked>
                                <label class="form-check-label small" for="isActive">Камера активна</label>
                            </div>
                        </div>

                        <div class="d-flex justify-content-between align-items-center pt-2 border-top">
                            <div class="btn-group btn-group-sm">
                                <a asp-action="Index" class="btn btn-outline-secondary">Отмена</a>
                                <a asp-action="Delete" asp-route-id="@ViewBag.CameraId" class="btn btn-outline-danger">Удалить</a>
                            </div>
                            <button type="button" class="btn btn-warning btn-sm px-4">Сохранить</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
