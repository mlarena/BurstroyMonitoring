@model BurstroyMonitoring.Data.Models.Camera
@{
    ViewData["Title"] = "Настройки камеры";
}

<div class="container-fluid">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-header bg-secondary text-white py-3">
                    <h1 class="h5 mb-0">Редактирование: @Model.Name</h1>
                </div>
                <div class="card-body">
                    <form asp-action="Edit">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                        <input type="hidden" asp-for="Id" />
                        <input type="hidden" asp-for="CreatedAt" />
                        
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label asp-for="Name" class="form-label fw-bold small"></label>
                                <input asp-for="Name" class="form-control form-control-sm" />
                                <span asp-validation-for="Name" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="MonitoringPostId" class="form-label fw-bold small">Пост мониторинга</label>
                                <select asp-for="MonitoringPostId" class="form-select form-select-sm" asp-items="ViewBag.MonitoringPostId">
                                    <option value="">-- Выберите пост --</option>
                                </select>
                            </div>

                            <div class="col-12">
                                <label asp-for="RtspUrl" class="form-label fw-bold small"></label>
                                <input asp-for="RtspUrl" class="form-control form-control-sm" />
                                <span asp-validation-for="RtspUrl" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="InstallationLocation" class="form-label fw-bold small"></label>
                                <input asp-for="InstallationLocation" class="form-control form-control-sm" />
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Picket" class="form-label fw-bold small"></label>
                                <input asp-for="Picket" class="form-control form-control-sm" />
                            </div>

                            <div class="col-md-4">
                                <label asp-for="Username" class="form-label fw-bold small"></label>
                                <input asp-for="Username" class="form-control form-control-sm" />
                            </div>
                            <div class="col-md-4">
                                <label asp-for="Password" class="form-label fw-bold small"></label>
                                <input asp-for="Password" type="password" class="form-control form-control-sm" />
                            </div>
                            <div class="col-md-4">
                                <label asp-for="PollingInterval" class="form-label fw-bold small"></label>
                                <input asp-for="PollingInterval" class="form-control form-control-sm" />
                            </div>

                            <div class="col-12">
                                <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox" asp-for="IsPtzSupported">
                                    <label class="form-check-label fw-bold small" asp-for="IsPtzSupported"></label>
                                </div>
                            </div>
                        </div>

                        <div class="mt-4 pt-3 border-top d-flex gap-2">
                            <button type="submit" class="btn btn-primary">Сохранить</button>
                            <a asp-action="Index" class="btn btn-outline-secondary">Отмена</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
