@model IEnumerable<BurstroyMonitoring.Data.Models.VwDspdDataFull>
@using BurstroyMonitoring.Data.Models.ViewModels
@{
    ViewData["Title"] = "Просмотр и экспорт данных DSPD";
    var filter = ViewBag.Filter as DataFilterViewModel ?? new DataFilterViewModel();
    var availableFields = ViewBag.AvailableFields as List<string> ?? new List<string>();
    var serialNumbers = ViewBag.SerialNumbers as List<string> ?? new List<string>();
    var totalCount = ViewBag.TotalCount as int? ?? 0;
    var displayedCount = Model.Count();
    var fieldDisplayNames = ViewBag.ColumnNames as Dictionary<string, string> ?? new Dictionary<string, string>();
}

<div class="container-fluid">
    <h1 class="h3 mb-3">Просмотр и экспорт данных DSPD</h1>
    
    <div class="card mb-3 shadow-sm">
        <div class="card-header bg-light py-2 d-flex justify-content-between align-items-center cursor-pointer" 
             data-bs-toggle="collapse" data-bs-target="#filterCollapse">
            <div class="d-flex align-items-center gap-2">
                <i class="bi bi-filter text-primary"></i>
                <h3 class="h6 mb-0">Фильтры и настройки</h3>
            </div>
        </div>
        
        <div class="collapse show" id="filterCollapse">
            <div class="card-body p-3">
                <form method="get" id="filterForm">
                    <div class="row g-2 mb-3">
                        <div class="col-md-2">
                            <label class="form-label small fw-bold mb-1">С даты</label>
                            <input type="datetime-local" class="form-control form-control-sm" name="StartDate" 
                                   value="@(filter.StartDate?.ToString("yyyy-MM-ddTHH:mm"))">
                        </div>
                        <div class="col-md-2">
                            <label class="form-label small fw-bold mb-1">По дату</label>
                            <input type="datetime-local" class="form-control form-control-sm" name="EndDate" 
                                   value="@(filter.EndDate?.ToString("yyyy-MM-ddTHH:mm"))">
                        </div>
                        <div class="col-md-2">
                            <label class="form-label small fw-bold mb-1">S/N</label>
                            <select class="form-select form-select-sm" name="SerialNumber">
                                <option value="">Все</option>
                                @foreach (var serial in serialNumbers) {
                                    <option value="@serial" selected="@(serial == filter.SerialNumber ? "selected" : null)">@serial</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-2">
                            <label class="form-label small fw-bold mb-1">Выводить по</label>
                            <select class="form-select form-select-sm" name="PageSize">
                                <option value="10" selected="@(filter.PageSize == "10" ? "selected" : null)">10</option>
                                <option value="100" selected="@(filter.PageSize == "100" ? "selected" : null)">100</option>
                                <option value="all" selected="@(filter.PageSize == "all" ? "selected" : null)">Всё</option>
                            </select>
                        </div>
                        <div class="col-md-2 d-flex align-items-end">
                            <button type="submit" class="btn btn-primary btn-sm w-100">Применить</button>
                        </div>
                    </div>
                    
                    <div class="mb-0">
                        <label class="form-label small fw-bold mb-2">Поля для отображения:</label>
                        <div class="row row-cols-2 row-cols-md-4 row-cols-lg-6 g-2">
                            @foreach (var field in availableFields) {
                                <div class="col">
                                    <div class="form-check">
                                        <input class="form-check-input field-checkbox" type="checkbox" 
                                               name="SelectedFields" value="@field" id="field_@field"
                                               @(filter.SelectedFields.Contains(field) ? "checked" : "")>
                                        <label class="form-check-label small text-truncate w-100" for="field_@field" title="@field">
                                            @{
                                                string displayName = field;
                                                if (fieldDisplayNames != null) {
                                                    var kvp = fieldDisplayNames.FirstOrDefault(x => x.Key.Equals(field, StringComparison.OrdinalIgnoreCase));
                                                    if (!string.IsNullOrEmpty(kvp.Value)) displayName = kvp.Value;
                                                }
                                            }
                                            @displayName
                                        </label>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="d-flex justify-content-between align-items-center mb-2">
        <div class="small text-muted">
            Найдено: <strong>@totalCount</strong>, показано: <strong>@displayedCount</strong>
        </div>
        <div class="btn-group btn-group-sm">
            <button type="button" class="btn btn-outline-success" onclick="exportData('excel', false)">
                <i class="bi bi-file-earmark-excel me-1"></i> Excel (тек.)
            </button>
            <button type="button" class="btn btn-success" onclick="exportData('excel', true)">
                <i class="bi bi-file-earmark-excel me-1"></i> Excel (все)
            </button>
            <button type="button" class="btn btn-outline-secondary" onclick="exportData('csv', false)">
                <i class="bi bi-file-earmark-spreadsheet me-1"></i> CSV (тек.)
            </button>
            <button type="button" class="btn btn-secondary" onclick="exportData('csv', true)">
                <i class="bi bi-file-earmark-spreadsheet me-1"></i> CSV (все)
            </button>
        </div>
    </div>

    <div class="table-responsive shadow-sm rounded border" style="max-height: 600px;">
        <table class="table table-sm table-hover table-striped align-middle mb-0" style="font-size: 0.75rem;">
            <thead class="table-light sticky-top">
                <tr>
                    @foreach (var field in filter.SelectedFields) {
                        <th class="text-nowrap">
                            @{
                                string headerName = field;
                                if (fieldDisplayNames != null) {
                                    var kvp = fieldDisplayNames.FirstOrDefault(x => x.Key.Equals(field, StringComparison.OrdinalIgnoreCase));
                                    if (!string.IsNullOrEmpty(kvp.Value)) headerName = kvp.Value;
                                }
                            }
                            @headerName
                        </th>
                    }
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model) {
                    <tr>
                        @foreach (var field in filter.SelectedFields) {
                            <td class="text-nowrap">
                                @{
                                    var property = item.GetType().GetProperty(field);
                                    var value = property?.GetValue(item);
                                    if (value is DateTime dt) { @dt.ToLocalTime().ToString("dd.MM.yyyy HH:mm") }
                                    else if (value is bool b) { @(b ? "Да" : "Нет") }
                                    else if (value is double d) { @d.ToString("F2") }
                                    else if (value is decimal dec) { @dec.ToString("F2") }
                                    else { @(value?.ToString() ?? "—") }
                                }
                            </td>
                        }
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<script>
    function exportData(format, all) {
        const form = document.getElementById('filterForm');
        const tempForm = document.createElement('form');
        tempForm.method = 'POST';
        tempForm.action = '@Url.Action("Export")';
        
        const formData = new FormData(form);
        for (const [key, value] of formData.entries()) {
            const input = document.createElement('input');
            input.type = 'hidden'; input.name = key; input.value = value;
            tempForm.appendChild(input);
        }
        
        const formatInput = document.createElement('input');
        formatInput.type = 'hidden'; formatInput.name = 'format'; formatInput.value = format;
        tempForm.appendChild(formatInput);
        
        const allInput = document.createElement('input');
        allInput.type = 'hidden'; allInput.name = 'exportAllData'; allInput.value = all;
        tempForm.appendChild(allInput);

        const token = document.querySelector('input[name="__RequestVerificationToken"]');
        if (token) {
            const tokenInput = document.createElement('input');
            tokenInput.type = 'hidden'; tokenInput.name = '__RequestVerificationToken'; tokenInput.value = token.value;
            tempForm.appendChild(tokenInput);
        }
        
        document.body.appendChild(tempForm);
        tempForm.submit();
        document.body.removeChild(tempForm);
    }
</script>
