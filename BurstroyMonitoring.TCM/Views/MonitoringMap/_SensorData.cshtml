@model dynamic

@{
    var data = new Dictionary<string, object>();
    if (Model != null) {
        foreach (var prop in Model.GetType().GetProperties()) {
            var val = prop.GetValue(Model);
            if (val != null) data[prop.Name] = val;
        }
    }

    var translations = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase) {
        { "UPower", "Питание, В" }, { "NeedCalibration", "Калибровка" }, { "AngleToRoad", "Угол, °" },
        { "Shake", "Вибрация, g" }, { "TemperatureRoad", "Т дороги, °С" }, { "HeightIce", "Лед, мм" },
        { "HeightSnow", "Снег, мм" }, { "HeightH2O", "Вода, мм" }, { "RoadStatus", "Статус дороги" },
        { "Grip", "Сцепление" }, { "EnvTemperature", "Т возд., ℃" }, { "Humidity", "Влажн., %" },
        { "PressureHPa", "Давл., гПа" }, { "WindSpeed", "Ветер, м/с" }, { "VisibleRange", "Видимость, м" }
    };

    var displayParams = data.Where(x => 
        !x.Key.Contains("ReceivedAt") && !x.Key.Contains("DataTimestamp") && 
        !x.Key.Contains("Id") && !x.Key.Contains("SensorId")).ToList();
}

@if (data.Any()) {
    <div class="list-group list-group-flush small">
        <div class="list-group-item bg-light py-1 fw-bold text-muted" style="font-size: 0.7rem;">ПАРАМЕТРЫ</div>
        @foreach (var item in displayParams) {
            var header = translations.ContainsKey(item.Key) ? translations[item.Key] : item.Key;
            <div class="list-group-item py-2 d-flex justify-content-between align-items-center">
                <span class="text-muted">@header</span>
                <span class="fw-bold text-primary">
                    @if (item.Value is double d) { @d.ToString("F2") }
                    else if (item.Value is decimal dec) { @dec.ToString("F2") }
                    else { @item.Value }
                </span>
            </div>
        }
    </div>
} else {
    <div class="text-center py-4 text-muted small">Нет данных для отображения</div>
}
