@model BurstroyMonitoring.Data.Models.MonitoringPost

@{
    ViewData["Title"] = "Подробности о посте мониторинга";
}

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-10 col-lg-8">
            <div class="card shadow-sm">
                <div class="card-header bg-info text-white py-2 d-flex justify-content-between align-items-center">
                    <h1 class="h5 mb-0">Подробности о посте мониторинга</h1>
                    <span class="badge bg-light text-dark">ID: @Model.Id</span>
                </div>
                <div class="card-body p-0">
                    <table class="table table-sm mb-0">
                        <tbody>
                            <tr>
                                <th class="bg-light ps-3" style="width: 30%;">Наименование</th>
                                <td class="ps-3">@Html.DisplayFor(model => model.Name)</td>
                            </tr>
                            <tr>
                                <th class="bg-light ps-3">Адрес</th>
                                <td class="ps-3">@(string.IsNullOrEmpty(Model.Address) ? "—" : Model.Address)</td>
                            </tr>
                            <tr>
                                <th class="bg-light ps-3">Описание</th>
                                <td class="ps-3">@(string.IsNullOrEmpty(Model.Description) ? "—" : Model.Description)</td>
                            </tr>
                            <tr>
                                <th class="bg-light ps-3">Координаты</th>
                                <td class="ps-3">
                                    @if (Model.Longitude.HasValue && Model.Latitude.HasValue)
                                    {
                                        <div class="d-flex align-items-center gap-2">
                                            <span>@Model.Longitude.Value.ToString("F6"), @Model.Latitude.Value.ToString("F6")</span>
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">Не указаны</span>
                                    }
                                </td>
                            </tr>
                            <tr>
                                <th class="bg-light ps-3">Тип поста</th>
                                <td class="ps-3">
                                    @if (Model.IsMobile)
                                    {
                                        <span class="badge bg-info text-dark fw-normal">Мобильный</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary fw-normal">Стационарный</span>
                                    }
                                </td>
                            </tr>
                            <tr>
                                <th class="bg-light ps-3">Статус</th>
                                <td class="ps-3">
                                    @if (Model.IsActive)
                                    {
                                        <span class="badge bg-success fw-normal">Активен</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger fw-normal">Неактивен</span>
                                    }
                                </td>
                            </tr>
                            <tr>
                                <th class="bg-light ps-3">Даты</th>
                                <td class="ps-3 small">
                                    <div><span class="text-muted">Создан:</span> @(Model.CreatedAt?.ToString("dd.MM.yyyy HH:mm") ?? "—")</div>
                                    <div><span class="text-muted">Обновлен:</span> @(Model.UpdatedAt?.ToString("dd.MM.yyyy HH:mm") ?? "—")</div>
                                </td>
                            </tr>
                            <tr>
                                <th class="bg-light ps-3">Датчики</th>
                                <td class="ps-3">
                                    @if (Model.Sensors != null && Model.Sensors.Any())
                                    {
                                        <div class="mb-2">
                                            <span class="badge bg-primary rounded-pill">@Model.Sensors.Count</span>
                                            <a href="@Url.Action("Index", "Sensors", new { monitoringPostId = Model.Id })" 
                                               class="btn btn-link btn-sm p-0 ms-2 text-decoration-none">
                                                Просмотреть все
                                            </a>
                                        </div>
                                        
                                        <ul class="list-group list-group-flush border rounded small">
                                            @foreach (var sensor in Model.Sensors.Take(5))
                                            {
                                                <li class="list-group-item py-1 d-flex justify-content-between align-items-center">
                                                    <a href="@Url.Action("Details", "Sensors", new { id = sensor.Id })" 
                                                       class="text-decoration-none">
                                                        @sensor.SerialNumber - @sensor.EndPointsName
                                                    </a>
                                                    @if (sensor.IsActive)
                                                    {
                                                        <span class="badge bg-success p-1" title="Активен">✓</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge bg-danger p-1" title="Неактивен">✗</span>
                                                    }
                                                </li>
                                            }
                                        </ul>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">Нет датчиков</span>
                                    }
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
                <div class="card-footer bg-light d-flex justify-content-between py-2">
                    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Назад к списку</a>
                    <div class="btn-group btn-group-sm">
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Редактировать</a>
                        <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger">Удалить</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
