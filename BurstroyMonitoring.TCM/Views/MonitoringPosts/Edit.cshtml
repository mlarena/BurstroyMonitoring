@model BurstroyMonitoring.Data.Models.MonitoringPost

@{
    ViewData["Title"] = "Редактировать пост мониторинга";
}

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow-sm border-warning">
                <div class="card-header bg-warning text-dark py-2">
                    <h1 class="h5 mb-0">Редактировать пост мониторинга</h1>
                </div>
                <div class="card-body p-3">
                    <form asp-action="Edit" id="monitoringPostForm">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>
                        <input type="hidden" asp-for="Id" />
                        <input type="hidden" asp-for="CreatedAt" />
                        
                        <div class="mb-3">
                            <label asp-for="Name" class="form-label small fw-bold">Наименование</label>
                            <input asp-for="Name" class="form-control form-control-sm" />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Address" class="form-label small fw-bold">Адрес</label>
                            <input asp-for="Address" class="form-control form-control-sm" />
                            <span asp-validation-for="Address" class="text-danger small"></span>
                        </div>
                        
                        <div class="mb-3">
                            <label asp-for="Description" class="form-label small fw-bold">Описание</label>
                            <textarea asp-for="Description" class="form-control form-control-sm" rows="3"></textarea>
                            <span asp-validation-for="Description" class="text-danger small"></span>
                        </div>
                        
                        <!-- Используем Partial View для координат -->
                        <div class="card bg-light mb-3 border-0">
                            <div class="card-body p-2">
                                @await Html.PartialAsync("_CoordinateFields", Model)
                            </div>
                        </div>
                        
                        <div class="row mb-3">
                            <div class="col-6">
                                <div class="form-check form-switch">
                                    <input asp-for="IsMobile" class="form-check-input" type="checkbox" role="switch" />
                                    <label asp-for="IsMobile" class="form-check-label small">Мобильный пост</label>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="form-check form-switch">
                                    <input asp-for="IsActive" class="form-check-input" type="checkbox" role="switch" />
                                    <label asp-for="IsActive" class="form-check-label small">Активный</label>
                                </div>
                            </div>
                        </div>
                        
                        <div class="d-flex justify-content-between align-items-center pt-2 border-top">
                            <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Назад к списку</a>
                            <button type="submit" class="btn btn-warning btn-sm px-4">Сохранить</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    
    <script src="~/js/coordinateValidation.js" asp-append-version="true"></script>
}