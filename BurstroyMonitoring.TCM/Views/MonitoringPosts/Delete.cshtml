@model BurstroyMonitoring.Data.Models.MonitoringPost

@{
    ViewData["Title"] = "Удалить пост мониторинга";
}

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow-sm border-danger">
                <div class="card-header bg-danger text-white py-2">
                    <h1 class="h5 mb-0">Удалить пост мониторинга</h1>
                </div>
                <div class="card-body p-3 text-center">
                    <div class="display-4 text-danger mb-3">⚠️</div>
                    <h3 class="h5 mb-3">Вы уверены, что хотите удалить этот пост?</h3>
                    
                    <div class="bg-light p-3 rounded mb-3 text-start small">
                        <div class="row mb-1">
                            <div class="col-4 fw-bold">Наименование:</div>
                            <div class="col-8">@Model.Name</div>
                        </div>
                        <div class="row mb-1">
                            <div class="col-4 fw-bold">Тип:</div>
                            <div class="col-8">@(Model.IsMobile ? "Мобильный" : "Стационарный")</div>
                        </div>
                        <div class="row mb-1">
                            <div class="col-4 fw-bold">Статус:</div>
                            <div class="col-8">@(Model.IsActive ? "Активен" : "Неактивен")</div>
                        </div>
                    </div>

                    @if (Model.Sensors?.Any() == true)
                    {
                        <div class="alert alert-warning py-2 small text-start">
                            <strong>Внимание!</strong> Пост имеет связанные датчики (@Model.Sensors.Count шт.).
                            Они будут отсоединены.
                        </div>
                    }
                    
                    <form asp-action="Delete">
                        <input type="hidden" asp-for="Id" />
                        <div class="d-flex justify-content-between align-items-center pt-3 border-top">
                            <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Отмена</a>
                            <button type="submit" class="btn btn-danger btn-sm px-4">Удалить</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>