@model BurstroyMonitoring.Data.Models.VwDovDataFull

@{
    ViewData["Title"] = "Подробности о данных DOV";
}

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-10 col-lg-8">
            <div class="card shadow-sm">
                <div class="card-header bg-info text-white py-2 d-flex justify-content-between align-items-center">
                    <h1 class="h5 mb-0">Подробности о данных DOV</h1>
                    <span class="badge bg-light text-dark">ID: @Model.DovDataId</span>
                </div>
                <div class="card-body p-0">
                    <table class="table table-sm mb-0">
                        <tbody>
                            <tr class="table-light"><th colspan="2" class="ps-3 py-2">Основная информация</th></tr>
                            <tr>
                                <th class="ps-3" style="width: 40%;">Дата получения</th>
                                <td class="ps-3">@(Model.ReceivedAt?.ToString("dd.MM.yyyy HH:mm:ss") ?? "—")</td>
                            </tr>
                            <tr>
                                <th class="ps-3">Серийный номер</th>
                                <td class="ps-3 fw-bold">@Model.SerialNumber</td>
                            </tr>
                            <tr>
                                <th class="ps-3">Конечная точка</th>
                                <td class="ps-3">@Model.EndpointName</td>
                            </tr>
                            <tr>
                                <th class="ps-3">Видимость</th>
                                <td class="ps-3 fw-bold text-primary">@(Model.VisibleRange?.ToString("F0") ?? "—") м</td>
                            </tr>
                            <tr>
                                <th class="ps-3">Яркость</th>
                                <td class="ps-3">
                                    @if (Model.BrightFlag == 1) { <span class="badge bg-warning text-dark fw-normal">Ярко</span> }
                                    else { <span class="badge bg-light text-dark border fw-normal">Норма</span> }
                                </td>
                            </tr>
                            <tr>
                                <th class="ps-3">Пост</th>
                                <td class="ps-3">@Model.PostName</td>
                            </tr>
                        </tbody>
                    </table>

                    <div class="collapse" id="additionalFields">
                        <table class="table table-sm mb-0 border-top">
                            <tbody>
                                <tr class="table-light"><th colspan="2" class="ps-3 py-2">Техническая информация</th></tr>
                                <tr>
                                    <th class="ps-3" style="width: 40%;">Метка времени данных</th>
                                    <td class="ps-3">@(Model.DataTimestamp?.ToString("dd.MM.yyyy HH:mm:ss") ?? "—")</td>
                                </tr>
                                <tr>
                                    <th class="ps-3">URL API</th>
                                    <td class="ps-3 small"><a href="@Model.SensorUrl" target="_blank" class="text-break">@Model.SensorUrl</a></td>
                                </tr>
                                <tr>
                                    <th class="ps-3">Тип датчика</th>
                                    <td class="ps-3">@Model.SensorTypeName <div class="small text-muted">@Model.SensorTypeDescription</div></td>
                                </tr>
                                <tr>
                                    <th class="ps-3">Координаты</th>
                                    <td class="ps-3 small">
                                        @if (Model.SensorLongitude.HasValue) {
                                            <span>@Model.SensorLongitude, @Model.SensorLatitude</span>
                                        } else { <span>—</span> }
                                    </td>
                                </tr>
                                <tr>
                                    <th class="ps-3">Интервал проверки</th>
                                    <td class="ps-3 small">@Model.CheckIntervalSeconds сек.</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
                <div class="card-footer bg-light d-flex justify-content-between py-2">
                    <a href="javascript:history.back()" class="btn btn-outline-secondary btn-sm">Назад</a>
                    <button class="btn btn-outline-info btn-sm" type="button" data-bs-toggle="collapse" data-bs-target="#additionalFields">
                        Доп. поля
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>
                            <span class="text-muted">-</span>
                        }
                    </div>
                </div>

                <!-- Последняя активность -->
                <div class="details-row">
                    <div class="details-label">Последняя активность</div>
                    <div class="details-value">
                        @if (Model.LastActivityUtc.HasValue)
                        {
                            <span>@Model.LastActivityUtc.Value.ToString("dd.MM.yyyy HH:mm:ss") UTC</span>
                            <br />
                            <small style="color: var(--text-secondary);">
                                @{
                                    var timeAgo = DateTime.UtcNow - Model.LastActivityUtc.Value;
                                    if (timeAgo.TotalDays >= 1)
                                    {
                                        <span>@((int)timeAgo.TotalDays) дней назад</span>
                                    }
                                    else if (timeAgo.TotalHours >= 1)
                                    {
                                        <span>@((int)timeAgo.TotalHours) часов назад</span>
                                    }
                                    else if (timeAgo.TotalMinutes >= 1)
                                    {
                                        <span>@((int)timeAgo.TotalMinutes) минут назад</span>
                                    }
                                    else
                                    {
                                        <span>Только что</span>
                                    }
                                }
                            </small>
                        }
                        else
                        {
                            <span class="text-muted">Нет данных</span>
                        }
                    </div>
                </div>

                <!-- Статус датчика -->
                <div class="details-row">
                    <div class="details-label">Статус датчика</div>
                    <div class="details-value">
                        @if (Model.SensorIsActive.HasValue)
                        {
                            @if (Model.SensorIsActive == true)
                            {
                                <span class="lozenge lozenge--success">Активен</span>
                            }
                            else
                            {
                                <span class="lozenge lozenge--error">Неактивен</span>
                            }
                        }
                        else
                        {
                            <span class="text-muted">-</span>
                        }
                    </div>
                </div>

                <!-- Тип поста -->
                <div class="details-row">
                    <div class="details-label">Тип поста</div>
                    <div class="details-value">
                        @if (Model.PostIsMobile.HasValue)
                        {
                            @if (Model.PostIsMobile == true)
                            {
                                <span class="lozenge">Мобильный</span>
                            }
                            else
                            {
                                <span class="lozenge">Стационарный</span>
                            }
                        }
                        else
                        {
                            <span class="text-muted">-</span>
                        }
                    </div>
                </div>

                <!-- Статус поста -->
                <div class="details-row">
                    <div class="details-label">Статус поста</div>
                    <div class="details-value">
                        @if (Model.PostIsActive.HasValue)
                        {
                            @if (Model.PostIsActive == true)
                            {
                                <span class="lozenge lozenge--success">Активен</span>
                            }
                            else
                            {
                                <span class="lozenge lozenge--error">Неактивен</span>
                            }
                        }
                        else
                        {
                            <span class="text-muted">-</span>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="details-actions">
        <a asp-action="Index" class="button button--secondary">Назад к списку</a>
    </div>
</div>

@section Scripts {
    <script>
        let isAdditionalExpanded = false;

        function toggleAdditionalFields() {
            const additionalFields = document.getElementById('additionalFields');
            const toggleBtn = document.getElementById('toggleAdditionalBtn');

            if (!isAdditionalExpanded) {
                additionalFields.style.display = 'block';
                toggleBtn.textContent = '📄 Скрыть дополнительные поля';
                isAdditionalExpanded = true;
            } else {
                additionalFields.style.display = 'none';
                toggleBtn.textContent = '📄 Показать дополнительные поля';
                isAdditionalExpanded = false;
            }
        }

        document.addEventListener('DOMContentLoaded', function () {
            // Можно добавить дополнительные действия при загрузке, если нужно
        });
    </script>

}