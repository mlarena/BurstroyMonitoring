@model BurstroyMonitoring.Data.Models.VwDovDataFull

@{
    ViewData["Title"] = "Подробности о данных DOV";
}

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-10 col-lg-8">
            <div class="card shadow-sm">
                <div class="card-header bg-info text-white py-2 d-flex justify-content-between align-items-center">
                    <h1 class="h5 mb-0">Подробности о данных DOV</h1>
                    <span class="badge bg-light text-dark">ID: @Model.DovDataId</span>
                </div>
                <div class="card-body p-0">
                    <table class="table table-sm mb-0">
                        <tbody>
                            <tr class="table-light"><th colspan="2" class="ps-3 py-2">Основная информация</th></tr>
                            <tr>
                                <th class="ps-3" style="width: 40%;">Дата и время получения</th>
                                <td class="ps-3">@(Model.ReceivedAt?.ToLocalTime().ToString("dd.MM.yyyy HH:mm:ss") ?? "—")</td>
                            </tr>
                            <!-- <tr>
                                <th class="ps-3">Метка времени данных</th>
                                <td class="ps-3">@(Model.DataTimestamp?.ToString("dd.MM.yyyy HH:mm:ss") ?? "—")</td>
                            </tr> -->
                            <tr>
                                <th class="ps-3">Серийный номер</th>
                                <td class="ps-3 fw-bold">@Model.SerialNumber</td>
                            </tr>
                            <tr>
                                <th class="ps-3">Конечная точка</th>
                                <td class="ps-3">@Model.EndpointName</td>
                            </tr>
                            <tr>
                                <th class="ps-3">Тип датчика</th>
                                <td class="ps-3">@Model.SensorTypeName <div class="small text-muted">@Model.SensorTypeDescription</div></td>
                            </tr>
                            <tr>
                                <th class="ps-3">Пост мониторинга</th>
                                <td class="ps-3">@Model.PostName @(Model.PostIsMobile == true ? "(Мобильный)" : "")</td>
                            </tr>
                            @if (!string.IsNullOrEmpty(Model.PostAddress)) {
                            <tr>
                                <th class="ps-3">Адрес поста</th>
                                <td class="ps-3 small">@Model.PostAddress</td>
                            </tr>
                            }
                            <tr>
                                <th class="ps-3">Видимость</th>
                                <td class="ps-3 fw-bold text-primary">@(Model.VisibleRange?.ToString("F0") ?? "—") м</td>
                            </tr>
                            <tr>
                                <th class="ps-3">Яркость</th>
                                <td class="ps-3">
                                    @if (Model.BrightFlag == 1) { <span class="badge bg-warning text-dark fw-normal">Ярко</span> }
                                    else { <span class="badge bg-light text-dark border fw-normal">Норма</span> }
                                </td>
                            </tr>

                            <tr class="table-light"><th colspan="2" class="ps-3 py-2">Параметры датчика</th></tr>
                            <tr>
                                <th class="ps-3">Координаты установки</th>
                                <td class="ps-3 small">
                                    @if (Model.SensorLongitude.HasValue) {
                                        <span>@(Model.SensorLatitude?.ToString("F6")), @(Model.SensorLongitude?.ToString("F6"))</span>
                                    } else { <span>—</span> }
                                </td>
                            </tr>
                            <tr>
                                <th class="ps-3">Последняя активность</th>
                                <td class="ps-3 small">@(Model.LastActivityUtc?.ToString("dd.MM.yyyy HH:mm:ss") ?? "—")</td>
                            </tr>
                            <tr>
                                <th class="ps-3">Статус датчика</th>
                                <td class="ps-3">
                                    @if (Model.SensorIsActive == true) { <span class="badge bg-success fw-normal">Активен</span> }
                                    else { <span class="badge bg-secondary fw-normal">Неактивен</span> }
                                </td>
                            </tr>
                            <tr>
                                <th class="ps-3">URL API</th>
                                <td class="ps-3 small text-break"><a href="@Model.SensorUrl" target="_blank">@Model.SensorUrl</a></td>
                            </tr>
                        </tbody>
                    </table>
                </div>
                <div class="card-footer bg-light py-2">
                    <a href="javascript:history.back()" class="btn btn-outline-secondary btn-sm">Назад</a>
                </div>
            </div>
        </div>
    </div>
</div>
