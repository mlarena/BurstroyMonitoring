@model BurstroyMonitoring.Data.Models.VwDustDataFull

@{
    ViewData["Title"] = "Подробности о данных DUST";
}

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-10 col-lg-8">
            <div class="card shadow-sm">
                <div class="card-header bg-info text-white py-2 d-flex justify-content-between align-items-center">
                    <h1 class="h5 mb-0">Подробности о данных DUST</h1>
                    <span class="badge bg-light text-dark">ID: @Model.DustDataId</span>
                </div>
                <div class="card-body p-0">
                    <table class="table table-sm mb-0">
                        <tbody>
                            <tr class="table-light"><th colspan="2" class="ps-3 py-2">Основная информация</th></tr>
                            <tr>
                                <th class="ps-3" style="width: 40%;">Дата получения</th>
                                <td class="ps-3">@(Model.ReceivedAt?.ToString("dd.MM.yyyy HH:mm:ss") ?? "—")</td>
                            </tr>
                            <tr>
                                <th class="ps-3">Серийный номер</th>
                                <td class="ps-3 fw-bold">@Model.SerialNumber</td>
                            </tr>
                            <tr>
                                <th class="ps-3">Конечная точка</th>
                                <td class="ps-3">@Model.EndpointName</td>
                            </tr>
                            <tr>
                                <th class="ps-3 text-primary">Концентрация PM (текущ)</th>
                                <td class="ps-3 fw-bold text-primary">
                                    PM10: @(Model.PM10Act?.ToString("F2") ?? "—"), 
                                    PM2.5: @(Model.PM25Act?.ToString("F2") ?? "—"), 
                                    PM1: @(Model.PM1Act?.ToString("F2") ?? "—")
                                </td>
                            </tr>
                            <tr>
                                <th class="ps-3">Температура / Влажность</th>
                                <td class="ps-3">
                                    @(Model.TemperatureProbe?.ToString("F1") ?? "—")°C / @(Model.HumidityProbe?.ToString("F1") ?? "—")%
                                </td>
                            </tr>
                            <tr>
                                <th class="ps-3">Статус лазера</th>
                                <td class="ps-3">
                                    @if (Model.LaserStatus > 0) { <span class="badge bg-success fw-normal">OK (@Model.LaserStatus)</span> }
                                    else { <span class="badge bg-danger fw-normal">Ошибка (@Model.LaserStatus)</span> }
                                </td>
                            </tr>
                            <tr>
                                <th class="ps-3">Пост</th>
                                <td class="ps-3">@Model.PostName</td>
                            </tr>
                        </tbody>
                    </table>

                    <div class="collapse" id="additionalFields">
                        <table class="table table-sm mb-0 border-top">
                            <tbody>
                                <tr class="table-light"><th colspan="2" class="ps-3 py-2">Технические данные</th></tr>
                                <tr>
                                    <th class="ps-3" style="width: 40%;">PM (среднее)</th>
                                    <td class="ps-3 small">
                                        PM10: @(Model.PM10AWG?.ToString("F2") ?? "—"), 
                                        PM2.5: @(Model.PM25AWG?.ToString("F2") ?? "—"), 
                                        PM1: @(Model.PM1AWG?.ToString("F2") ?? "—")
                                    </td>
                                </tr>
                                <tr>
                                    <th class="ps-3">Расход пробы</th>
                                    <td class="ps-3 small">@(Model.FlowProbe?.ToString("F2") ?? "—")</td>
                                </tr>
                                <tr>
                                    <th class="ps-3">Напряжение питания</th>
                                    <td class="ps-3 small">@(Model.SupplyVoltage?.ToString("F1") ?? "—")V</td>
                                </tr>
                                <tr>
                                    <th class="ps-3">URL API</th>
                                    <td class="ps-3 small text-break">@Model.SensorUrl</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
                <div class="card-footer bg-light d-flex justify-content-between py-2">
                    <a href="javascript:history.back()" class="btn btn-outline-secondary btn-sm">Назад</a>
                    <button class="btn btn-outline-info btn-sm" type="button" data-bs-toggle="collapse" data-bs-target="#additionalFields">
                        Тех. данные
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>
