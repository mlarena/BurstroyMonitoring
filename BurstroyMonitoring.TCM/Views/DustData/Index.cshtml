@model IEnumerable<BurstroyMonitoring.Data.Models.VwDustDataFull>

@{
    ViewData["Title"] = "Данные DUST";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1 class="h3 mb-0">Данные DUST</h1>
        <div class="d-flex gap-2 align-items-center">
            <div class="form-check form-switch me-2">
                <input class="form-check-input" type="checkbox" role="switch" id="autoRefresh">
                <label class="form-check-label small" for="autoRefresh">Автообновление</label>
            </div>
            <a href="@Url.Action("DataViewer")" class="btn btn-outline-primary btn-sm">Просмотр и экспорт</a>
        </div>
    </div>

    <!-- Поиск и фильтры -->
    <div class="card mb-3 shadow-sm">
        <div class="card-body py-2">
            <form method="get" class="row g-2 align-items-center">
                <div class="col-auto flex-grow-1">
                    <input type="text" name="search" value="@ViewBag.Search" 
                           placeholder="Поиск по S/N, названию точки..." 
                           class="form-control form-control-sm" />
                </div>
                <div class="col-auto">
                    <button type="submit" class="btn btn-primary btn-sm">Найти</button>
                    <a href="@Url.Action("Index")" class="btn btn-outline-secondary btn-sm">Сбросить</a>
                </div>
            </form>
        </div>
    </div>

    <!-- Пагинация сверху -->
    <div class="mb-2">
        @await Html.PartialAsync("_Pagination")
    </div>

    <!-- Таблица данных -->
    <div class="table-responsive shadow-sm rounded">
        <table class="table table-sm table-hover table-striped align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <!-- <th>
                        <a href="@Url.Action("Index", new { 
                            page = ViewBag.Page, 
                            pageSize = ViewBag.PageSize, 
                            search = ViewBag.Search,
                            sortBy = "DustDataId",
                            sortDesc = ViewBag.SortBy == "DustDataId" ? !ViewBag.SortDesc : true
                        })" class="text-decoration-none text-dark">
                            ID @(ViewBag.SortBy == "DustDataId" ? (ViewBag.SortDesc ? "▼" : "▲") : "")
                        </a>
                    </th> -->
                    <th>Дата</th>
                    <th>S/N</th>
                    <th>Точка</th>
                    <th>PM10</th>
                    <th>PM2.5</th>
                    <th>PM1</th>
                    <th>Темп.</th>
                    <th>Влажн.</th>
                    <th>Лазер</th>
                    <th class="text-end">Детали</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <!-- <td class="small text-muted">@item.DustDataId</td> -->
                        <td class="text-nowrap small">@item.ReceivedAt?.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
                        <td class="fw-bold small">@item.SerialNumber</td>
                        <td class="text-truncate small" style="max-width: 150px;" title="@item.EndpointName">@item.EndpointName</td>
                        <td>
                            @if (item.PM10Act.HasValue)
                            {
                                <span class="badge bg-light text-dark border fw-normal">@item.PM10Act.Value.ToString("F2")</span>
                            }
                            else
                            {
                                <span class="text-muted small">—</span>
                            }
                        </td>
                        <td>
                            @if (item.PM25Act.HasValue)
                            {
                                <span class="badge bg-light text-dark border fw-normal">@item.PM25Act.Value.ToString("F2")</span>
                            }
                            else
                            {
                                <span class="text-muted small">—</span>
                            }
                        </td>
                        <td>
                            @if (item.PM1Act.HasValue)
                            {
                                <span class="badge bg-light text-dark border fw-normal">@item.PM1Act.Value.ToString("F2")</span>
                            }
                            else
                            {
                                <span class="text-muted small">—</span>
                            }
                        </td>
                        <td>
                            @if (item.TemperatureProbe.HasValue)
                            {
                                <span class="small">@item.TemperatureProbe.Value.ToString("F1")°C</span>
                            }
                            else
                            {
                                <span class="text-muted small">—</span>
                            }
                        </td>
                        <td>
                            @if (item.HumidityProbe.HasValue)
                            {
                                <span class="small">@item.HumidityProbe.Value.ToString("F1")%</span>
                            }
                            else
                            {
                                <span class="text-muted small">—</span>
                            }
                        </td>
                        <td>
                            @if (item.LaserStatus.HasValue)
                            {
                                <span class="@(item.LaserStatus > 0 ? "text-success" : "text-danger")" title="Статус лазера: @item.LaserStatus">
                                    @(item.LaserStatus > 0 ? "✓" : "✗")
                                </span>
                            }
                            else
                            {
                                <span class="text-muted small">—</span>
                            }
                        </td>
                        <td class="text-end">
                            <a asp-action="Details" asp-route-id="@item.DustDataId" 
                               class="btn btn-outline-secondary btn-sm py-0 px-2" title="Детали">
                                📊
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Пагинация снизу -->
    <div class="mt-3">
        @await Html.PartialAsync("_Pagination")
    </div>

    <!-- Информация о количестве записей -->
    <div class="mt-2 small text-muted text-end">
        Показано @(((ViewBag.Page - 1) * ViewBag.PageSize) + 1)-@Math.Min(ViewBag.Page * ViewBag.PageSize, ViewBag.TotalCount) 
        из @ViewBag.TotalCount записей
    </div>
</div>
@section Scripts {
    
    <script src="~/js/autoRefresh.js"></script>
    
}