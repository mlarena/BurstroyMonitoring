@model BurstroyMonitoring.Data.Models.ViewModels.SensorViewModel
@{
    var sensorId = Model.Id;
    var sensorType = Model.SensorTypeName.ToLower();
}

<div class="bsp-chart-sensor-card" data-sensor-id="@sensorId" data-sensor-type="@sensorType">
    <div class="filter-container" style="margin-bottom: var(--spacing-md);">
        <div class="filter-header">
            <div class="d-flex align-center flex-wrap" style="gap: var(--spacing-md); width: 100%;">
                <!-- ВЫБОР ПАРАМЕТРА (КНОПКИ) -->
                <div class="d-flex align-center flex-wrap" style="gap: 5px; width: 100%; margin-top: 10px;">
                    <span class="text-secondary" style="margin-right: var(--spacing-sm); font-size: 14px;">Параметр:</span>
                    <div class="btn-group iws-parameter-group" role="group" style="display: flex; gap: 2px; flex-wrap: wrap;">
                        <input type="radio" class="btn-check iws-param-radio" name="iwsParam" id="iwsParamTemp-@sensorId" value="environmentTemperature" checked style="display: none;">
                        <label class="button button--sm button--secondary" for="iwsParamTemp-@sensorId">Темп. воздуха ℃</label>

                        <input type="radio" class="btn-check iws-param-radio" name="iwsParam" id="iwsParamHum-@sensorId" value="humidityPercentage" style="display: none;">
                        <label class="button button--sm button--secondary" for="iwsParamHum-@sensorId">Влажность %</label>

                        <input type="radio" class="btn-check iws-param-radio" name="iwsParam" id="iwsParamDew-@sensorId" value="dewPoint" style="display: none;">
                        <label class="button button--sm button--secondary" for="iwsParamDew-@sensorId">Точка росы ℃</label>

                        <input type="radio" class="btn-check iws-param-radio" name="iwsParam" id="iwsParamPressHpa-@sensorId" value="pressureHpa" style="display: none;">
                        <label class="button button--sm button--secondary" for="iwsParamPressHpa-@sensorId">Давление гПа</label>

                        <input type="radio" class="btn-check iws-param-radio" name="iwsParam" id="iwsParamPressMm-@sensorId" value="pressureMmHg" style="display: none;">
                        <label class="button button--sm button--secondary" for="iwsParamPressMm-@sensorId">Давление мм.рт.ст</label>

                        <input type="radio" class="btn-check iws-param-radio" name="iwsParam" id="iwsParamWindSp-@sensorId" value="windSpeed" style="display: none;">
                        <label class="button button--sm button--secondary" for="iwsParamWindSp-@sensorId">Скорость ветра м/с</label>

                        <input type="radio" class="btn-check iws-param-radio" name="iwsParam" id="iwsParamWindDir-@sensorId" value="windDirection" style="display: none;">
                        <label class="button button--sm button--secondary" for="iwsParamWindDir-@sensorId">Направление ветра º</label>

                        <input type="radio" class="btn-check iws-param-radio" name="iwsParam" id="iwsParamWindV-@sensorId" value="windVSound" style="display: none;">
                        <label class="button button--sm button--secondary" for="iwsParamWindV-@sensorId">Скорость звука м/с</label>

                        <input type="radio" class="btn-check iws-param-radio" name="iwsParam" id="iwsParamPrecType-@sensorId" value="precipitationType" style="display: none;">
                        <label class="button button--sm button--secondary" for="iwsParamPrecType-@sensorId">Тип осадков</label>

                        <input type="radio" class="btn-check iws-param-radio" name="iwsParam" id="iwsParamPrecInt-@sensorId" value="precipitationIntensity" style="display: none;">
                        <label class="button button--sm button--secondary" for="iwsParamPrecInt-@sensorId">Интенсивность осадков мм/час</label>

                        <input type="radio" class="btn-check iws-param-radio" name="iwsParam" id="iwsParamPrecQty-@sensorId" value="precipitationQuantity" style="display: none;">
                        <label class="button button--sm button--secondary" for="iwsParamPrecQty-@sensorId">Осадки за сутки мм</label>

                        <input type="radio" class="btn-check iws-param-radio" name="iwsParam" id="iwsParamCO2-@sensorId" value="co2Level" style="display: none;">
                        <label class="button button--sm button--secondary" for="iwsParamCO2-@sensorId">CO2 ppm</label>

                        <input type="radio" class="btn-check iws-param-radio" name="iwsParam" id="iwsParamVolt-@sensorId" value="supplyVoltage" style="display: none;">
                        <label class="button button--sm button--secondary" for="iwsParamVolt-@sensorId">Напряжение В</label>

                        <input type="radio" class="btn-check iws-param-radio" name="iwsParam" id="iwsParamAcc-@sensorId" value="accelerationStdDev" style="display: none;">
                        <label class="button button--sm button--secondary" for="iwsParamAcc-@sensorId">Вибрации g</label>
                    </div>
                </div>

                @await Html.PartialAsync("_AutoUpdatePartial", new BurstroyMonitoring.Data.Models.ViewModels.AutoUpdateViewModel 
                { 
                    Prefix = "iws", 
                    Color = "secondary" 
                })
                
                <!-- ВЫБОР ИНТЕРВАЛА АГРЕГАЦИИ -->
                @await Html.PartialAsync("_AggregationIntervalPartial", new { 
                    Prefix = "iws", 
                    ActiveInterval = "hour" 
                })
                
                <!-- ВЫБОР ПЕРИОДА -->
                @await Html.PartialAsync("_TimeRangePartial", new { 
                    Prefix = "iws", 
                    ActiveDays = 1 
                })
                
                <!-- ТИП ГРАФИКА -->
                <div class="d-flex align-center">
                    <span class="text-secondary" style="margin-right: var(--spacing-sm); font-size: 14px;">Тип:</span>
                    <div class="btn-group" role="group" style="display: flex; gap: 2px;">
                        <input type="radio" class="btn-check chart-type-radio" name="iwsChartType" id="iwsChartTypeLine" 
                               value="line" autocomplete="off" checked style="display: none;">
                        <label class="button button--sm button--secondary chart-type-label" for="iwsChartTypeLine" 
                               style="border-radius: var(--radius-small) 0 0 var(--radius-small);"
                               title="Линейный график">Линейный</label>
                        
                        <input type="radio" class="btn-check chart-type-radio" name="iwsChartType" id="iwsChartTypeScatter" 
                               value="scatter" autocomplete="off" style="display: none;">
                        <label class="button button--sm button--secondary chart-type-label" for="iwsChartTypeScatter" 
                               style="border-radius: 0 var(--radius-small) var(--radius-small) 0;"
                               title="Точечный график">Точечный</label>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <!-- Один большой график IWS -->
    <div class="chart-main-wrapper" style="background: white; border: 1px solid #dee2e6; border-radius: 8px; padding: 20px; height: 500px; margin-top: 20px;">
        <canvas id="iws-main-chart-@sensorId"></canvas>
    </div>

    <script src="~/js/chartComponents/iws-charts.js"></script>
    <script>
        $(document).ready(function() {
            if (typeof initIWSCharts === 'function') {
                initIWSCharts(@sensorId);
            }
        });
    </script>
</div>