@model BurstroyMonitoring.Data.Models.ViewModels.SensorViewModel
@{
    var sensorId = Model.Id;
    var sensorType = Model.SensorTypeName.ToLower();
}

<div class="bsp-chart-sensor-card" data-sensor-id="@sensorId" data-sensor-type="@sensorType">
    <div class="filter-container" style="margin-bottom: var(--spacing-md);">
        <div class="filter-header">
            <div class="d-flex align-center flex-wrap" style="gap: var(--spacing-md); width: 100%;">
                @await Html.PartialAsync("_AutoUpdatePartial", new BurstroyMonitoring.Data.Models.ViewModels.AutoUpdateViewModel 
                { 
                    Prefix = "iws", 
                    Color = "success" 
                })
                
                <!-- ВЫБОР ИНТЕРВАЛА АГРЕГАЦИИ -->
                <div class="d-flex align-center">
                    @await Html.PartialAsync("_AggregationIntervalPartial", new { 
                        Prefix = "iws", 
                        OutlineColor = "success", 
                        ActiveInterval = "hour" 
                    })
                </div>
                
                <!-- ВЫБОР ПЕРИОДА -->
                <div class="d-flex align-center">
                    @await Html.PartialAsync("_TimeRangePartial", new { 
                        Prefix = "iws", 
                        OutlineColor = "success", 
                        ActiveDays = 1 
                    })
                </div>
                
                <!-- ТИП ГРАФИКА -->
                <div class="d-flex align-center">
                    <span class="text-secondary" style="margin-right: var(--spacing-sm); font-size: 14px;">Тип графика:</span>
                    <div class="btn-group" role="group" style="display: flex; gap: 2px;">
                        <input type="radio" class="btn-check chart-type-radio" name="iwsChartType" id="iwsChartTypeLine" 
                               value="line" autocomplete="off" checked style="display: none;">
                        <label class="button button--sm button--success chart-type-label" for="iwsChartTypeLine" 
                               style="border-radius: var(--radius-small) 0 0 var(--radius-small);">Линейный</label>
                        
                        <input type="radio" class="btn-check chart-type-radio" name="iwsChartType" id="iwsChartTypeScatter" 
                               value="scatter" autocomplete="off" style="display: none;">
                        <label class="button button--sm button--success chart-type-label" for="iwsChartTypeScatter" 
                               style="border-radius: 0 var(--radius-small) var(--radius-small) 0;">Точечный</label>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <!-- Информационная панель для отладки (заглушка вместо графика) -->
    <div class="debug-panel">
        <h4><i class="fas fa-cloud-sun"></i> Метеостанция IWS</h4>
        <div class="sensor-info" style="margin-bottom: 15px; padding: 10px; background: #e9ecef; border-radius: 4px;">
            <p style="margin: 5px 0;"><strong>Точка измерения:</strong> @Model.EndPointsName</p>
            <p style="margin: 5px 0;"><strong>Серийный номер:</strong> @Model.SerialNumber</p>
            <p style="margin: 5px 0;"><strong>Пост мониторинга:</strong> @Model.MonitoringPostName</p>
        </div>
        
        <div id="iwsMethodInfo" class="method-info">
            <p><strong>Метод:</strong> <span id="iwsMethodName" class="method-name">GetIWSDataHour</span></p>
            <p><strong>Параметры:</strong> <span id="iwsMethodParams">sensorId=@sensorId, days=1</span></p>
            <p><strong>URL:</strong> <span id="iwsMethodUrl">/GraphsAndCharts/GetIWSDataHour?sensorId=@sensorId&days=1</span></p>
            <p><strong>Статус:</strong> <span id="iwsMethodStatus" style="color: #28a745;">Готов к загрузке</span></p>
        </div>
        
        <!-- Дополнительная информация о параметрах IWS -->
        <div style="margin-top: 15px; background: #f8f9fa; border-radius: 4px; padding: 10px; font-size: 12px;">
            <details>
                <summary style="cursor: pointer; color: #0066cc; font-weight: 600;">📊 Доступные измерения IWS</summary>
                <ul style="margin-top: 10px; list-style: none; padding-left: 0;">
                    <li><span class="badge" style="background: #17a2b8;">🌡️</span> Температура, влажность, точка росы</li>
                    <li><span class="badge" style="background: #28a745;">💨</span> Скорость и направление ветра</li>
                    <li><span class="badge" style="background: #6f42c1;">📏</span> Атмосферное давление (hPa, mmHg)</li>
                    <li><span class="badge" style="background: #fd7e14;">☔</span> Осадки (тип, интенсивность, количество)</li>
                    <li><span class="badge" style="background: #dc3545;">⚡</span> Уровень CO2, напряжение питания</li>
                </ul>
            </details>
        </div>
        
        <div style="display: flex; gap: 10px; margin-top: 15px;">
            <button class="button button--success test-load-btn" data-sensor-type="iws">
                <i class="fas fa-play"></i> Загрузить данные
            </button>
            <button class="button button--secondary clear-result-btn" data-prefix="iws">
                <i class="fas fa-times"></i> Очистить
            </button>
        </div>
        
        <div id="iwsTestResult" style="margin-top: 15px; display: none;">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px;">
                <h5 style="margin: 0;">Результат запроса:</h5>
                <span class="badge" id="iwsResultBadge" style="background: #28a745; color: white; padding: 3px 8px; border-radius: 4px; font-size: 12px;"></span>
            </div>
            <pre style="background: #1e1e1e; color: #d4d4d4; padding: 15px; border-radius: 4px; max-height: 400px; overflow: auto; font-size: 12px; font-family: 'Courier New', monospace;"></pre>
        </div>
    </div>
    
    <div id="iwsChartContainer" class="w-100" style="min-height: 400px; display: none;">
        <canvas id="iwsChart" class="bsp-chart-canvas"></canvas>
    </div>
</div>