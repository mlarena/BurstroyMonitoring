@model dynamic
@{
    var prefix = Model?.Prefix ?? "";
    var activeDays = Model?.ActiveDays ?? 1;
}

<div class="d-flex align-center time-range-control" 
     data-prefix="@prefix" 
     data-active-days="@activeDays"
     style="gap: var(--spacing-sm);">
    <i class="fas fa-calendar-alt text-secondary" style="font-size: 14px;"></i>
    <span class="text-secondary" style="margin-right: var(--spacing-sm); font-size: 14px;">Период:</span>
    
    <div class="btn-group range-btn-group" role="group" style="display: flex; gap: 2px;">
        <button type="button" 
                class="button button--sm button--secondary range-btn @(activeDays == 1 ? "active" : "")" 
                data-days="1"
                data-prefix="@prefix"
                style="border-radius: var(--radius-small) 0 0 var(--radius-small);"
                title="Последние 24 часа">
            24ч
        </button>
        <button type="button" 
                class="button button--sm button--secondary range-btn @(activeDays == 3 ? "active" : "")" 
                data-days="3"
                data-prefix="@prefix"
                style="border-radius: 0;"
                title="Последние 3 дня">
            3д
        </button>
        <button type="button" 
                class="button button--sm button--secondary range-btn @(activeDays == 7 ? "active" : "")" 
                data-days="7"
                data-prefix="@prefix"
                style="border-radius: 0;"
                title="Последние 7 дней">
            7д
        </button>
        <button type="button" 
                class="button button--sm button--secondary range-btn @(activeDays == 14 ? "active" : "")" 
                data-days="14"
                data-prefix="@prefix"
                style="border-radius: 0;"
                title="Последние 14 дней">
            14д
        </button>
        <button type="button" 
                class="button button--sm button--secondary range-btn @(activeDays == 30 ? "active" : "")" 
                data-days="30"
                data-prefix="@prefix"
                style="border-radius: 0 var(--radius-small) var(--radius-small) 0;"
                title="Последние 30 дней">
            30д
        </button>
    </div>
    <!-- Скрытый инпут для хранения значения, чтобы JS мог его легко считать -->
    <input type="hidden" name="@(prefix)Days" value="@activeDays" class="range-value-input" />
</div>
