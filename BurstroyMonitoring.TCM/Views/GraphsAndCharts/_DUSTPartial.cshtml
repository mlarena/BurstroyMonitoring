@model BurstroyMonitoring.Data.Models.ViewModels.SensorViewModel
@{
    var sensorId = Model.Id;
    var sensorType = Model.SensorTypeName.ToLower();
}

<div class="bsp-chart-sensor-card" data-sensor-id="@sensorId" data-sensor-type="@sensorType">
    <div class="filter-container" style="margin-bottom: var(--spacing-md);">
        <div class="filter-header">
            <div class="d-flex align-center flex-wrap" style="gap: var(--spacing-md); width: 100%;">
                @await Html.PartialAsync("_AutoUpdatePartial", new BurstroyMonitoring.Data.Models.ViewModels.AutoUpdateViewModel 
                { 
                    Prefix = "dust", 
                    Color = "secondary" 
                })
                
                <!-- ВЫБОР ИНТЕРВАЛА АГРЕГАЦИИ -->
                @await Html.PartialAsync("_AggregationIntervalPartial", new { 
                    Prefix = "dust", 
                    ActiveInterval = "hour" 
                })
                
                <!-- ВЫБОР ПЕРИОДА -->
                @await Html.PartialAsync("_TimeRangePartial", new { 
                    Prefix = "dust", 
                    ActiveDays = 1 
                })
                
                <!-- ТИП ГРАФИКА -->
                <div class="d-flex align-center">
                    <span class="text-secondary" style="margin-right: var(--spacing-sm); font-size: 14px;">Тип графика:</span>
                    <div class="btn-group" role="group" style="display: flex; gap: 2px;">
                        <input type="radio" class="btn-check chart-type-radio" name="dustChartType" id="dustChartTypeLine" 
                               value="line" autocomplete="off" checked style="display: none;">
                        <label class="button button--sm button--secondary chart-type-label" for="dustChartTypeLine" 
                               style="border-radius: var(--radius-small) 0 0 var(--radius-small);"
                               title="Линейный график">Линейный</label>
                        
                        <input type="radio" class="btn-check chart-type-radio" name="dustChartType" id="dustChartTypeScatter" 
                               value="scatter" autocomplete="off" style="display: none;">
                        <label class="button button--sm button--secondary chart-type-label" for="dustChartTypeScatter" 
                               style="border-radius: 0 var(--radius-small) var(--radius-small) 0;"
                               title="Точечный график">Точечный</label>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <!-- Информационная панель для отладки (заглушка вместо графика) -->
    <div class="debug-panel">
        <h4><i class="fas fa-microchip"></i> Датчик DUST (пылемер)</h4>
        <div class="sensor-info">
            <p><strong>Точка измерения:</strong> @Model.EndPointsName</p>
            <p><strong>Серийный номер:</strong> @Model.SerialNumber</p>
            <p><strong>Пост мониторинга:</strong> @Model.MonitoringPostName</p>
        </div>
        
        <div id="dustMethodInfo" class="method-info">
            <p><strong>Метод:</strong> <span id="dustMethodName" class="method-name">GetDUSTDataHour</span></p>
            <p><strong>Параметры:</strong> <span id="dustMethodParams">sensorId=@sensorId, days=1</span></p>
            <p><strong>URL:</strong> <span id="dustMethodUrl">/GraphsAndCharts/GetDUSTDataHour?sensorId=@sensorId&days=1</span></p>
            <p><strong>Статус:</strong> <span id="dustMethodStatus" style="color: #28a745;">Готов к загрузке</span></p>
        </div>
        
        <!-- Дополнительная информация о параметрах DUST -->
        <div style="margin-top: 15px; background: #f8f9fa; border-radius: 4px; padding: 10px; font-size: 12px;">
            <details>
                <summary style="cursor: pointer; color: #495057; font-weight: 600;">📊 Параметры качества воздуха</summary>
                <ul style="margin-top: 10px; list-style: none; padding-left: 0; display: grid; grid-template-columns: repeat(2, 1fr); gap: 5px;">
                    <li><span class="badge" style="background: #6c757d;">🌫️</span> PM1 (актуальное)</li>
                    <li><span class="badge" style="background: #6c757d;">🌫️</span> PM2.5 (актуальное)</li>
                    <li><span class="badge" style="background: #6c757d;">🌫️</span> PM10 (актуальное)</li>
                    <li><span class="badge" style="background: #6c757d;">📊</span> PM1 (среднее)</li>
                    <li><span class="badge" style="background: #6c757d;">📊</span> PM2.5 (среднее)</li>
                    <li><span class="badge" style="background: #6c757d;">📊</span> PM10 (среднее)</li>
                    <li><span class="badge" style="background: #6c757d;">💨</span> Поток проб</li>
                    <li><span class="badge" style="background: #6c757d;">🌡️</span> Температура</li>
                    <li><span class="badge" style="background: #6c757d;">💧</span> Влажность</li>
                </ul>
            </details>
        </div>
        
        <div style="display: flex; gap: 10px; margin-top: 15px;">
            <button class="test-load-btn" data-sensor-type="dust">
                <i class="fas fa-play"></i> Тестовый вызов метода
            </button>
            <button class="clear-result-btn" data-prefix="dust">
                <i class="fas fa-times"></i> Очистить
            </button>
        </div>
        
        <!-- Результат вызова -->
        <div id="dustTestResult" style="margin-top: 15px; display: none;">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px;">
                <h5 style="margin: 0;">Результат:</h5>
                <span class="badge" id="dustResultBadge" style="background: #28a745;"></span>
            </div>
            <pre style="background: #1e1e1e; color: #d4d4d4; padding: 15px; border-radius: 4px; max-height: 300px; overflow: auto; font-size: 12px;"></pre>
        </div>
    </div>
    
    <div id="dustChartContainer" class="w-100" style="min-height: 400px; display: none;">
        <canvas id="dustChart" class="bsp-chart-canvas"></canvas>
    </div>
</div>