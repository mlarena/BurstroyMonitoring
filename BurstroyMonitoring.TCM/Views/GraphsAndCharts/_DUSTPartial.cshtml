@model BurstroyMonitoring.Data.Models.ViewModels.SensorViewModel
@{
    var sensorId = Model.Id;
    var sensorType = Model.SensorTypeName.ToLower();
}

<div class="bsp-chart-sensor-card" data-sensor-id="@sensorId" data-sensor-type="@sensorType">
    <div class="filter-container" style="margin-bottom: var(--spacing-md);">
        <div class="filter-header">
            <div class="d-flex align-center flex-wrap" style="gap: var(--spacing-md); width: 100%;">
                @await Html.PartialAsync("_AutoUpdatePartial", new BurstroyMonitoring.Data.Models.ViewModels.AutoUpdateViewModel 
                { 
                    Prefix = "dust", 
                    Color = "secondary" 
                })
                
                <!-- ВЫБОР ИНТЕРВАЛА АГРЕГАЦИИ -->
                @await Html.PartialAsync("_AggregationIntervalPartial", new { 
                    Prefix = "dust", 
                    ActiveInterval = "hour" 
                })
                
                <!-- ВЫБОР ПЕРИОДА -->
                @await Html.PartialAsync("_TimeRangePartial", new { 
                    Prefix = "dust", 
                    ActiveDays = 1 
                })
                
                <!-- ТИП ГРАФИКА -->
                <div class="d-flex align-center">
                    <span class="text-secondary" style="margin-right: var(--spacing-sm); font-size: 14px;">Тип графика:</span>
                    <div class="btn-group" role="group" style="display: flex; gap: 2px;">
                        <input type="radio" class="btn-check chart-type-radio" name="dustChartType" id="dustChartTypeLine" 
                               value="line" autocomplete="off" checked style="display: none;">
                        <label class="button button--sm button--secondary chart-type-label" for="dustChartTypeLine" 
                               style="border-radius: var(--radius-small) 0 0 var(--radius-small);"
                               title="Линейный график">Линейный</label>
                        
                        <input type="radio" class="btn-check chart-type-radio" name="dustChartType" id="dustChartTypeScatter" 
                               value="scatter" autocomplete="off" style="display: none;">
                        <label class="button button--sm button--secondary chart-type-label" for="dustChartTypeScatter" 
                               style="border-radius: 0 var(--radius-small) var(--radius-small) 0;"
                               title="Точечный график">Точечный</label>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
                <!-- ВЫБОР ПАРАМЕТРА (КНОПКИ) -->
                <div class="d-flex align-center flex-wrap" style="gap: 5px; width: 100%; margin-top: 10px;">
                    <span class="text-secondary" style="margin-right: var(--spacing-sm); font-size: 14px;">Параметр:</span>
                    <div class="btn-group dust-parameter-group" role="group" style="display: flex; gap: 2px; flex-wrap: wrap;">
                        <input type="radio" class="btn-check dust-param-radio" name="dustParam" id="dustParamPM-@sensorId" value="pm_all" checked style="display: none;">
                        <label class="button button--sm button--secondary" for="dustParamPM-@sensorId">Все частицы PM</label>

                        <input type="radio" class="btn-check dust-param-radio" name="dustParam" id="dustParamFlow-@sensorId" value="flowProbe" style="display: none;">
                        <label class="button button--sm button--secondary" for="dustParamFlow-@sensorId">Поток воздуха</label>

                        <input type="radio" class="btn-check dust-param-radio" name="dustParam" id="dustParamHum-@sensorId" value="humidityProbe" style="display: none;">
                        <label class="button button--sm button--secondary" for="dustParamHum-@sensorId">Влажность датчика %</label>

                        <input type="radio" class="btn-check dust-param-radio" name="dustParam" id="dustParamTemp-@sensorId" value="temperatureProbe" style="display: none;">
                        <label class="button button--sm button--secondary" for="dustParamTemp-@sensorId">Темп. датчика °С</label>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <!-- Один большой график DUST -->
    <div class="chart-main-wrapper" style="background: white; border: 1px solid #dee2e6; border-radius: 8px; padding: 20px; height: 500px; margin-top: 20px;">
        <canvas id="dust-main-chart-@sensorId"></canvas>
    </div>

    <script src="~/js/chartComponents/dust-charts.js"></script>
    <script>
        $(document).ready(function() {
            if (typeof initDUSTCharts === 'function') {
                initDUSTCharts(@sensorId);
            }
        });
    </script>
</div>