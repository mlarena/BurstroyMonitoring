@model BurstroyMonitoring.Data.Models.ViewModels.SensorSelectionViewModel

@{
    ViewData["Title"] = "Графики и диаграммы";
}
<link rel="stylesheet" href="~/css/charts.css" asp-append-version="true" />

<div class="container-fluid">

    <div class="card mb-3 shadow-sm d-inline-block">
        <div class="card-body py-2">
            <form id="sensorForm" class="row g-2 align-items-center">
                <div class="col-auto d-flex align-items-center gap-2">
                    <label for="monitoringPostSelect" class="form-label small fw-bold mb-0 text-nowrap">Пост мониторинга</label>
                    <select id="monitoringPostSelect" class="form-select form-select-sm" 
                            asp-for="SelectedMonitoringPostId" 
                            asp-items="Model.MonitoringPosts"
                            style="width: auto; min-width: 250px;">                           
                    </select>
                </div>
            </form>
        </div>
    </div>

    <div id="chartDashboard" class="dashboard" style="display: none;">
        <div class="card mb-3 shadow-sm">
            <div class="card-body py-2 d-flex flex-wrap align-items-center gap-4">
                <!-- Период -->
                <div class="d-flex align-items-center gap-2">
                    <span class="small fw-bold text-muted">📅 Период:</span>
                    <div class="btn-group btn-group-sm shadow-sm">
                        <button type="button" class="btn btn-outline-primary range-btn active" data-days="1">24ч</button>
                        <button type="button" class="btn btn-outline-primary range-btn" data-days="3">3д</button>
                        <button type="button" class="btn btn-outline-primary range-btn" data-days="7">7д</button>
                        <button type="button" class="btn btn-outline-primary range-btn" data-days="14">14д</button>
                        <button type="button" class="btn btn-outline-primary range-btn" data-days="30">30д</button>
                    </div>
                </div>

                <!-- Агрегация -->
                <div class="d-flex align-items-center gap-2">
                    <span class="small fw-bold text-muted">📈 Агрегация:</span>
                    <div class="btn-group btn-group-sm shadow-sm">
                        <button type="button" class="btn btn-outline-info aggregation-btn" data-interval="raw">Все</button>
                        <button type="button" class="btn btn-outline-info aggregation-btn" data-interval="tenminutes">10 мин</button>
                        <button type="button" class="btn btn-outline-info aggregation-btn active" data-interval="hour">Час</button>
                    </div>
                </div>

                <!-- Настройка подсказки -->
                <div class="form-check form-switch">
                    <input class="form-check-input" type="checkbox" role="switch" id="showAllMetrics" checked>
                    <label class="form-check-label small fw-bold text-muted" for="showAllMetrics">Все метрики</label>
                </div>

                <div class="card-body py-2 d-flex justify-content-between align-items-center">
                        <div class="btn-group btn-group-sm" id="groupSelector">
                            <!-- Кнопки будут добавлены через JS -->
                        </div>
                        <div id="sensorSubSelectContainer" style="display: none;" class="d-flex align-items-center gap-2">
                            <label for="sensorSubSelect" class="small fw-bold text-muted mb-0">Устройство:</label>
                            <select id="sensorSubSelect" class="form-select form-select-sm" style="width: auto;"></select>
                        </div>
                 </div>
            </div>
        </div>

         <!-- <div class="card mb-3 shadow-sm">
           <div class="card-body py-2 d-flex justify-content-between align-items-center">
                <div class="btn-group btn-group-sm" id="groupSelector">
                   
                </div>
                <div id="sensorSubSelectContainer" style="display: none;" class="d-flex align-items-center gap-2">
                    <label for="sensorSubSelect" class="small fw-bold text-muted mb-0">Устройство:</label>
                    <select id="sensorSubSelect" class="form-select form-select-sm" style="width: auto;"></select>
                </div>
            </div>
        </div> -->

        <div class="card mb-3 shadow-sm border-info">
            <div class="card-header bg-info text-white py-1 d-flex justify-content-between align-items-center">
                <span class="small fw-bold">📋 Текущие значения (наведите на точку)</span>
                <button type="button" class="btn btn-light btn-sm py-0 px-2" id="resetFilterBtn" style="font-size: 0.75rem;">Сброс</button>
            </div>
            <div class="card-body p-1">
                <div class="d-flex flex-wrap gap-1" id="statsGrid">
                    <!-- Заполняется через JS -->
                </div>
            </div>
        </div>

        <div class="chart-wrapper bg-white border rounded shadow-sm p-3 position-relative">
            <div id="tooltip" class="chart-tooltip"></div>
            <svg id="chart" width="1200" height="430" viewBox="0 0 1200 430" style="width: 100%; height: auto;"></svg>
        </div>
    </div>
</div>

<style>
    /* Стили тултипа из тестового проекта (переименованы для исключения конфликта с Bootstrap) */
    .chart-tooltip {
        position: fixed;
        padding: 12px 16px;
        background: rgba(11, 43, 66, 0.95);
        color: white;
        border-radius: 12px;
        pointer-events: none;
        font-size: 0.85rem;
        box-shadow: 0 10px 25px rgba(0,0,0,0.2);
        backdrop-filter: blur(4px);
        border: 1px solid rgba(255,255,255,0.1);
        z-index: 2000;
        display: none;
        min-width: 200px;
    }
    
    .tooltip-title {
        font-weight: 600;
        margin-bottom: 8px;
        border-bottom: 1px solid rgba(255,255,255,0.2);
        padding-bottom: 6px;
        font-size: 0.9rem;
    }

    .tooltip-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 15px;
        margin-bottom: 4px;
    }

    .tooltip-value {
        font-weight: 700;
        font-family: 'JetBrains Mono', monospace;
        color: #fff;
    }

    /* Компактные карточки значений */
    .stat-card {
        flex: 1 1 calc(25% - 0.5rem); /* 4 колонки на больших экранах */
        min-width: 200px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0.25rem 0.5rem;
        background: var(--bs-body-bg);
        border: 1px solid var(--bs-border-color);
        border-radius: 0.25rem;
        font-size: 0.75rem;
    }
    
    .stat-card .label-content {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        overflow: hidden;
    }
    
    .stat-label {
        white-space: nowrap;
        overflow: hidden;
        text-truncate: ellipsis;
        color: var(--bs-secondary-color);
    }
    
    .stat-value {
        font-weight: bold;
        margin-left: 0.5rem;
        white-space: nowrap;
    }

    .stat-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        flex-shrink: 0;
    }

    /* Интеграция JS-кнопок с Bootstrap */
    .group-btn {
        display: inline-block;
        font-weight: 400;
        line-height: 1.5;
        color: #212529;
        text-align: center;
        text-decoration: none;
        vertical-align: middle;
        cursor: pointer;
        user-select: none;
        background-color: transparent;
        border: 1px solid #6c757d;
        padding: 0.25rem 0.5rem;
        font-size: 0.875rem;
        border-radius: 0.25rem;
        transition: color 0.15s ease-in-out, background-color 0.15s ease-in-out, border-color 0.15s ease-in-out, box-shadow 0.15s ease-in-out;
    }
    .group-btn:hover, .group-btn.active {
        color: #fff;
        background-color: #6c757d;
        border-color: #6c757d;
    }
</style>

@section Scripts {
    <script src="~/js/chartComponents/d3.v7.min.js"></script>
    <script src="~/js/chartComponents/chart-utils.js" asp-append-version="true"></script>
    <script>
        $(document).ready(function () {
            console.log("Page ready, initializing UI...");
            const chartManager = new ChartManager("#chart", "#tooltip", "#statsGrid");

            // Инициализация кнопок групп
            const groupSelector = d3.select("#groupSelector");
            Object.keys(metricsGroups).forEach(key => {
                groupSelector.append("button")
                    .attr("class", "btn btn-outline-secondary")
                    .attr("id", "btn-group-" + key)
                    .text(key)
                    .on("click", function() {
                        const key = d3.select(this).text();
                        console.log(`Group button clicked: ${key}`);
                        chartManager.currentGroup = key;
                        chartManager.activeMetricKey = null;
                        d3.selectAll("#groupSelector .btn").classed("active", false).classed("btn-secondary", false).classed("btn-outline-secondary", true);
                        d3.select(this).classed("active", true).classed("btn-outline-secondary", false).classed("btn-secondary", true);
                        
                        const postId = $('#monitoringPostSelect').val();
                        if (postId) {
                            // Скрываем контейнер перед загрузкой новых данных
                            $('#sensorSubSelectContainer').hide();
                            
                            $.get('/GraphsAndCharts/GetSensorsByPost', { monitoringPostId: postId }, function (data) {
                                // Ищем все датчики этой группы
                                const groupSensors = data.filter(s => s.text.toUpperCase().includes(key.toUpperCase()));
                                
                                if (groupSensors.length > 0) {
                                    const subSelectContainer = $('#sensorSubSelectContainer');
                                    const subSelect = $('#sensorSubSelect');
                                    subSelect.empty(); // Очищаем старые опции
                                    
                                    if (groupSensors.length > 1) {
                                        // Если датчиков несколько, заполняем и показываем список
                                        groupSensors.forEach(s => {
                                            subSelect.append($('<option>', { value: s.value, text: s.text }));
                                        });
                                        subSelectContainer.show();
                                        chartManager.loadData(groupSensors[0].value, key, chartManager.currentDays, chartManager.currentInterval);
                                    } else {
                                        // Если датчик один, скрываем контейнер и просто загружаем данные
                                        subSelectContainer.hide();
                                        chartManager.loadData(groupSensors[0].value, key, chartManager.currentDays, chartManager.currentInterval);
                                    }
                                } else {
                                    console.warn(`No sensor found for group ${key} on post ${postId}`);
                                    chartManager.chartData = [];
                                    chartManager.render();
                                }
                            });
                        }
                    });
            });

            // Обработчик смены конкретного датчика в группе
            $('#sensorSubSelect').change(function() {
                const sensorId = $(this).val();
                console.log(`Sub-sensor changed: ${sensorId}`);
                chartManager.loadData(sensorId, chartManager.currentGroup, chartManager.currentDays, chartManager.currentInterval);
            });

            $('#monitoringPostSelect').change(function () {
                const postId = $(this).val();
                console.log(`Monitoring post changed: ${postId}`);
                if (postId) {
                    $.get('/GraphsAndCharts/GetSensorsByPost', { monitoringPostId: postId }, function (data) {
                        console.log("Sensors for post:", data);
                        if (data && data.length > 1) {
                            // Показываем дашборд
                            $('#chartDashboard').show();
                            
                            // Обновляем видимость кнопок групп на основе доступных датчиков
                            const availableGroups = new Set();
                            data.forEach(s => {
                                Object.keys(metricsGroups).forEach(groupKey => {
                                    if (s.text.toUpperCase().includes(groupKey)) {
                                        availableGroups.add(groupKey);
                                    }
                                });
                            });
                            
                            console.log("Available groups for this post:", Array.from(availableGroups));
                            
                            d3.selectAll(".group-btn").each(function() {
                                const btn = d3.select(this);
                                const group = btn.text();
                                btn.style("display", availableGroups.has(group) ? "inline-block" : "none");
                            });

                            // Берем первый реальный датчик
                            const firstSensor = data[1];
                            $.get('/GraphsAndCharts/GetSensorData', { sensorId: firstSensor.value }, function (sensorInfo) {
                                console.log("Initial sensor info:", sensorInfo);
                                chartManager.currentGroup = sensorInfo.sensorTypeName;
                                
                                d3.selectAll(".group-btn").classed("active", false);
                                d3.select("#btn-group-" + chartManager.currentGroup).classed("active", true);
                                
                                // Имитируем клик по кнопке группы для инициализации списка под-датчиков
                                d3.select("#btn-group-" + chartManager.currentGroup).dispatch("click");
                            });
                        } else {
                            console.warn("No sensors found for this post");
                            $('#chartDashboard').hide();
                        }
                    });
                } else {
                    $('#chartDashboard').hide();
                }
            });

            $('.range-btn').click(function() {
                $('.range-btn').removeClass('active');
                $(this).addClass('active');
                const days = $(this).data('days');
                console.log(`Range changed: ${days} days`);
                chartManager.loadData(chartManager.currentSensorId, chartManager.currentGroup, days, chartManager.currentInterval);
            });

            $('.aggregation-btn').click(function() {
                $('.aggregation-btn').removeClass('active');
                $(this).addClass('active');
                const interval = $(this).data('interval');
                console.log(`Aggregation changed: ${interval}`);
                chartManager.loadData(chartManager.currentSensorId, chartManager.currentGroup, chartManager.currentDays, interval);
            });

            $('#resetFilterBtn').click(function() {
                console.log("Reset filter clicked");
                chartManager.resetFilter();
            });
        });
    </script>
}