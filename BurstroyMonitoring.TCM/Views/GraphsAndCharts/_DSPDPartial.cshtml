@model BurstroyMonitoring.Data.Models.ViewModels.SensorViewModel
@{
    var sensorId = Model.Id;
    var sensorType = Model.SensorTypeName.ToLower();
}

<div class="bsp-chart-sensor-card" data-sensor-id="@sensorId" data-sensor-type="@sensorType">
    <div class="filter-container" style="margin-bottom: var(--spacing-md);">
        <div class="filter-header">
            <div class="d-flex align-center flex-wrap" style="gap: var(--spacing-md); width: 100%;">
                @await Html.PartialAsync("_AutoUpdatePartial", new BurstroyMonitoring.Data.Models.ViewModels.AutoUpdateViewModel 
                { 
                    Prefix = "dspd", 
                    Color = "secondary" 
                })
                
                <!-- ВЫБОР ИНТЕРВАЛА АГРЕГАЦИИ -->
                @await Html.PartialAsync("_AggregationIntervalPartial", new { 
                    Prefix = "dspd", 
                    ActiveInterval = "hour" 
                })
                
                <!-- ВЫБОР ПЕРИОДА -->
                @await Html.PartialAsync("_TimeRangePartial", new { 
                    Prefix = "dspd", 
                    ActiveDays = 1 
                })
                
                <!-- ТИП ГРАФИКА -->
                <div class="d-flex align-center">
                    <span class="text-secondary" style="margin-right: var(--spacing-sm); font-size: 14px;">Тип графика:</span>
                    <div class="btn-group" role="group" style="display: flex; gap: 2px;">
                        <input type="radio" class="btn-check chart-type-radio" name="dspdChartType" id="dspdChartTypeLine" 
                               value="line" autocomplete="off" checked style="display: none;">
                        <label class="button button--sm button--secondary chart-type-label" for="dspdChartTypeLine" 
                               style="border-radius: var(--radius-small) 0 0 var(--radius-small);"
                               title="Линейный график">Линейный</label>
                        
                        <input type="radio" class="btn-check chart-type-radio" name="dspdChartType" id="dspdChartTypeScatter" 
                               value="scatter" autocomplete="off" style="display: none;">
                        <label class="button button--sm button--secondary chart-type-label" for="dspdChartTypeScatter" 
                               style="border-radius: 0 var(--radius-small) var(--radius-small) 0;"
                               title="Точечный график">Точечный</label>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
                <!-- ВЫБОР ПАРАМЕТРА (КНОПКИ) -->
                <div class="d-flex align-center flex-wrap" style="gap: 5px; width: 100%; margin-top: 10px;">
                    <span class="text-secondary" style="margin-right: var(--spacing-sm); font-size: 14px;">Параметр:</span>
                    <div class="btn-group dspd-parameter-group" role="group" style="display: flex; gap: 2px; flex-wrap: wrap;">
                        <input type="radio" class="btn-check dspd-param-radio" name="dspdParam" id="dspdParamGrip-@sensorId" value="gripCoefficient" checked style="display: none;">
                        <label class="button button--sm button--secondary" for="dspdParamGrip-@sensorId">Сцепление</label>

                        <input type="radio" class="btn-check dspd-param-radio" name="dspdParam" id="dspdParamRoadTemp-@sensorId" value="roadTemperature" style="display: none;">
                        <label class="button button--sm button--secondary" for="dspdParamRoadTemp-@sensorId">Темп. дороги °С</label>

                        <input type="radio" class="btn-check dspd-param-radio" name="dspdParam" id="dspdParamWater-@sensorId" value="waterHeight" style="display: none;">
                        <label class="button button--sm button--secondary" for="dspdParamWater-@sensorId">Вода мм</label>

                        <input type="radio" class="btn-check dspd-param-radio" name="dspdParam" id="dspdParamIce-@sensorId" value="iceHeight" style="display: none;">
                        <label class="button button--sm button--secondary" for="dspdParamIce-@sensorId">Лед мм</label>

                        <input type="radio" class="btn-check dspd-param-radio" name="dspdParam" id="dspdParamSnow-@sensorId" value="snowHeight" style="display: none;">
                        <label class="button button--sm button--secondary" for="dspdParamSnow-@sensorId">Снег мм</label>

                        <input type="radio" class="btn-check dspd-param-radio" name="dspdParam" id="dspdParamShake-@sensorId" value="shakeLevel" style="display: none;">
                        <label class="button button--sm button--secondary" for="dspdParamShake-@sensorId">Дрожание g</label>

                        <input type="radio" class="btn-check dspd-param-radio" name="dspdParam" id="dspdParamVolt-@sensorId" value="voltagePower" style="display: none;">
                        <label class="button button--sm button--secondary" for="dspdParamVolt-@sensorId">Напряжение В</label>

                        <input type="radio" class="btn-check dspd-param-radio" name="dspdParam" id="dspdParamAngle-@sensorId" value="roadAngle" style="display: none;">
                        <label class="button button--sm button--secondary" for="dspdParamAngle-@sensorId">Угол наклона °</label>

                        <input type="radio" class="btn-check dspd-param-radio" name="dspdParam" id="dspdParamPgm-@sensorId" value="pgmPercentage" style="display: none;">
                        <label class="button button--sm button--secondary" for="dspdParamPgm-@sensorId">ПГМ %</label>

                        <input type="radio" class="btn-check dspd-param-radio" name="dspdParam" id="dspdParamFreeze-@sensorId" value="freezeTemperature" style="display: none;">
                        <label class="button button--sm button--secondary" for="dspdParamFreeze-@sensorId">Темп. замерзания °С</label>

                        <input type="radio" class="btn-check dspd-param-radio" name="dspdParam" id="dspdParamDist-@sensorId" value="distanceToSurface" style="display: none;">
                        <label class="button button--sm button--secondary" for="dspdParamDist-@sensorId">Расстояние мм</label>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <!-- Один большой график DSPD -->
    <div class="chart-main-wrapper" style="background: white; border: 1px solid #dee2e6; border-radius: 8px; padding: 20px; height: 500px; margin-top: 20px;">
        <canvas id="dspd-main-chart-@sensorId"></canvas>
    </div>

    <script src="~/js/chartComponents/dspd-charts.js"></script>
    <script>
        $(document).ready(function() {
            if (typeof initDSPDCharts === 'function') {
                initDSPDCharts(@sensorId);
            }
        });
    </script>
</div>
        
        <div id="dspdMethodInfo" class="method-info">
            <p><strong>Метод:</strong> <span id="dspdMethodName" class="method-name">GetDSPDDataHour</span></p>
            <p><strong>Параметры:</strong> <span id="dspdMethodParams">sensorId=@sensorId, days=1</span></p>
            <p><strong>URL:</strong> <span id="dspdMethodUrl">/GraphsAndCharts/GetDSPDDataHour?sensorId=@sensorId&days=1</span></p>
            <p><strong>Статус:</strong> <span id="dspdMethodStatus" style="color: #28a745;">Готов к загрузке</span></p>
        </div>
        
        <!-- Дополнительная информация о параметрах DSPD -->
        <div style="margin-top: 15px; background: #f8f9fa; border-radius: 4px; padding: 10px; font-size: 12px;">
            <details>
                <summary style="cursor: pointer; color: #495057; font-weight: 600;">📊 Параметры дорожных условий</summary>
                <ul style="margin-top: 10px; list-style: none; padding-left: 0; display: grid; grid-template-columns: repeat(2, 1fr); gap: 5px;">
                    <li><span class="badge" style="background: #6c757d;">⚡</span> Коэффициент сцепления</li>
                    <li><span class="badge" style="background: #6c757d;">📊</span> Уровень вибрации</li>
                    <li><span class="badge" style="background: #6c757d;">🌡️</span> Температура корпуса</li>
                    <li><span class="badge" style="background: #6c757d;">🌡️</span> Температура дороги</li>
                    <li><span class="badge" style="background: #6c757d;">💧</span> Высота воды</li>
                    <li><span class="badge" style="background: #6c757d;">❄️</span> Высота льда</li>
                    <li><span class="badge" style="background: #6c757d;">⛄</span> Высота снега</li>
                    <li><span class="badge" style="background: #6c757d;">📈</span> Процент льда</li>
                </ul>
            </details>
        </div>
        
        <div style="display: flex; gap: 10px; margin-top: 15px;">
            <button class="test-load-btn" data-sensor-type="dspd">
                <i class="fas fa-play"></i> Тестовый вызов метода
            </button>
            <button class="clear-result-btn" data-prefix="dspd">
                <i class="fas fa-times"></i> Очистить
            </button>
        </div>
        
        <!-- Результат вызова -->
        <div id="dspdTestResult" style="margin-top: 15px; display: none;">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px;">
                <h5 style="margin: 0;">Результат:</h5>
                <span class="badge" id="dspdResultBadge" style="background: #28a745;"></span>
            </div>
            <pre style="background: #1e1e1e; color: #d4d4d4; padding: 15px; border-radius: 4px; max-height: 300px; overflow: auto; font-size: 12px;"></pre>
        </div>
    </div>
    
    <div id="dspdChartContainer" class="w-100" style="min-height: 400px; display: none;">
        <canvas id="dspdChart" class="bsp-chart-canvas"></canvas>
    </div>
</div>