@model dynamic
@{
    string prefix = Model.Prefix;
    string activeInterval = Model.ActiveInterval ?? "hour";
}

<div class="d-flex align-center">
    <span class="text-secondary" style="margin-right: var(--spacing-sm); font-size: 14px;">Интервал:</span>
    <div class="btn-group" role="group" style="display: flex; gap: 2px;">
        <input type="radio" class="btn-check" name="@(prefix)Interval" id="@(prefix)IntervalRaw" 
               value="raw" autocomplete="off" @(activeInterval == "raw" ? "checked" : "") style="display: none;">
        <label class="button button--sm button--secondary" for="@(prefix)IntervalRaw" 
               style="border-radius: var(--radius-small) 0 0 var(--radius-small);">Сырые</label>
        
        <input type="radio" class="btn-check" name="@(prefix)Interval" id="@(prefix)IntervalTen" 
               value="ten-minute" autocomplete="off" @(activeInterval == "ten-minute" ? "checked" : "") style="display: none;">
        <label class="button button--sm button--secondary" for="@(prefix)IntervalTen" 
               style="border-radius: 0;">10 мин</label>
        
        <input type="radio" class="btn-check" name="@(prefix)Interval" id="@(prefix)IntervalHour" 
               value="hour" autocomplete="off" @(activeInterval == "hour" ? "checked" : "") style="display: none;">
        <label class="button button--sm button--secondary" for="@(prefix)IntervalHour" 
               style="border-radius: 0 var(--radius-small) var(--radius-small) 0;">1 час</label>
    </div>
</div>
