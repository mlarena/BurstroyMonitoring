@model BurstroyMonitoring.Data.Models.ViewModels.SensorViewModel
@{
    var sensorId = Model.Id;
    var sensorType = Model.SensorTypeName.ToLower();
}

<div class="bsp-chart-sensor-card" data-sensor-id="@sensorId" data-sensor-type="@sensorType">
    <div class="filter-container" style="margin-bottom: var(--spacing-md);">
        <div class="filter-header">
            <div class="d-flex align-center flex-wrap" style="gap: var(--spacing-md); width: 100%;">
                @await Html.PartialAsync("_AutoUpdatePartial", new BurstroyMonitoring.Data.Models.ViewModels.AutoUpdateViewModel 
                { 
                    Prefix = "mueks", 
                    Color = "secondary" 
                })
                
                <!-- ВЫБОР ИНТЕРВАЛА АГРЕГАЦИИ -->
                @await Html.PartialAsync("_AggregationIntervalPartial", new { 
                    Prefix = "mueks", 
                    ActiveInterval = "hour" 
                })
                
                <!-- ВЫБОР ПЕРИОДА -->
                @await Html.PartialAsync("_TimeRangePartial", new { 
                    Prefix = "mueks", 
                    ActiveDays = 1 
                })
                
                <!-- ТИП ГРАФИКА -->
                <div class="d-flex align-center">
                    <span class="text-secondary" style="margin-right: var(--spacing-sm); font-size: 14px;">Тип графика:</span>
                    <div class="btn-group" role="group" style="display: flex; gap: 2px;">
                        <input type="radio" class="btn-check chart-type-radio" name="mueksChartType" id="mueksChartTypeLine" 
                               value="line" autocomplete="off" checked style="display: none;">
                        <label class="button button--sm button--secondary chart-type-label" for="mueksChartTypeLine" 
                               style="border-radius: var(--radius-small) 0 0 var(--radius-small);"
                               title="Линейный график">Линейный</label>
                        
                        <input type="radio" class="btn-check chart-type-radio" name="mueksChartType" id="mueksChartTypeScatter" 
                               value="scatter" autocomplete="off" style="display: none;">
                        <label class="button button--sm button--secondary chart-type-label" for="mueksChartTypeScatter" 
                               style="border-radius: 0 var(--radius-small) var(--radius-small) 0;"
                               title="Точечный график">Точечный</label>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
                <!-- ВЫБОР ПАРАМЕТРА (КНОПКИ) -->
                <div class="d-flex align-center flex-wrap" style="gap: 5px; width: 100%; margin-top: 10px;">
                    <span class="text-secondary" style="margin-right: var(--spacing-sm); font-size: 14px;">Параметр:</span>
                    <div class="btn-group mueks-parameter-group" role="group" style="display: flex; gap: 2px; flex-wrap: wrap;">
                        <input type="radio" class="btn-check mueks-param-radio" name="mueksParam" id="mueksParamTemp-@sensorId" value="temperatureBox" checked style="display: none;">
                        <label class="button button--sm button--secondary" for="mueksParamTemp-@sensorId">Темп. бокса °С</label>

                        <input type="radio" class="btn-check mueks-param-radio" name="mueksParam" id="mueksParamVoltIn-@sensorId" value="voltagePowerIn12b" style="display: none;">
                        <label class="button button--sm button--secondary" for="mueksParamVoltIn-@sensorId">Напр. вход 12В</label>

                        <input type="radio" class="btn-check mueks-param-radio" name="mueksParam" id="mueksParamVoltOut-@sensorId" value="voltageOut12b" style="display: none;">
                        <label class="button button--sm button--secondary" for="mueksParamVoltOut-@sensorId">Напр. выход 12В</label>

                        <input type="radio" class="btn-check mueks-param-radio" name="mueksParam" id="mueksParamVoltAkb-@sensorId" value="voltageAkb" style="display: none;">
                        <label class="button button--sm button--secondary" for="mueksParamVoltAkb-@sensorId">Напр. АКБ</label>

                        <input type="radio" class="btn-check mueks-param-radio" name="mueksParam" id="mueksParamCurr12-@sensorId" value="currentOut12b" style="display: none;">
                        <label class="button button--sm button--secondary" for="mueksParamCurr12-@sensorId">Ток 12В</label>

                        <input type="radio" class="btn-check mueks-param-radio" name="mueksParam" id="mueksParamCurr48-@sensorId" value="currentOut48b" style="display: none;">
                        <label class="button button--sm button--secondary" for="mueksParamCurr48-@sensorId">Ток 48В</label>

                        <input type="radio" class="btn-check mueks-param-radio" name="mueksParam" id="mueksParamCurrAkb-@sensorId" value="currentAkb" style="display: none;">
                        <label class="button button--sm button--secondary" for="mueksParamCurrAkb-@sensorId">Ток АКБ</label>

                        <input type="radio" class="btn-check mueks-param-radio" name="mueksParam" id="mueksParamWatt-@sensorId" value="wattHoursAkb" style="display: none;">
                        <label class="button button--sm button--secondary" for="mueksParamWatt-@sensorId">Вт*ч АКБ</label>

                        <input type="radio" class="btn-check mueks-param-radio" name="mueksParam" id="mueksParamVis-@sensorId" value="visibleRange" style="display: none;">
                        <label class="button button--sm button--secondary" for="mueksParamVis-@sensorId">Видимость м</label>

                        <input type="radio" class="btn-check mueks-param-radio" name="mueksParam" id="mueksParam220-@sensorId" value="sensor220b" style="display: none;">
                        <label class="button button--sm button--secondary" for="mueksParam220-@sensorId">Сеть 220В</label>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <!-- Один большой график MUEKS -->
    <div class="chart-main-wrapper" style="background: white; border: 1px solid #dee2e6; border-radius: 8px; padding: 20px; height: 500px; margin-top: 20px;">
        <canvas id="mueks-main-chart-@sensorId"></canvas>
    </div>

    <script src="~/js/chartComponents/mueks-charts.js"></script>
    <script>
        $(document).ready(function() {
            if (typeof initMUEKSCharts === 'function') {
                initMUEKSCharts(@sensorId);
            }
        });
    </script>
</div>