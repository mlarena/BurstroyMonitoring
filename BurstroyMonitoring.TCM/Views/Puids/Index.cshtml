@model IEnumerable<BurstroyMonitoring.Data.Models.Puid>

@{
    ViewData["Title"] = "PUID Устройства";
    var sortBy = ViewBag.SortBy as string ?? "Id";
    var sortDesc = ViewBag.SortDesc as bool? ?? true;
    
    string GetSortArrow(string col) => sortBy == col ? (sortDesc ? "▼" : "▲") : "";
    string GetSortUrl(string col) => Url.Action("Index", new { sortBy = col, sortDesc = sortBy == col ? !sortDesc : true });
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1 class="h3 mb-0">PUID Устройства</h1>
        <a asp-action="Create" class="btn btn-primary btn-sm">Добавить PUID</a>
    </div>

    @if (Model.Any()) {
        <div class="table-responsive shadow-sm rounded">
            <table class="table table-sm table-hover table-striped align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th><a href="@GetSortUrl("SerialNumber")" class="text-decoration-none text-dark">S/N @GetSortArrow("SerialNumber")</a></th>
                        <th><a href="@GetSortUrl("EndPointsName")" class="text-decoration-none text-dark">Название @GetSortArrow("EndPointsName")</a></th>
                        <th>Пост</th>
                        <th><a href="@GetSortUrl("Url")" class="text-decoration-none text-dark">URL API @GetSortArrow("Url")</a></th>
                        <th><a href="@GetSortUrl("Interval")" class="text-decoration-none text-dark">Интервал (сек) @GetSortArrow("Interval")</a></th>
                        <th>Статус</th>
                        <th><a href="@GetSortUrl("LastActivity")" class="text-decoration-none text-dark">Активность @GetSortArrow("LastActivity")</a></th>
                        <th class="text-end">Действия</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model) {
                        <tr>
                            <td class="fw-bold small">@item.SerialNumber</td>
                            <td class="text-truncate small" style="max-width: 200px;">@item.EndPointsName</td>
                            <td class="text-truncate small" style="max-width: 150px;">@(item.MonitoringPost?.Name ?? "—")</td>
                            <td class="text-truncate small" style="max-width: 150px;">@item.Url</td>
                            <td class="small">@item.IntervalSeconds</td>
                            <td class="small">
                                @if (item.IsActive) { <span class="text-success">Активен</span> }
                                else { <span class="text-danger">Неактивен</span> }
                            </td>
                            <td class="small">@(item.LastActivityUTC?.ToString("dd.MM.yyyy HH:mm") ?? "—")</td>
                            <td class="text-end">
                                <div class="btn-group btn-group-sm">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-secondary">✏️</a>
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-secondary">📄</a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger">🗑️</a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    } else {
        <div class="alert alert-info">Устройства PUID не найдены.</div>
    }
</div>
