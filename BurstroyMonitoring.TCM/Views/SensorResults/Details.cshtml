@model BurstroyMonitoring.Data.Models.VwSensorResultsFull

@{
    ViewData["Title"] = "Результат проверки датчика";
}

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-10 col-lg-8">
            <div class="card shadow-sm">
                <div class="card-header bg-info text-white py-2 d-flex justify-content-between align-items-center">
                    <h1 class="h5 mb-0">Результат проверки датчика</h1>
                    <span class="badge bg-light text-dark">ID: @Model.ResultId</span>
                </div>
                <div class="card-body p-0">
                    <table class="table table-sm mb-0">
                        <tbody>
                            <tr class="table-light"><th colspan="2" class="ps-3 py-2">Результат</th></tr>
                            <tr>
                                <th class="ps-3" style="width: 40%;">Время проверки</th>
                                <td class="ps-3">@(Model.CheckedAt?.ToString("dd.MM.yyyy HH:mm:ss") ?? "—")</td>
                            </tr>
                            <tr>
                                <th class="ps-3">Статус</th>
                                <td class="ps-3">
                                    @if (Model.IsSuccess == true) { <span class="badge bg-success fw-normal">Успешно</span> }
                                    else { <span class="badge bg-danger fw-normal">Ошибка</span> }
                                </td>
                            </tr>
                            <tr>
                                <th class="ps-3">HTTP Код / Время</th>
                                <td class="ps-3">
                                    <span class="badge bg-light text-dark border fw-normal">@Model.StatusCode</span>
                                    <span class="ms-2 small text-muted">@Model.ResponseTimeMs мс</span>
                                </td>
                            </tr>
                            <tr class="table-light"><th colspan="2" class="ps-3 py-2">Датчик</th></tr>
                            <tr>
                                <th class="ps-3">Серийный номер</th>
                                <td class="ps-3 fw-bold">@Model.SerialNumber</td>
                            </tr>
                            <tr>
                                <th class="ps-3">Конечная точка</th>
                                <td class="ps-3">@Model.EndpointName</td>
                            </tr>
                            <tr>
                                <th class="ps-3">Тип / Пост</th>
                                <td class="ps-3 small">
                                    <div>@Model.SensorTypeName</div>
                                    <div class="text-muted">@Model.PostName @(Model.PostIsMobile == true ? "(Моб.)" : "")</div>
                                </td>
                            </tr>
                            <tr>
                                <th class="ps-3">URL API</th>
                                <td class="ps-3 small text-break"><a href="@Model.SensorUrl" target="_blank">@Model.SensorUrl</a></td>
                            </tr>
                        </tbody>
                    </table>

                    @if (!string.IsNullOrEmpty(Model.ResponseBody))
                    {
                        <div class="p-3 border-top bg-light">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <label class="small fw-bold text-muted">Ответ (JSON):</label>
                                <button type="button" class="btn btn-outline-secondary btn-sm py-0 px-2" onclick="copyJson()" style="font-size: 0.7rem;">
                                    <i class="bi bi-clipboard"></i> Копировать
                                </button>
                            </div>
                            <pre id="jsonCode" class="bg-white p-2 border rounded small mb-0" style="max-height: 300px; overflow: auto; font-size: 0.75rem;"></pre>
                        </div>
                    }
                </div>
                <div class="card-footer bg-light py-2">
                    <a href="javascript:history.back()" class="btn btn-outline-secondary btn-sm">Назад</a>
                </div>
            </div>
        </div>
    </div>
</div>

@if (!string.IsNullOrEmpty(Model.ResponseBody))
{
    @section Scripts {
        <script>
            document.addEventListener('DOMContentLoaded', function() {
                try {
                    const raw = `@Html.Raw(Model.ResponseBody?.Replace("`", "\\`"))`;
                    const json = JSON.parse(raw);
                    document.getElementById('jsonCode').textContent = JSON.stringify(json, null, 2);
                } catch (e) {
                    document.getElementById('jsonCode').textContent = `@Html.Raw(Model.ResponseBody)`;
                }
            });

            function copyJson() {
                const text = document.getElementById('jsonCode').textContent;
                navigator.clipboard.writeText(text).then(() => {
                    alert('JSON скопирован');
                });
            }
        </script>
    }
}
