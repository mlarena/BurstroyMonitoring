@model IEnumerable<BurstroyMonitoring.Data.Models.VwSensorErrorsFull>

@{
    ViewData["Title"] = "Ошибки датчиков";
    var search = ViewBag.Search as string ?? "";
    var selectedSensorTypeIds = ViewBag.SelectedSensorTypeIds as List<int> ?? new List<int>();
    var selectedMonitoringPostIds = ViewBag.SelectedMonitoringPostIds as List<int> ?? new List<int>();
    
    bool IsSensorTypeActive(int id) => selectedSensorTypeIds.Contains(id);
    bool IsMonitoringPostActive(int id) => selectedMonitoringPostIds.Contains(id);
    
    var hasFilter = selectedSensorTypeIds.Any() || selectedMonitoringPostIds.Any() || !string.IsNullOrEmpty(search);
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1 class="h3 mb-0 text-danger">Ошибки датчиков</h1>
        <div class="form-check form-switch">
            <input class="form-check-input" type="checkbox" role="switch" id="autoRefresh">
            <label class="form-check-label small" for="autoRefresh">Автообновление</label>
        </div>
    </div>

    <div class="card mb-3 shadow-sm border-danger-subtle">
        <div class="card-body py-2">
            <form method="get" class="row g-2 align-items-end">
                <div class="col-md-3">
                    <label class="form-label small fw-bold mb-1">Поиск</label>
                    <input type="text" name="search" value="@search" class="form-control form-control-sm" placeholder="S/N, сообщение..." />
                </div>
                <div class="col-md-3">
                    <label class="form-label small fw-bold mb-1">Пост</label>
                    <select name="selectedMonitoringPosts" class="form-select form-select-sm" onchange="this.form.submit()">
                        <option value="">Все посты</option>
                        @if (ViewBag.MonitoringPosts != null) {
                            foreach (var post in ViewBag.MonitoringPosts) {
                                <option value="@post.PostId" selected="@(IsMonitoringPostActive(post.PostId) ? "selected" : null)">@post.Name</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label small fw-bold mb-1">Тип</label>
                    <select name="selectedSensorTypes" class="form-select form-select-sm" onchange="this.form.submit()">
                        <option value="">Все типы</option>
                        @if (ViewBag.SensorTypes != null) {
                            foreach (var type in ViewBag.SensorTypes) {
                                <option value="@type.SensorTypeId" selected="@(IsSensorTypeActive(type.SensorTypeId) ? "selected" : null)">@type.SensorTypeName</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-3 text-end">
                    <div class="btn-group btn-group-sm w-100">
                        <button type="submit" class="btn btn-danger">Найти</button>
                        @if (hasFilter) { <a href="@Url.Action("Index")" class="btn btn-outline-secondary">Сброс</a> }
                    </div>
                </div>
                <input type="hidden" name="pageSize" value="@ViewBag.PageSize" />
                <input type="hidden" name="sortBy" value="@ViewBag.SortBy" />
                <input type="hidden" name="sortDesc" value="@ViewBag.SortDesc.ToString()" />
            </form>
        </div>
    </div>

    <div class="mb-2">@await Html.PartialAsync("_Pagination")</div>

    <div class="table-responsive shadow-sm rounded">
        <table class="table table-sm table-hover table-striped align-middle mb-0">
            <thead class="table-danger">
                <tr>
                    <th>ID</th>
                    <th>Дата</th>
                    <th>S/N</th>
                    <th>Тип</th>
                    <th>Пост</th>
                    <th>Сообщение</th>
                    <th class="text-end">Детали</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model) {
                    <tr>
                        <td class="small text-muted">@item.ErrorId</td>
                        <td class="text-nowrap small">@(item.ErrorCreatedAt?.ToLocalTime().ToString("dd.MM.yyyy HH:mm") ?? "—")</td>
                        <td class="fw-bold small">@item.SerialNumber</td>
                        <td><span class="badge bg-light text-dark border fw-normal">@item.SensorTypeName</span></td>
                        <td class="text-truncate small" style="max-width: 120px;">@item.PostName</td>
                        <td class="small text-danger">
                            <div class="text-truncate" style="max-width: 300px;" title="@item.ErrorMessage">@item.ErrorMessage</div>
                        </td>
                        <td class="text-end">
                            <a asp-action="Details" asp-route-id="@item.ErrorId" class="btn btn-outline-danger btn-sm py-0 px-2">📄</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="mt-3">@await Html.PartialAsync("_Pagination")</div>
</div>

@section Scripts {
    <script src="~/js/autoRefresh.js"></script>
}
