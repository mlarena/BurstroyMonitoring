@model BurstroyMonitoring.Data.Models.VwSensorErrorsFull

@{
    ViewData["Title"] = "Подробности ошибки датчика";
}

<style>
    .json-key { color: #a52a2a; font-weight: bold; }
    .json-string { color: #008000; }
    .json-number { color: #0000ff; }
    .json-boolean { color: #b22222; }
    .json-null { color: #808080; }
    
    pre.code-block {
        background: #f8f9fa;
        border: 1px solid #dee2e6;
        border-radius: 0.5rem;
        padding: 1rem;
        font-family: 'Consolas', 'Monaco', 'Courier New', monospace;
        font-size: 0.85rem;
        line-height: 1.5;
        max-height: 500px;
        overflow: auto;
        white-space: pre-wrap;
        word-break: break-all;
    }

    .info-label {
        font-weight: 600;
        color: #6c757d;
        width: 30%;
    }
</style>

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-xl-10">
            <div class="d-flex align-items-center justify-content-between mb-4">
                <div>
                    <nav aria-label="breadcrumb">
                        <ol class="breadcrumb mb-1">
                            <li class="breadcrumb-item"><a asp-action="Index">Ошибки датчиков</a></li>
                            <li class="breadcrumb-item active">Детали</li>
                        </ol>
                    </nav>
                    <h2 class="h3 mb-0 text-gray-800">Ошибка #@Model.ErrorId</h2>
                </div>
                <a asp-action="Index" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left"></i> Назад к списку
                </a>
            </div>

            <div class="row g-4">
                <!-- Основная информация об ошибке -->
                <div class="col-md-7">
                    <div class="card shadow-sm border-0 h-100">
                        <div class="card-header bg-danger text-white py-3">
                            <h5 class="card-title mb-0"><i class="bi bi-exclamation-octagon me-2"></i>Информация об исключении</h5>
                        </div>
                        <div class="card-body">
                            <div class="mb-4">
                                <label class="small text-muted text-uppercase fw-bold">Сообщение</label>
                                <div class="p-3 bg-danger bg-opacity-10 border border-danger border-opacity-25 rounded text-danger fw-bold">
                                    @Model.ErrorMessage
                                </div>
                            </div>

                            <table class="table table-sm table-borderless">
                                <tbody>
                                    <tr>
                                        <td class="info-label">Дата и время</td>
                                        <td><i class="bi bi-clock me-1"></i> @(Model.ErrorCreatedAt?.ToString("dd.MM.yyyy HH:mm:ss") ?? "—")</td>
                                    </tr>
                                    <tr>
                                        <td class="info-label">Уровень</td>
                                        <td><span class="badge bg-danger">@Model.ErrorLevel</span></td>
                                    </tr>
                                    <tr>
                                        <td class="info-label">Тип исключения</td>
                                        <td class="text-break"><code>@Model.ExceptionType</code></td>
                                    </tr>
                                    <tr>
                                        <td class="info-label">Источник</td>
                                        <td class="small text-muted">@Model.ErrorSource</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <!-- Информация о датчике и посте -->
                <div class="col-md-5">
                    <div class="card shadow-sm border-0 h-100">
                        <div class="card-header bg-primary text-white py-3">
                            <h5 class="card-title mb-0"><i class="bi bi-cpu me-2"></i>Датчик и локация</h5>
                        </div>
                        <div class="card-body">
                            <div class="d-flex align-items-center mb-4">
                                <div class="bg-light rounded-circle p-3 me-3">
                                    <i class="bi bi-geo-alt text-primary fs-4"></i>
                                </div>
                                <div>
                                    <h6 class="mb-0 fw-bold">@Model.PostName</h6>
                                    <small class="text-muted">@(Model.PostIsMobile == true ? "Мобильный пост" : "Стационарный пост")</small>
                                </div>
                            </div>

                            <hr class="text-muted opacity-25">

                            <table class="table table-sm table-borderless">
                                <tbody>
                                    <tr>
                                        <td class="info-label">S/N</td>
                                        <td class="fw-bold">@Model.SerialNumber</td>
                                    </tr>
                                    <tr>
                                        <td class="info-label">Тип датчика</td>
                                        <td>@Model.SensorTypeName</td>
                                    </tr>
                                    <tr>
                                        <td class="info-label">Endpoint</td>
                                        <td class="small">@Model.EndpointName</td>
                                    </tr>
                                    <tr>
                                        <td class="info-label">Статус</td>
                                        <td>
                                            @if (Model.SensorIsActive == true) {
                                                <span class="badge bg-success-subtle text-success border border-success border-opacity-25">Активен</span>
                                            } else {
                                                <span class="badge bg-secondary-subtle text-secondary border border-secondary border-opacity-25">Неактивен</span>
                                            }
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <!-- Дополнительные данные (JSON) -->
                @if (!string.IsNullOrEmpty(Model.AdditionalData))
                {
                    <div class="col-12">
                        <div class="card shadow-sm border-0">
                            <div class="card-header bg-light d-flex justify-content-between align-items-center py-3">
                                <h5 class="card-title mb-0 text-dark"><i class="bi bi-braces me-2"></i>Дополнительные данные (JSON)</h5>
                                <button class="btn btn-sm btn-outline-primary" onclick="copyToClipboard('jsonCode', this)">
                                    <i class="bi bi-clipboard"></i> Копировать
                                </button>
                            </div>
                            <div class="card-body">
                                <pre id="jsonCode" class="code-block mb-0"></pre>
                            </div>
                        </div>
                    </div>
                }

                <!-- Трассировка стека -->
                @if (!string.IsNullOrEmpty(Model.StackTrace))
                {
                    <div class="col-12">
                        <div class="card shadow-sm border-0">
                            <div class="card-header bg-light d-flex justify-content-between align-items-center py-3">
                                <h5 class="card-title mb-0 text-dark"><i class="bi bi-list-nested me-2"></i>Трассировка стека</h5>
                                <button class="btn btn-sm btn-outline-primary" onclick="copyToClipboard('stackTraceCode', this)">
                                    <i class="bi bi-clipboard"></i> Копировать
                                </button>
                            </div>
                            <div class="card-body">
                                <pre id="stackTraceCode" class="code-block mb-0">@Model.StackTrace</pre>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Обработка JSON
            const rawJson = @Html.Raw(Json.Serialize(Model.AdditionalData));
            if (rawJson) {
                const jsonElement = document.getElementById('jsonCode');
                try {
                    let parsed;
                    // Если это строка, которая выглядит как JSON, пробуем распарсить еще раз
                    if (typeof rawJson === 'string') {
                        parsed = JSON.parse(rawJson);
                    } else {
                        parsed = rawJson;
                    }
                    jsonElement.innerHTML = syntaxHighlight(JSON.stringify(parsed, null, 4));
                } catch (e) {
                    jsonElement.textContent = rawJson;
                }
            }
        });

        function syntaxHighlight(json) {
            if (!json) return '';
            json = json.replace(/&/g, '&').replace(/</g, '<').replace(/>/g, '>');
            return json.replace(/("([^\\"]|\\\\")*":?|true|false|null|-?\d+(\.\d+)?([eE][+-]?\d+)?)/g, function(match) {
                let cls = 'json-number';
                if (/^"/.test(match)) {
                    if (match.endsWith(':')) cls = 'json-key';
                    else cls = 'json-string';
                } else if (/true|false/.test(match)) cls = 'json-boolean';
                else if (/null/.test(match)) cls = 'json-null';
                return '<span class="' + cls + '">' + match + '</span>';
            });
        }

        function copyToClipboard(elementId, btn) {
            const text = document.getElementById(elementId).textContent;
            navigator.clipboard.writeText(text).then(() => {
                const originalHtml = btn.innerHTML;
                btn.innerHTML = '<i class="bi bi-check2"></i> Скопировано!';
                btn.classList.replace('btn-outline-primary', 'btn-success');
                setTimeout(() => {
                    btn.innerHTML = originalHtml;
                    btn.classList.replace('btn-success', 'btn-outline-primary');
                }, 2000);
            });
        }
    </script>
}
