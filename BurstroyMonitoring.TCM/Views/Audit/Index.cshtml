@model BurstroyMonitoring.Data.Models.ViewModels.AuditIndexViewModel
@using BurstroyMonitoring.Data.Models.ViewModels

@{
    ViewData["Title"] = "Аудит (действия + изменения)";
}

<div class="main-content">
    <div class="view-container">
        <div class="table-header">
            <div>
                <h1 class="view-title" style="margin-bottom: 0;">Аудит</h1>
                <div class="text-muted">Единый журнал действий пользователей и изменений данных</div>
            </div>
            <div class="d-flex gap-2">
                <button type="button" class="button button--secondary" id="toggleColumnsBtn">
                    Показать все столбцы
                </button>
                <a class="button button--secondary" href="@Url.Action("Index")">Сбросить</a>
            </div>
        </div>

        <!-- Filters -->
        <div class="filter-container">
            <form method="get" class="filter-form">
                <div class="form-row" style="display: flex; flex-wrap: wrap; gap: 10px; align-items: flex-end;">
                    <div class="field-group" style="flex: 0 1 100px;">
                        <label class="control-label">Тип</label>
                        <select class="input select" name="type">
                            <option value="">Все</option>
                            <option value="@AuditLogType.Action" selected="@(Model.Type == AuditLogType.Action)">Действия</option>
                            <option value="@AuditLogType.Change" selected="@(Model.Type == AuditLogType.Change)">Изменения</option>
                        </select>
                    </div>

                    <div class="field-group" style="flex: 0 1 150px;">
                        <label class="control-label">Пользователь</label>
                        <select class="input select" name="userName">
                            <option value="">Все</option>
                            @foreach (var u in Model.UserNames)
                            {
                                <option value="@u" selected="@(Model.UserName == u)">@u</option>
                            }
                        </select>
                    </div>

                    <div class="field-group" style="flex: 0 1 150px;">
                        <label class="control-label">IP адрес</label>
                        <select class="input select" name="ipAddress">
                            <option value="">Все</option>
                            @foreach (var ip in Model.IpAddresses)
                            {
                                <option value="@ip" selected="@(Model.IpAddress == ip)">@ip</option>
                            }
                        </select>
                    </div>

                    <div class="field-group" style="flex: 1 1 180px;">
                        <label class="control-label">Сущность</label>
                        <select class="input select" name="entityType">
                            <option value="">Все</option>
                            @foreach (var t in Model.EntityTypes)
                            {
                                <option value="@t" selected="@(Model.EntityType == t)">@t</option>
                            }
                        </select>
                    </div>

                    <div class="field-group" style="flex: 1 1 180px;">
                        <label class="control-label">Тип изменения</label>
                        <select class="input select" name="changeType">
                            <option value="">Все</option>
                            @foreach (var t in Model.ChangeTypes)
                            {
                                <option value="@t" selected="@(Model.ChangeType == t)">@t</option>
                            }
                        </select>
                    </div>

                    <div class="field-group" style="flex: 0 1 180px;">
                        <label class="control-label">С даты</label>
                        <input type="datetime-local" name="from" class="input" value="@(Model.From?.ToString("yyyy-MM-ddTHH:mm"))" />
                    </div>

                    <div class="field-group" style="flex: 0 1 180px;">
                        <label class="control-label">По дату</label>
                        <input type="datetime-local" name="to" class="input" value="@(Model.To?.ToString("yyyy-MM-ddTHH:mm"))" />
                    </div>

                    <div class="field-group">
                        <button type="submit" class="button button--primary">Применить</button>
                    </div>
                </div>
            </form>
        </div>

        <!-- Paging header -->
        <div class="pagination-container">
            <div class="records-count">
                <strong>Страница @Model.Page из @Model.TotalPages</strong>
                <span class="text-muted">(всего: @Model.TotalItems)</span>
            </div>
            <div class="pagination">
                @if (Model.Page > 1)
                {
                    <a class="pagination-btn" href="@Url.Action("Index", new {
                        page = Model.Page - 1,
                        type = Model.Type,
                        userName = Model.UserName,
                        ipAddress = Model.IpAddress,
                        entityType = Model.EntityType,
                        changeType = Model.ChangeType,
                        from = Model.From,
                        to = Model.To
                    })">Предыдущая</a>
                }
                @if (Model.Page < Model.TotalPages)
                {
                    <a class="pagination-btn" href="@Url.Action("Index", new {
                        page = Model.Page + 1,
                        type = Model.Type,
                        userName = Model.UserName,
                        ipAddress = Model.IpAddress,
                        entityType = Model.EntityType,
                        changeType = Model.ChangeType,
                        from = Model.From,
                        to = Model.To
                    })">Следующая</a>
                }
            </div>
        </div>

        <!-- Table -->
        <div class="table-responsive">
            <table class="table">
                <thead>
                    <tr>
                        <th>Время</th>
                        <th>Тип</th>
                        <th>Пользователь</th>
                        <th>Сводка</th>
                        <th class="col-extra d-none">Метод</th>
                        <th class="col-extra d-none">URL</th>
                        <th class="col-extra d-none">IP</th>
                        <th class="col-extra d-none">Статус</th>
                        <th class="col-extra d-none">Время (мс)</th>
                        <th class="col-extra d-none">Сущность</th>
                        <th class="col-extra d-none">EntityId</th>
                        <th class="col-extra d-none">ChangeType</th>
                        <th>Действия</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in Model.Items)
                    {
                        <tr>
                            <td>@row.TimestampUtc.ToLocalTime().ToString("dd.MM.yyyy HH:mm:ss")</td>
                            <td>
                                @if (row.Type == AuditLogType.Action)
                                {
                                    <span class="lozenge lozenge--warning">Действие</span>
                                }
                                else
                                {
                                    <span class="lozenge" style="background-color: var(--warning-bg); color: var(--warning-color);">Изменение</span>
                                }
                            </td>
                            <td>
                                <span class="font-weight-bold">@(row.UserName ?? "System")</span>
                                @if (row.UserId.HasValue)
                                {
                                    <div class="text-muted" style="font-size: 11px;">ID: @row.UserId</div>
                                }
                            </td>
                            <td>
                                @if (row.Type == AuditLogType.Action)
                                {
                                    <div class="font-weight-bold">@row.ActionName</div>
                                    @if (!string.IsNullOrEmpty(row.Details) && row.Details != "No parameters")
                                    {
                                        <div class="text-muted" style="font-size: 12px;">@row.Details</div>
                                    }
                                }
                                else
                                {
                                    <div class="font-weight-bold">@row.EntityType</div>
                                    <div class="text-muted" style="font-size: 12px;">@row.ChangeType @(row.EntityId?.ToString() ?? "—")</div>
                                }
                            </td>

                            <td class="col-extra d-none">
                                @if (row.Type == AuditLogType.Action)
                                {
                                    <span class="lozenge" style="background-color: @(row.HttpMethod == "GET" ? "var(--primary-color)" :
                                                                        row.HttpMethod == "POST" ? "var(--success-color)" :
                                                                        row.HttpMethod == "PUT" ? "var(--warning-color)" :
                                                                        row.HttpMethod == "DELETE" ? "var(--danger-color)" : "var(--text-muted)"); color: white;">
                                        @row.HttpMethod
                                    </span>
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>
                            <td class="col-extra d-none">
                                @if (row.Type == AuditLogType.Action)
                                {
                                    <small class="text-break">@row.Url</small>
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>
                            <td class="col-extra d-none">
                                @if (row.Type == AuditLogType.Action)
                                {
                                    <small>@(row.IpAddress ?? "—")</small>
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>
                            <td class="col-extra d-none">
                                @if (row.Type == AuditLogType.Action)
                                {
                                    @if (row.IsSuccess == true)
                                    {
                                        <span class="lozenge lozenge--success">OK</span>
                                    }
                                    else
                                    {
                                        <span class="lozenge lozenge--error">ERR</span>
                                    }
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>
                            <td class="col-extra d-none text-right">
                                @if (row.Type == AuditLogType.Action)
                                {
                                    @row.ExecutionTimeMs
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>
                            <td class="col-extra d-none">@((row.Type == AuditLogType.Change) ? row.EntityType : "—")</td>
                            <td class="col-extra d-none">@((row.Type == AuditLogType.Change) ? (row.EntityId?.ToString() ?? "—") : "—")</td>
                            <td class="col-extra d-none">@((row.Type == AuditLogType.Change) ? row.ChangeType : "—")</td>
                            <td>
                                <a class="button button--sm button--secondary"
                                   asp-action="Details"
                                   asp-route-type="@row.Type"
                                   asp-route-id="@row.Id">
                                    Детали
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (!Model.Items.Any())
        {
            <div class="empty-state">
                <div class="empty-state-icon">📋</div>
                <h3>Записи не найдены</h3>
                <p>Попробуйте изменить параметры фильтрации.</p>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            var showingAll = false;
            var btn = document.getElementById('toggleColumnsBtn');
            var extras = document.querySelectorAll('.col-extra');

            function setState(show) {
                showingAll = show;
                extras.forEach(function (el) {
                    el.classList.toggle('d-none', !showingAll);
                });
                if (btn) btn.textContent = showingAll ? 'Скрыть дополнительные столбцы' : 'Показать все столбцы';
            }

            if (btn) {
                btn.addEventListener('click', function () {
                    setState(!showingAll);
                });
            }

            setState(false);
        })();
    </script>
}