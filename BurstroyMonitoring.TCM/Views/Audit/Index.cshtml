@model BurstroyMonitoring.Data.Models.ViewModels.AuditIndexViewModel
@using BurstroyMonitoring.Data.Models.ViewModels

@{
    ViewData["Title"] = "Аудит";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h1 class="h3 mb-0">Аудит</h1>
            <div class="small text-muted">Журнал действий пользователей и изменений данных</div>
        </div>
        <div class="btn-group btn-group-sm shadow-sm">
            <button type="button" class="btn btn-outline-secondary" id="toggleColumnsBtn">Все столбцы</button>
            <a class="btn btn-outline-secondary" href="@Url.Action("Index")">Сбросить</a>
        </div>
    </div>

    <div class="card mb-3 shadow-sm">
        <div class="card-body py-2">
            <form method="get" class="row g-2 align-items-end">
                <div class="col-md-1">
                    <label class="form-label small fw-bold mb-1">Тип</label>
                    <select class="form-select form-select-sm" name="type">
                        <option value="">Все</option>
                        <option value="@AuditLogType.Action" selected="@(Model.Type == AuditLogType.Action)">Действия</option>
                        <option value="@AuditLogType.Change" selected="@(Model.Type == AuditLogType.Change)">Изменения</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small fw-bold mb-1">Пользователь</label>
                    <select class="form-select form-select-sm" name="userName">
                        <option value="">Все</option>
                        @foreach (var u in Model.UserNames) { <option value="@u" selected="@(Model.UserName == u)">@u</option> }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small fw-bold mb-1">Сущность</label>
                    <select class="form-select form-select-sm" name="entityType">
                        <option value="">Все</option>
                        @foreach (var t in Model.EntityTypes) { <option value="@t" selected="@(Model.EntityType == t)">@t</option> }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small fw-bold mb-1">С даты</label>
                    <input type="datetime-local" name="from" class="form-control form-control-sm" value="@(Model.From?.ToString("yyyy-MM-ddTHH:mm"))" />
                </div>
                <div class="col-md-2">
                    <label class="form-label small fw-bold mb-1">По дату</label>
                    <input type="datetime-local" name="to" class="form-control form-control-sm" value="@(Model.To?.ToString("yyyy-MM-ddTHH:mm"))" />
                </div>
                <div class="col-md-3 text-end">
                    <button type="submit" class="btn btn-primary btn-sm w-100">Применить</button>
                </div>
            </form>
        </div>
    </div>

    <div class="d-flex justify-content-between align-items-center mb-2">
        <div class="small text-muted">Страница <strong>@Model.Page</strong> из @Model.TotalPages (@Model.TotalItems записей)</div>
        <ul class="pagination pagination-sm mb-0">
            <li class="page-item @(Model.Page <= 1 ? "disabled" : "")">
                <a class="page-link" href="@Url.Action("Index", new { page = Model.Page - 1, type = Model.Type, userName = Model.UserName, entityType = Model.EntityType, from = Model.From, to = Model.To })">«</a>
            </li>
            <li class="page-item @(Model.Page >= Model.TotalPages ? "disabled" : "")">
                <a class="page-link" href="@Url.Action("Index", new { page = Model.Page + 1, type = Model.Type, userName = Model.UserName, entityType = Model.EntityType, from = Model.From, to = Model.To })">»</a>
            </li>
        </ul>
    </div>

    <div class="table-responsive shadow-sm rounded">
        <table class="table table-sm table-hover table-striped align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>Время</th>
                    <th>Тип</th>
                    <th>Пользователь</th>
                    <th>Сводка</th>
                    <th class="col-extra d-none">Метод</th>
                    <th class="col-extra d-none">IP</th>
                    <th class="col-extra d-none">Статус</th>
                    <th class="col-extra d-none">Сущность</th>
                    <th class="col-extra d-none">ID</th>
                    <th class="text-end">Действия</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var row in Model.Items)
                {
                    <tr>
                        <td class="text-nowrap small">@row.TimestampUtc.ToLocalTime().ToString("dd.MM.yyyy HH:mm:ss")</td>
                        <td>
                            <span class="badge @(row.Type == AuditLogType.Action ? "bg-info" : "bg-warning") text-dark fw-normal">
                                @(row.Type == AuditLogType.Action ? "Действие" : "Изменение")
                            </span>
                        </td>
                        <td><div class="fw-bold small">@(row.UserName ?? "System")</div></td>
                        <td class="small">
                            @if (row.Type == AuditLogType.Action) { <strong>@row.ActionName</strong> }
                            else { <strong>@row.EntityType</strong> <span class="text-muted">(@row.ChangeType)</span> }
                        </td>
                        <td class="col-extra d-none small">@row.HttpMethod</td>
                        <td class="col-extra d-none small">@row.IpAddress</td>
                        <td class="col-extra d-none small">@(row.IsSuccess == true ? "✓" : "✗")</td>
                        <td class="col-extra d-none small">@row.EntityType</td>
                        <td class="col-extra d-none small">@row.EntityId</td>
                        <td class="text-end">
                            <a asp-action="Details" asp-route-id="@row.Id" class="btn btn-outline-secondary btn-sm py-0 px-2">📄</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('toggleColumnsBtn').addEventListener('click', function() {
            const extras = document.querySelectorAll('.col-extra');
            const isHidden = extras[0].classList.contains('d-none');
            extras.forEach(el => el.classList.toggle('d-none'));
            this.textContent = isHidden ? 'Скрыть столбцы' : 'Все столбцы';
        });
    </script>
}
