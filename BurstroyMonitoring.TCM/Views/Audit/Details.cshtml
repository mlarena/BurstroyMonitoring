@model BurstroyMonitoring.Data.Models.ViewModels.AuditDetailsViewModel
@using BurstroyMonitoring.Data.Models.ViewModels
@using System.Text.Json

@{
    ViewData["Title"] = "Детали аудита";
}

<div class="container">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1 class="h3 mb-0">Детали аудита</h1>
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Назад к списку</a>
    </div>

    @if (Model.Log != null)
    {
        var log = Model.Log;
        <div class="card shadow-sm mb-4">
            <div class="card-header @(Model.Type == AuditLogType.Action ? "bg-info" : "bg-warning") text-white py-2">
                <span class="badge bg-dark me-2">@(Model.Type == AuditLogType.Action ? "Действие" : "Изменение")</span>
                <strong>@(Model.Type == AuditLogType.Action ? log.Action : log.EntityType)</strong>
            </div>
            <div class="card-body p-0">
                <table class="table table-sm mb-0">
                    <tbody>
                        <tr><th class="bg-light ps-3" style="width: 30%;">ID записи</th><td class="ps-3">@log.Id</td></tr>
                        <tr><th class="bg-light ps-3">Время</th><td class="ps-3">@log.Timestamp.ToLocalTime().ToString("dd.MM.yyyy HH:mm:ss.fff")</td></tr>
                        <tr><th class="bg-light ps-3">Пользователь</th><td class="ps-3">@(log.UserName ?? "System") @(log.UserId.HasValue ? $"(ID: {log.UserId})" : "")</td></tr>
                        
                        @if (Model.Type == AuditLogType.Action)
                        {
                            <tr><th class="bg-light ps-3">HTTP Метод / URL</th><td class="ps-3"><span class="badge bg-primary me-2">@log.HttpMethod</span> <small class="text-break">@log.Url</small></td></tr>
                            <tr><th class="bg-light ps-3">IP / User Agent</th><td class="ps-3 small"><div>@log.IpAddress</div><div class="text-muted">@log.UserAgent</div></td></tr>
                            <tr><th class="bg-light ps-3">Статус / Время</th><td class="ps-3">
                                @if (log.IsSuccess == true) { <span class="badge bg-success fw-normal">OK</span> }
                                else { <span class="badge bg-danger fw-normal">Ошибка</span> }
                                <span class="ms-2 small text-muted">@log.ExecutionTimeMs мс</span>
                            </td></tr>
                            @if (log.TargetId.HasValue)
                            {
                                <tr><th class="bg-light ps-3">Target ID</th><td class="ps-3">@log.TargetId</td></tr>
                            }
                            <tr><th class="bg-light ps-3">Детали</th><td class="ps-3"><pre class="bg-light p-2 rounded small mb-0" style="white-space: pre-wrap;">@log.Details</pre></td></tr>
                        }
                        else
                        {
                            <tr><th class="bg-light ps-3">Сущность / ID</th><td class="ps-3">@log.EntityType <span class="badge bg-light text-dark border ms-2">@log.EntityId</span></td></tr>
                            <tr><th class="bg-light ps-3">Тип изменения</th><td class="ps-3"><span class="badge bg-info text-dark fw-normal">@log.ChangeType</span></td></tr>
                            @if (!string.IsNullOrEmpty(log.IpAddress))
                            {
                                <tr><th class="bg-light ps-3">IP адрес</th><td class="ps-3 small">@log.IpAddress</td></tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>

        @if (Model.Type == AuditLogType.Change)
        {
            @if (log.ChangeType == "Added" && !string.IsNullOrEmpty(log.NewValues))
            {
                <div class="card shadow-sm mb-4 border-success">
                    <div class="card-header bg-success text-white py-1 small fw-bold">Новые данные</div>
                    <div class="card-body p-0">
                        <table class="table table-sm mb-0">
                            <tbody>
                                @{ var addedData = JsonSerializer.Deserialize<Dictionary<string, object>>(log.NewValues); }
                                @if (addedData != null) {
                                    @foreach (var item in addedData) {
                                        <tr><th class="bg-light ps-3" style="width: 30%;">@item.Key</th><td class="ps-3 small">@item.Value?.ToString()</td></tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }

            @if (log.ChangeType == "Modified" && !string.IsNullOrEmpty(log.ChangedProperties))
            {
                <div class="card shadow-sm mb-4 border-warning">
                    <div class="card-header bg-warning text-dark py-1 small fw-bold">Изменённые поля</div>
                    <div class="card-body p-0">
                        <table class="table table-sm mb-0">
                            <thead class="table-light">
                                <tr><th class="ps-3">Поле</th><th class="ps-3">Старое → Новое</th></tr>
                            </thead>
                            <tbody>
                                @{ var changes = JsonSerializer.Deserialize<List<JsonElement>>(log.ChangedProperties); }
                                @if (changes != null) {
                                    @foreach (var change in changes) {
                                        <tr>
                                            <th class="ps-3">@change.GetProperty("Property").GetString()</th>
                                            <td class="ps-3 small">
                                                <span class="text-danger text-decoration-line-through">@(change.GetProperty("OldValue").ValueKind == JsonValueKind.Null ? "null" : change.GetProperty("OldValue").ToString())</span>
                                                <span class="mx-2">&rarr;</span>
                                                <span class="text-success fw-bold">@(change.GetProperty("NewValue").ValueKind == JsonValueKind.Null ? "null" : change.GetProperty("NewValue").ToString())</span>
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }
        }
    }
</div>
