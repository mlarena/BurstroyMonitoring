@model BurstroyMonitoring.Data.Models.ViewModels.AuditDetailsViewModel
@using BurstroyMonitoring.Data.Models.ViewModels
@using System.Text.Json

@{
    ViewData["Title"] = "Детали аудита";
}

<div class="main-content">
    <div class="view-container">
        <div class="table-header">
            <h1 class="view-title" style="margin-bottom: 0;">Детали аудита</h1>
            <a asp-action="Index" class="button button--secondary">Назад к списку</a>
        </div>

        @if (Model.Type == AuditLogType.Action && Model.Log != null)
        {
            var log = Model.Log;
            <div class="details-section">
                <div class="details-section-title">
                    <span class="lozenge lozenge--warning" style="margin-right: 8px;">Действие</span>
                    <strong>@log.Action</strong>
                </div>

                <div class="details-table">
                    <div class="details-row">
                        <div class="details-label">ID записи</div>
                        <div class="details-value">@log.Id</div>
                    </div>

                    <div class="details-row">
                        <div class="details-label">Время</div>
                        <div class="details-value">@log.Timestamp.ToLocalTime().ToString("dd.MM.yyyy HH:mm:ss.fff")</div>
                    </div>

                    <div class="details-row">
                        <div class="details-label">Пользователь</div>
                        <div class="details-value">@log.UserName (ID: @(log.UserId?.ToString() ?? "—"))</div>
                    </div>

                    <div class="details-row">
                        <div class="details-label">HTTP метод</div>
                        <div class="details-value">@log.HttpMethod</div>
                    </div>

                    <div class="details-row">
                        <div class="details-label">URL</div>
                        <div class="details-value">@log.Url</div>
                    </div>

                    <div class="details-row">
                        <div class="details-label">IP адрес</div>
                        <div class="details-value">@log.IpAddress</div>
                    </div>

                    <div class="details-row">
                        <div class="details-label">User Agent</div>
                        <div class="details-value"><small>@log.UserAgent</small></div>
                    </div>

                    <div class="details-row">
                        <div class="details-label">Успешно</div>
                        <div class="details-value">
                            @if (log.IsSuccess == true)
                            {
                                <span class="lozenge lozenge--success">OK</span>
                            }
                            else
                            {
                                <span class="lozenge lozenge--error">Ошибка</span>
                            }
                        </div>
                    </div>

                    <div class="details-row">
                        <div class="details-label">Время выполнения</div>
                        <div class="details-value">@log.ExecutionTimeMs мс</div>
                    </div>

                    @if (log.TargetId.HasValue)
                    {
                        <div class="details-row">
                            <div class="details-label">TargetId</div>
                            <div class="details-value">@log.TargetId</div>
                        </div>
                    }

                    <div class="details-row">
                        <div class="details-label">Details</div>
                        <div class="details-value">
                            <pre style="margin: 0; background: var(--bg-primary); padding: 10px; border-radius: var(--radius-medium);">@log.Details</pre>
                        </div>
                    </div>
                </div>
            </div>
        }
        else if (Model.Type == AuditLogType.Change && Model.Log != null)
        {
            var log = Model.Log;
            <div class="details-section">
                <div class="details-section-title">
                    <span class="lozenge lozenge--warning" style="background-color: var(--warning-bg); color: var(--warning-color); margin-right: 8px;">Изменение</span>
                    <strong>@log.EntityType</strong>
                </div>

                <div class="details-table">
                    <div class="details-row">
                        <div class="details-label">ID записи</div>
                        <div class="details-value">@log.Id</div>
                    </div>

                    <div class="details-row">
                        <div class="details-label">Время</div>
                        <div class="details-value">@log.Timestamp.ToLocalTime().ToString("dd.MM.yyyy HH:mm:ss.fff")</div>
                    </div>

                    <div class="details-row">
                        <div class="details-label">Пользователь</div>
                        <div class="details-value">
                            @(log.UserName ?? "System")
                            @if (log.UserId.HasValue)
                            {
                                <span class="text-muted">(ID: @log.UserId)</span>
                            }
                        </div>
                    </div>

                    <div class="details-row">
                        <div class="details-label">Сущность</div>
                        <div class="details-value">@log.EntityType</div>
                    </div>

                    <div class="details-row">
                        <div class="details-label">EntityId</div>
                        <div class="details-value">@(log.EntityId?.ToString() ?? "—")</div>
                    </div>

                    <div class="details-row">
                        <div class="details-label">Тип изменения</div>
                        <div class="details-value">@log.ChangeType</div>
                    </div>
                </div>
            </div>

            @if (log.ChangeType == "Added" && !string.IsNullOrEmpty(log.NewValues))
            {
                <div class="details-section">
                    <h3 class="details-section-title" style="color: var(--success-color);">Новые данные</h3>
                    <div class="details-table">
                        @{
                            var newData = JsonSerializer.Deserialize<Dictionary<string, object>>(log.NewValues);
                        }
                        @if (newData != null)
                        {
                            @foreach (var item in newData)
                            {
                                <div class="details-row">
                                    <div class="details-label"><strong>@item.Key</strong></div>
                                    <div class="details-value">@item.Value?.ToString()</div>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="details-row">
                                <div class="details-value">
                                    <pre style="margin: 0; background: var(--bg-primary); padding: 10px;">@log.NewValues</pre>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }

            @if (log.ChangeType == "Deleted" && !string.IsNullOrEmpty(log.OriginalValues))
            {
                <div class="details-section">
                    <h3 class="details-section-title" style="color: var(--danger-color);">Удалённые данные</h3>
                    <div class="details-table">
                        @{
                            var originalData = JsonSerializer.Deserialize<Dictionary<string, object>>(log.OriginalValues);
                        }
                        @if (originalData != null)
                        {
                            @foreach (var item in originalData)
                            {
                                <div class="details-row">
                                    <div class="details-label"><strong>@item.Key</strong></div>
                                    <div class="details-value">@item.Value?.ToString()</div>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="details-row">
                                <div class="details-value">
                                    <pre style="margin: 0; background: var(--bg-primary); padding: 10px;">@log.OriginalValues</pre>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }

            @if (log.ChangeType == "Modified")
            {
                @if (!string.IsNullOrEmpty(log.ChangedProperties))
                {
                    <div class="details-section">
                        <h3 class="details-section-title" style="color: var(--warning-color);">Изменённые поля</h3>
                        <div class="details-table">
                            @{
                                var changes = JsonSerializer.Deserialize<List<JsonElement>>(log.ChangedProperties);
                            }
                            @if (changes != null && changes.Any())
                            {
                                <div class="details-row details-row--header">
                                    <div class="details-label">Поле</div>
                                    <div class="details-value">Старое → Новое</div>
                                </div>
                                @foreach (var change in changes)
                                {
                                    <div class="details-row">
                                        <div class="details-label"><strong>@change.GetProperty("Property").GetString()</strong></div>
                                        <div class="details-value">
                                            <span class="text-danger">@change.GetProperty("OldValue").GetString()</span> 
                                            → 
                                            <span class="text-success">@change.GetProperty("NewValue").GetString()</span>
                                        </div>
                                    </div>
                                }
                            }
                        </div>
                    </div>
                }

                <div class="details-section">
                    <div style="display: flex; gap: var(--spacing-lg);">
                        <div style="flex: 1;">
                            <h3 class="details-section-title" style="color: var(--text-secondary);">До</h3>
                            <div class="details-table">
                                @{
                                    var originalData = JsonSerializer.Deserialize<Dictionary<string, object>>(log.OriginalValues ?? "{}");
                                }
                                @if (originalData != null && originalData.Any())
                                {
                                    @foreach (var item in originalData)
                                    {
                                        <div class="details-row">
                                            <div class="details-label"><strong>@item.Key</strong></div>
                                            <div class="details-value">@item.Value?.ToString()</div>
                                        </div>
                                    }
                                }
                                else
                                {
                                    <div class="details-row">
                                        <div class="details-value text-muted">Нет данных</div>
                                    </div>
                                }
                            </div>
                        </div>
                        <div style="flex: 1;">
                            <h3 class="details-section-title" style="color: var(--primary-color);">После</h3>
                            <div class="details-table">
                                @{
                                    var newData = JsonSerializer.Deserialize<Dictionary<string, object>>(log.NewValues ?? "{}");
                                }
                                @if (newData != null && newData.Any())
                                {
                                    @foreach (var item in newData)
                                    {
                                        <div class="details-row">
                                            <div class="details-label"><strong>@item.Key</strong></div>
                                            <div class="details-value">@item.Value?.ToString()</div>
                                        </div>
                                    }
                                }
                                else
                                {
                                    <div class="details-row">
                                        <div class="details-value text-muted">Нет данных</div>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="alert-warning" style="padding: var(--spacing-lg);">
                <strong>⚠️ Запись не найдена</strong>
            </div>
        }
    </div>
</div>