@model IEnumerable<BurstroyMonitoring.Data.Models.User>

@{
    ViewData["Title"] = "Управление пользователями";
}

<div class="main-content">
    <div class="view-container">
        <div class="table-header">
            <h1 class="view-title" style="margin-bottom: 0;">Управление пользователями</h1>
            <a asp-action="Create" class="button button--success">
                <span class="button-icon">👤</span> Создать пользователя
            </a>
        </div>

        <div class="table-responsive">
            <table class="table">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Имя пользователя</th>
                        <th>Роль</th>
                        <th>Дата создания</th>
                        <th>Действия</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        <tr>
                            <td>@user.Id</td>
                            <td>@user.UserName</td>
                            <td>
                                @if (user.Role == "Admin")
                                {
                                    <span class="lozenge lozenge--error">Admin</span>
                                }
                                else
                                {
                                    <span class="lozenge lozenge--success">User</span>
                                }
                            </td>
                            <td>@user.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                            <td>
                                <div class="action-buttons">
                                    <a asp-action="Edit" asp-route-id="@user.Id" class="button button--sm button--secondary" title="Редактировать">
                                        ✏️
                                    </a>
                                    <form asp-action="Delete" asp-route-id="@user.Id" method="post" style="display: inline;" 
                                          onsubmit="return confirm('Вы уверены, что хотите удалить пользователя @user.UserName?');">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="button button--sm button--danger" title="Удалить">
                                            🗑️
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (!Model.Any())
        {
            <div class="empty-state">
                <div class="empty-state-icon">👥</div>
                <h3>Пользователи не найдены</h3>
                <p>Нажмите "Создать пользователя", чтобы добавить первого пользователя.</p>
            </div>
        }
    </div>
</div>