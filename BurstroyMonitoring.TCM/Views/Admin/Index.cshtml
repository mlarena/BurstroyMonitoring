@model IEnumerable<BurstroyMonitoring.Data.Models.User>

@{
    ViewData["Title"] = "Управление пользователями";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1 class="h3 mb-0">Управление пользователями</h1>
        <a asp-action="Create" class="btn btn-success btn-sm">
            👤 Создать пользователя
        </a>
    </div>

    <div class="table-responsive shadow-sm rounded">
        <table class="table table-sm table-hover table-striped align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th style="width: 50px;">ID</th>
                    <th>Имя пользователя</th>
                    <th>Роль</th>
                    <th>Дата создания</th>
                    <th class="text-end">Действия</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model)
                {
                    <tr>
                        <td class="small text-muted">@user.Id</td>
                        <td class="fw-bold">@user.UserName</td>
                        <td>
                            @if (user.Role == "Admin")
                            {
                                <span class="badge bg-danger fw-normal">Admin</span>
                            }
                            else
                            {
                                <span class="badge bg-success fw-normal">User</span>
                            }
                        </td>
                        <td class="small text-nowrap">@user.CreatedAt.ToString("dd.MM.yyyy HH:mm")</td>
                        <td class="text-end">
                            <div class="btn-group btn-group-sm">
                                <a asp-action="Edit" asp-route-id="@user.Id" class="btn btn-outline-secondary" title="Редактировать">✏️</a>
                                <form asp-action="Delete" asp-route-id="@user.Id" method="post" class="d-inline" 
                                      onsubmit="return confirm('Вы уверены, что хотите удалить пользователя @user.UserName?');">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-outline-danger" title="Удалить">🗑️</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5 border rounded bg-light shadow-sm mt-3">
            <div class="display-4 mb-3 text-muted">👥</div>
            <h3 class="h5">Пользователи не найдены</h3>
            <p class="text-muted small">Нажмите "Создать пользователя", чтобы добавить первого пользователя.</p>
        </div>
    }
</div>