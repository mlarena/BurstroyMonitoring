@model BurstroyMonitoring.Data.Models.ViewModels.EditUserViewModel

@{
    ViewData["Title"] = "Редактирование пользователя";
}

<div class="main-content">
    <div class="view-container" style="max-width: 600px;">
        <h1 class="view-title">Редактирование пользователя</h1>

        <form asp-action="Edit" method="post" class="form-container" style="box-shadow: none; padding: 0;">
            <input type="hidden" asp-for="Id" />
            <div asp-validation-summary="All" class="validation-summary-errors"></div>

            <div class="field-group">
                <label asp-for="UserName" class="control-label required"></label>
                <input asp-for="UserName" class="input" />
                <span asp-validation-for="UserName" class="field-validation-error"></span>
            </div>

            <div class="field-group">
                <label asp-for="Role" class="control-label required"></label>
                <select asp-for="Role" class="input select">
                    <option value="User">User</option>
                    <option value="Admin">Admin</option>
                </select>
                <span asp-validation-for="Role" class="field-validation-error"></span>
            </div>

            <div class="form-actions">
                <button type="submit" class="button button--primary">
                    <span class="button-icon">💾</span> Сохранить
                </button>
                <a asp-action="Index" class="button button--secondary">Отмена</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/dist/jquery.validate.unobtrusive.min.js"></script>
}