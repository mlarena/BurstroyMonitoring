@model BurstroyMonitoring.Data.Models.ViewModels.CreateUserViewModel

@{
    ViewData["Title"] = "Создание пользователя";
}

<div class="main-content">
    <div class="view-container" style="max-width: 600px;">
        <h1 class="view-title">Создание нового пользователя</h1>

        <form asp-action="Create" method="post" class="form-container" style="box-shadow: none; padding: 0;">
           
            <div class="field-group">
                <label asp-for="UserName" class="control-label required">Имя пользователя</label>
                <input asp-for="UserName" class="input" placeholder="Введите имя пользователя" />
                <span asp-validation-for="UserName" class="field-validation-error"></span>
            </div>

            <div class="field-group">
                <label asp-for="Password" class="control-label required">Пароль</label>
                <div class="password-toggle">
                    <input asp-for="Password" type="password" class="input" placeholder="Введите пароль" />
                    <button type="button" class="toggle-btn" tabindex="-1">
                        <i class="bi bi-eye-slash"></i>
                    </button>
                </div>
                <span asp-validation-for="Password" class="field-validation-error"></span>
                <small class="coordinates-hint">Пароль должен быть не менее 6 символов.</small>
            </div>

            <div class="field-group">
                <label asp-for="Role" class="control-label required">Роль</label>
                <select asp-for="Role" class="input select">
                    <option value="">Выберите роль...</option>
                    <option value="User">User</option>
                    <option value="Admin">Admin</option>
                </select>
                <span asp-validation-for="Role" class="field-validation-error"></span>
            </div>

            <div class="form-actions">
                <button type="submit" class="button button--primary">
                    <span class="button-icon">👤</span> Создать пользователя
                </button>
                <a asp-action="Index" class="button button--secondary">Вернуться к списку</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/dist/jquery.validate.unobtrusive.min.js"></script>
    <script src="~/js/password-toggle.js"></script>
}