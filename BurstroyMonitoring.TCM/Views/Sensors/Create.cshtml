@model BurstroyMonitoring.Data.Models.Sensor

@{
    ViewData["Title"] = "Добавить датчик";
}

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-10 col-lg-8">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white py-2">
                    <h1 class="h5 mb-0">Добавить датчик</h1>
                </div>
                <div class="card-body p-3">
                    <form asp-action="Create" id="sensorForm">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>
                        
                        <div class="row g-3 mb-3">
                            <div class="col-md-6">
                                <label asp-for="SerialNumber" class="form-label small fw-bold">Серийный номер</label>
                                <input asp-for="SerialNumber" class="form-control form-control-sm" placeholder="Введите S/N" />
                                <span asp-validation-for="SerialNumber" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="EndPointsName" class="form-label small fw-bold">Название</label>
                                <input asp-for="EndPointsName" class="form-control form-control-sm" placeholder="Введите название" />
                                <span asp-validation-for="EndPointsName" class="text-danger small"></span>
                            </div>
                        </div>
                        
                        <div class="row g-3 mb-3">
                            <div class="col-md-6">
                                <label asp-for="SensorTypeId" class="form-label small fw-bold">Тип датчика</label>
                                <select asp-for="SensorTypeId" class="form-select form-select-sm" asp-items="ViewBag.SensorTypeId">
                                    <option value="">-- Выберите тип --</option>
                                </select>
                                <span asp-validation-for="SensorTypeId" class="text-danger small"></span>
                            </div>
                            
                            <div class="col-md-6">
                                <label asp-for="MonitoringPostId" class="form-label small fw-bold">Пост мониторинга</label>
                                <select asp-for="MonitoringPostId" class="form-select form-select-sm" asp-items="ViewBag.MonitoringPostId">
                                    <option value="">-- Не привязан --</option>
                                </select>
                                <span asp-validation-for="MonitoringPostId" class="text-danger small"></span>
                            </div>
                        </div>
                        
                        <div class="card bg-light mb-3 border-0">
                            <div class="card-body p-2">
                                @await Html.PartialAsync("_CoordinateFields", Model)
                            </div>
                        </div>
                        
                        <div class="row g-3 mb-3">
                            <div class="col-md-8">
                                <label asp-for="Url" class="form-label small fw-bold">URL API</label>
                                <input asp-for="Url" class="form-control form-control-sm" placeholder="https://example.com/api" />
                                <span asp-validation-for="Url" class="text-danger small"></span>
                            </div>
                            <div class="col-md-4">
                                <label asp-for="CheckIntervalSeconds" class="form-label small fw-bold">Интервал (сек)</label>
                                <input asp-for="CheckIntervalSeconds" class="form-control form-control-sm" value="300" />
                                <span asp-validation-for="CheckIntervalSeconds" class="text-danger small"></span>
                            </div>
                        </div>
                        
                        <div class="mb-3">
                            <div class="form-check form-switch">
                                <input asp-for="IsActive" class="form-check-input" type="checkbox" role="switch" checked="checked" />
                                <label asp-for="IsActive" class="form-check-label small">Активен</label>
                            </div>
                        </div>
                        
                        <div class="d-flex justify-content-between align-items-center pt-2 border-top">
                            <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Назад к списку</a>
                            <button type="submit" class="btn btn-primary btn-sm px-4">Создать</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    
    <script src="~/js/coordinateValidation.js" asp-append-version="true"></script>
}