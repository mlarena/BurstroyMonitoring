@model IEnumerable<BurstroyMonitoring.Data.Models.Sensor>

@{
    ViewData["Title"] = "Датчики";
    var search = ViewBag.Search as string ?? "";
    var selectedSensorTypeIds = ViewBag.SelectedSensorTypeIds as List<int> ?? new List<int>();
    var selectedMonitoringPostIds = ViewBag.SelectedMonitoringPostIds as List<int> ?? new List<int>();
    
    bool IsSensorTypeActive(int id) => selectedSensorTypeIds.Contains(id);
    bool IsMonitoringPostActive(int id) => selectedMonitoringPostIds.Contains(id);
    
    var sortBy = ViewBag.SortBy as string ?? "Id";
    var sortDesc = ViewBag.SortDesc as bool? ?? true;
    
    string GetSortArrow(string col) => sortBy == col ? (sortDesc ? "▼" : "▲") : "";
    string GetSortUrl(string col) => Url.Action("Index", new { sortBy = col, sortDesc = sortBy == col ? !sortDesc : true, search = search });
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1 class="h3 mb-0">Датчики</h1>
        <a asp-action="Create" class="btn btn-primary btn-sm">Добавить датчик</a>
    </div>

    <div class="card mb-3 shadow-sm">
        <div class="card-body py-2">
            <form method="get" class="row g-2 align-items-end">
                <div class="col-md-4">
                    <label class="form-label small fw-bold mb-1">Поиск</label>
                    <input type="text" name="search" value="@search" class="form-control form-control-sm" placeholder="S/N, название..." />
                </div>
                <div class="col-md-3">
                    <label class="form-label small fw-bold mb-1">Пост</label>
                    <select name="selectedMonitoringPosts" class="form-select form-select-sm" onchange="this.form.submit()">
                        <option value="">Все посты</option>
                        @if (ViewBag.MonitoringPosts != null) {
                            foreach (var post in ViewBag.MonitoringPosts) {
                                <option value="@post.MonitoringPostId" selected="@(IsMonitoringPostActive(post.MonitoringPostId) ? "selected" : null)">@post.Name</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label small fw-bold mb-1">Тип</label>
                    <select name="selectedSensorTypes" class="form-select form-select-sm" onchange="this.form.submit()">
                        <option value="">Все типы</option>
                        @if (ViewBag.SensorTypes != null) {
                            foreach (var type in ViewBag.SensorTypes) {
                                <option value="@type.SensorTypeId" selected="@(IsSensorTypeActive(type.SensorTypeId) ? "selected" : null)">@type.SensorTypeName</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-2 text-end">
                    <button type="submit" class="btn btn-primary btn-sm w-100">Найти</button>
                </div>
                <input type="hidden" name="sortBy" value="@sortBy" />
                <input type="hidden" name="sortDesc" value="@sortDesc.ToString()" />
            </form>
        </div>
    </div>

    @if (Model.Any()) {
        <div class="table-responsive shadow-sm rounded">
            <table class="table table-sm table-hover table-striped align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th><a href="@GetSortUrl("SerialNumber")" class="text-decoration-none text-dark">S/N @GetSortArrow("SerialNumber")</a></th>
                        <th><a href="@GetSortUrl("EndPointsName")" class="text-decoration-none text-dark">Название @GetSortArrow("EndPointsName")</a></th>
                        <th>Тип</th>
                        <th>Пост</th>
                        <th><a href="@GetSortUrl("Url")" class="text-decoration-none text-dark">URL API @GetSortArrow("Url")</a></th>
                        <th>Статус</th>
                        <th class="text-end">Действия</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model) {
                        <tr>
                            <td class="fw-bold small">@item.SerialNumber</td>
                            <td class="text-truncate small" style="max-width: 200px;">@item.EndPointsName</td>
                            <td class="small">@(item.SensorType?.SensorTypeName ?? "—")</td>
                            <td class="text-truncate small" style="max-width: 150px;">@(item.MonitoringPost?.Name ?? "—")</td>
                            <td class="text-truncate small" style="max-width: 150px;">@item.Url</td>
                            <td class="small">
                                @if (item.IsActive) { <span class="text-success">Активен</span> }
                                else { <span class="text-danger">Неактивен</span> }
                            </td>
                            <td class="text-end">
                                <div class="btn-group btn-group-sm">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-secondary">✏️</a>
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-secondary">📄</a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger">🗑️</a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    } else {
        <div class="alert alert-info">Датчики не найдены.</div>
    }
</div>
