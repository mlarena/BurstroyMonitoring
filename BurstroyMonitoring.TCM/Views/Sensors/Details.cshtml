@model BurstroyMonitoring.Data.Models.Sensor

@{
    ViewData["Title"] = "Подробности о датчике";
}

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-10 col-lg-8">
            <div class="card shadow-sm">
                <div class="card-header bg-info text-white py-2 d-flex justify-content-between align-items-center">
                    <h1 class="h5 mb-0">Подробности о датчике</h1>
                    <span class="badge bg-light text-dark">ID: @Model.Id</span>
                </div>
                <div class="card-body p-0">
                    <table class="table table-sm mb-0">
                        <tbody>
                            <tr>
                                <th class="bg-light ps-3" style="width: 35%;">Серийный номер</th>
                                <td class="ps-3 fw-bold">@Html.DisplayFor(model => model.SerialNumber)</td>
                            </tr>
                            <tr>
                                <th class="bg-light ps-3">Тип датчика</th>
                                <td class="ps-3">
                                    @if (Model.SensorType != null)
                                    {
                                        <div class="fw-bold">@Model.SensorType.SensorTypeName</div>
                                        <div class="small text-muted">@Model.SensorType.Description</div>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">Не указан</span>
                                    }
                                </td>
                            </tr>
                            <tr>
                                <th class="bg-light ps-3">Пост мониторинга</th>
                                <td class="ps-3">
                                    @if (Model.MonitoringPost != null)
                                    {
                                        <a href="@Url.Action("Details", "MonitoringPosts", new { id = Model.MonitoringPostId })" class="text-decoration-none">
                                            @Model.MonitoringPost.Name
                                        </a>
                                        @if (Model.MonitoringPost.IsMobile)
                                        {
                                            <span class="badge bg-info text-dark ms-2 fw-normal">Мобильный</span>
                                        }
                                    }
                                    else
                                    {
                                        <span class="text-muted small">Не привязан</span>
                                    }
                                </td>
                            </tr>
                            <tr>
                                <th class="bg-light ps-3">Координаты</th>
                                <td class="ps-3">
                                    @if (Model.Longitude.HasValue && Model.Latitude.HasValue)
                                    {
                                        <div class="d-flex align-items-center gap-2">
                                            <span>@Model.Longitude.Value.ToString("F6"), @Model.Latitude.Value.ToString("F6")</span>
                                            <a href="https://www.google.com/maps?q=@Model.Latitude.Value,@Model.Longitude.Value" 
                                               target="_blank" class="btn btn-link btn-sm p-0 text-decoration-none">
                                                📍 Карта
                                            </a>
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">Не указаны</span>
                                    }
                                </td>
                            </tr>
                            <tr>
                                <th class="bg-light ps-3">Название точки</th>
                                <td class="ps-3">@Html.DisplayFor(model => model.EndPointsName)</td>
                            </tr>
                            <tr>
                                <th class="bg-light ps-3">URL API</th>
                                <td class="ps-3">
                                    <a href="@Model.Url" target="_blank" class="text-break small">@Model.Url</a>
                                </td>
                            </tr>
                            <tr>
                                <th class="bg-light ps-3">Интервал проверки</th>
                                <td class="ps-3">
                                    @Model.CheckIntervalSeconds сек. 
                                    <span class="text-muted small">(@(Model.CheckIntervalSeconds / 60) мин.)</span>
                                </td>
                            </tr>
                            <tr>
                                <th class="bg-light ps-3">Активность</th>
                                <td class="ps-3 small">
                                    @if (Model.LastActivityUTC.HasValue)
                                    {
                                        <div><span class="text-muted">Последняя:</span> @Model.LastActivityUTC.Value.ToString("dd.MM.yyyy HH:mm:ss") UTC</div>
                                        <div class="text-info">
                                            @{
                                                var timeAgo = DateTime.UtcNow - Model.LastActivityUTC.Value;
                                                if (timeAgo.TotalDays >= 1) { <span>@((int)timeAgo.TotalDays) дн. назад</span> }
                                                else if (timeAgo.TotalHours >= 1) { <span>@((int)timeAgo.TotalHours) ч. назад</span> }
                                                else if (timeAgo.TotalMinutes >= 1) { <span>@((int)timeAgo.TotalMinutes) мин. назад</span> }
                                                else { <span>Только что</span> }
                                            }
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="text-muted">Нет данных</span>
                                    }
                                </td>
                            </tr>
                            <tr>
                                <th class="bg-light ps-3">Статус</th>
                                <td class="ps-3">
                                    @if (Model.IsActive)
                                    {
                                        <span class="badge bg-success fw-normal">Активен</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger fw-normal">Неактивен</span>
                                    }
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
                <div class="card-footer bg-light d-flex justify-content-between py-2">
                    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Назад к списку</a>
                    <div class="btn-group btn-group-sm">
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Редактировать</a>
                        <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger">Удалить</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>