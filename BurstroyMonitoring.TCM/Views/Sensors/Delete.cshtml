@model BurstroyMonitoring.Data.Models.Sensor

@{
    ViewData["Title"] = "Удалить датчик";
}

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow-sm border-danger">
                <div class="card-header bg-danger text-white py-2">
                    <h1 class="h5 mb-0">Удалить датчик</h1>
                </div>
                <div class="card-body p-3 text-center">
                    <div class="display-4 text-danger mb-3">⚠️</div>
                    <h3 class="h5 mb-3">Вы уверены, что хотите удалить этот датчик?</h3>
                    
                    <div class="bg-light p-3 rounded mb-3 text-start small">
                        <div class="row mb-1">
                            <div class="col-4 fw-bold">S/N:</div>
                            <div class="col-8 fw-bold">@Model.SerialNumber</div>
                        </div>
                        <div class="row mb-1">
                            <div class="col-4 fw-bold">Название:</div>
                            <div class="col-8">@Model.EndPointsName</div>
                        </div>
                        <div class="row mb-1">
                            <div class="col-4 fw-bold">Тип:</div>
                            <div class="col-8">@(Model.SensorType?.SensorTypeName ?? "—")</div>
                        </div>
                        <div class="row mb-1">
                            <div class="col-4 fw-bold">Пост:</div>
                            <div class="col-8">@(Model.MonitoringPost?.Name ?? "—")</div>
                        </div>
                    </div>

                    <div class="alert alert-warning py-2 small text-start">
                        <strong>Внимание!</strong> Удаление датчика приведет к потере связи с историческими данными в этом интерфейсе.
                    </div>
                    
                    <form asp-action="Delete">
                        <input type="hidden" asp-for="Id" />
                        <div class="d-flex justify-content-between align-items-center pt-3 border-top">
                            <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Отмена</a>
                            <button type="submit" class="btn btn-danger btn-sm px-4">Удалить</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>