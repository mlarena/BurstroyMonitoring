@model IEnumerable<BurstroyMonitoring.Data.Models.Sensor>
@{
    ViewData["Title"] = "Поверка датчиков";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="mb-0">
            <i class="bi bi-calendar-check me-2 text-primary"></i>Поверка
        </h2>
        <div class="d-flex align-items-center">
            <div class="form-check form-switch me-4">
                <input class="form-check-input" type="checkbox" role="switch" id="autoRefresh">
                <label class="form-check-label small fw-semibold" for="autoRefresh">Автообновление</label>
            </div>
            <label for="postSelect" class="me-2 fw-semibold">Пост:</label>
            <select id="postSelect" class="form-select shadow-sm" style="width: auto; min-width: 250px;" onchange="location.href='?postId=' + this.value">
                @foreach (var post in (IEnumerable<BurstroyMonitoring.Data.Models.MonitoringPost>)ViewBag.Posts)
                {
                    <option value="@post.Id" selected="@(post.Id == ViewBag.SelectedPostId)">@post.Name</option>
                }
            </select>
        </div>
    </div>

    <div class="card shadow-sm border-0" data-post-id="@ViewBag.SelectedPostId">
        <div class="card-header bg-white py-3 border-bottom">
            @{
                var selectedPost = ((IEnumerable<BurstroyMonitoring.Data.Models.MonitoringPost>)ViewBag.Posts)
                                    .FirstOrDefault(p => p.Id == ViewBag.SelectedPostId);
            }
            <div class="d-flex align-items-center">
                <i class="bi bi-geo-alt text-primary me-2 fs-5"></i>
                <span class="fw-bold fs-5">@selectedPost?.Name</span>
                @if (!string.IsNullOrEmpty(selectedPost?.Description))
                {
                    <span class="text-muted ms-2 small">— @selectedPost.Description</span>
                }
            </div>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">Название датчика</th>
                            <!-- <th>Тип датчика</th> -->
                            <th>Серийный номер</th>
                            <th>URL API</th>
                            <th class="pe-4 text-end">Статус</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="5" class="text-center py-5 text-muted">
                                    <i class="bi bi-info-circle me-2"></i>Активные датчики не найдены
                                </td>
                            </tr>
                        }
                        else
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td class="ps-4">
                                        <div class="d-flex flex-column">
                                            <span class="fw-bold text-primary fs-6">@item.EndPointsName</span>
                                            <small class="text-muted sensor-last-update" id="update-time-@item.Id" style="font-size: 0.7rem;">—</small>
                                        </div>
                                    </td>                                    
                                    <!-- <td>
                                        <span class="badge bg-info text-dark">
                                            @(item.SensorType?.SensorTypeName ?? "—")
                                        </span>
                                    </td> -->
                                    <td><code>@item.SerialNumber</code></td>
                                    <td>
                                        <small class="text-muted">@item.Url</small>
                                    </td>
                                    <td class="pe-4 text-end">
                                        <span class="badge bg-success">Активен</span>
                                    </td>
                                </tr>
                                <tr class="sensor-data-row" id="data-@item.Id" data-sensor-id="@item.Id" data-type="@(item.SensorType?.SensorTypeName)">
                                    <td colspan="5" class="ps-5 py-2 bg-light">
                                        <div class="d-flex flex-wrap gap-4 metrics-container">
                                            <div class="spinner-border spinner-border-sm text-primary" role="status">
                                                <span class="visually-hidden">Загрузка...</span>
                                            </div>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div></div>

@section Styles {
    <style>
        .table thead th {
            font-weight: 600;
            text-transform: uppercase;
            font-size: 0.75rem;
            letter-spacing: 0.5px;
            border-top: none;
        }
        .card {
            border-radius: 0.75rem;
            overflow: hidden;
        }
        .metrics-container {
            font-size: 0.85rem;
            min-height: 2.5rem;
            display: flex;
            align-items: center;
        }
        .metric-item {
            display: flex;
            flex-direction: column;
        }
        .metric-label {
            color: #6c757d;
            font-size: 0.75rem;
        }
        .metric-value {
            font-weight: 600;
        }
    </style>
}

@section Scripts {
    <script>
        let refreshTimer = null;
        const REFRESH_INTERVAL = 300; // 2 секунды

        const roadStatuses = {
            "0": "Измерение невозможно", "1": "Сухо", "2": "Влажно", "3": "Мокро",
            "5": "Лёд", "6": "Снег", "9": "Противогололёдные материалы",
            "10": "Снег со льдом", "11": "Сухо, небольшие следы снега/льда", "49": "Снег, посыпанный песком"
        };

        async function updateAllSensors() {
            const card = document.querySelector('.card[data-post-id]');
            if (!card) return;
            
            const postId = card.dataset.postId;
            
            try {
                const response = await fetch(`/Poverka/GetAllSensorsData?postId=${postId}`);
                if (!response.ok) throw new Error(`HTTP ${response.status}`);
                
                const allData = await response.json();
                
                // Собираем все метки времени для нахождения самого свежего значения
                const timestamps = [];
                for (const id in allData) {
                    if (allData[id] && allData[id].receivedAt) {
                        timestamps.push(new Date(allData[id].receivedAt).getTime());
                    }
                }

                const maxTime = timestamps.length > 0 ? Math.max(...timestamps) : null;

                document.querySelectorAll('.sensor-data-row').forEach(row => {
                    const sensorId = row.dataset.sensorId;
                    const type = row.dataset.type;
                    const container = row.querySelector('.metrics-container');
                    const data = allData[sensorId];

                    if (!data) {
                        container.innerHTML = '<span class="text-muted small">Нет данных</span>';
                        return;
                    }

                    // Обновляем время
                    const sensorTime = new Date(data.receivedAt).getTime();
                    const updateTimeStr = new Date(data.receivedAt).toLocaleTimeString('ru-RU', { hour: '2-digit', minute: '2-digit', second: '2-digit' });
                    const timeElement = document.getElementById(`update-time-${sensorId}`);
                    
                    if (timeElement) {
                        timeElement.textContent = `Обновлено: ${updateTimeStr}`;
                        
                        // Проверяем отставание конкретного датчика от самого свежего на 10+ секунд
                        if (maxTime && (maxTime - sensorTime > 10000)) {
                            timeElement.classList.remove('text-muted');
                            timeElement.classList.add('text-danger', 'fw-bold');
                        } else {
                            timeElement.classList.remove('text-danger', 'fw-bold');
                            timeElement.classList.add('text-muted');
                        }
                    }

                    // Формируем HTML метрик
                    let html = '';
                    const missingText = '<span class="text-muted" style="font-size: 0.7rem;">Отсутствует в комплектации</span>';

                    const formatMetric = (label, value, unit = '') => {
                        const displayValue = (value !== null && value !== undefined) ? `${value}${unit}` : missingText;
                        return `<div class="metric-item"><span class="metric-label">${label}</span><span class="metric-value">${displayValue}</span></div>`;
                    };

                    if (type === 'IWS') {
                        html += formatMetric('Темп. воздуха', data.environmentTemperature, '°C');
                        html += formatMetric('Давление (гПа)', data.pressureHpa);
                        html += formatMetric('Давление (мм рт. ст.)', data.pressureMmHg);
                        html += formatMetric('Скорость ветра', data.windSpeed, ' м/с');
                        html += formatMetric('Направление ветра', data.windDirection, '°');
                        // html += formatMetric('Интенсивность осадков', data.precipitationIntensity);
                        html += formatMetric('Кол-во осадков', data.precipitationQuantity);
                        html += formatMetric('Влажность', data.humidityPercentage, '%');
                        html += formatMetric('CO2', data.co2Level, ' ppm');
                    } else if (type === 'DSPD') {
                        html += formatMetric('Темп. дороги', data.roadTemperature, '°C');
                        const statusText = data.roadStatusCode !== null ? (roadStatuses[data.roadStatusCode] || data.roadStatusCode) : null;
                        html += formatMetric('Состояние', statusText);
                        html += formatMetric('Высота слоя воды', data.waterHeight, ' мм');
                        html += formatMetric('Высота слоя льда', data.iceHeight, ' мм');
                        html += formatMetric('Высота слоя снега', data.snowHeight, ' мм');
                    } else if (type === 'DOV') {
                        html += formatMetric('Видимость', data.visibleRange, ' м');
                    } else if (type === 'MUEKS') {
                        html += formatMetric('Темп. грунта', data.owenCh1, '°C');
                    } else if (type === 'DUST') {
                        html += formatMetric('PM10', data.pm10Act);
                    }

                    if (html) {
                        container.innerHTML = html;
                    } else {
                        container.innerHTML = '<span class="text-muted small">Нет актуальных метрик</span>';
                    }
                });
            } catch (e) {
                console.error('[Poverka] Update error:', e);
            }
        }

        function startAutoRefresh() {
            if (refreshTimer) clearInterval(refreshTimer);
            refreshTimer = setInterval(updateAllSensors, REFRESH_INTERVAL);
            localStorage.setItem('poverka_autoRefresh', 'true');
        }

        function stopAutoRefresh() {
            if (refreshTimer) clearInterval(refreshTimer);
            refreshTimer = null;
            localStorage.setItem('poverka_autoRefresh', 'false');
        }

        document.addEventListener('DOMContentLoaded', () => {
            const refreshSwitch = document.getElementById('autoRefresh');
            
            // Инициализация состояния из localStorage
            const isEnabled = localStorage.getItem('poverka_autoRefresh') === 'true';
            refreshSwitch.checked = isEnabled;

            // Первичная загрузка
            updateAllSensors();

            if (isEnabled) {
                startAutoRefresh();
            }

            refreshSwitch.addEventListener('change', (e) => {
                if (e.target.checked) {
                    startAutoRefresh();
                } else {
                    stopAutoRefresh();
                }
            });
        });
    </script>
}
