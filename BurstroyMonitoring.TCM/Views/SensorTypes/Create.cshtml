@model BurstroyMonitoring.Data.Models.SensorType

@{
    ViewData["Title"] = "Создать тип датчика";
}

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white py-2">
                    <h1 class="h5 mb-0">Создать тип датчика</h1>
                </div>
                <div class="card-body p-3">
                    <form asp-action="Create">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>
                        
                        <div class="mb-3">
                            <label asp-for="SensorTypeName" class="form-label small fw-bold">Название типа</label>
                            <input asp-for="SensorTypeName" class="form-control form-control-sm" 
                                   placeholder="Например: MUEKS, IWS, DSPD" maxlength="20" />
                            <span asp-validation-for="SensorTypeName" class="text-danger small"></span>
                            <div class="form-text small" style="font-size: 0.7rem;">Максимум 20 символов</div>
                        </div>
                        
                        <div class="mb-3">
                            <label asp-for="Description" class="form-label small fw-bold">Описание</label>
                            <textarea asp-for="Description" class="form-control form-control-sm" rows="4" 
                                      placeholder="Подробное описание типа датчика..."></textarea>
                            <span asp-validation-for="Description" class="text-danger small"></span>
                        </div>
                        
                        <div class="d-flex justify-content-between align-items-center pt-2 border-top">
                            <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Назад к списку</a>
                            <button type="submit" class="btn btn-primary btn-sm px-4">Создать</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}