@model IEnumerable<BurstroyMonitoring.Data.Models.SensorType>

@{
    ViewData["Title"] = "Типы датчиков";
    
    // Получаем параметры сортировки из ViewBag
    var sortBy = ViewBag.SortBy as string ?? "Id";
    var sortDesc = ViewBag.SortDesc as bool? ?? true;
    var search = ViewBag.Search as string ?? "";
    
    // Функция для получения URL сортировки
    string GetSortUrl(string columnName)
    {
        var newSortDesc = (sortBy == columnName) ? !sortDesc : true;
        return Url.Action("Index", new { 
            sortBy = columnName, 
            sortDesc = newSortDesc,
            search = search
        });
    }
    
    // Функция для отображения стрелки сортировки
    string GetSortArrow(string columnName)
    {
        if (sortBy == columnName)
        {
            return sortDesc ? "▼" : "▲";
        }
        return "";
    }
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1 class="h3 mb-0">Типы датчиков</h1>
        <a asp-action="Create" class="btn btn-primary btn-sm">Создать новый</a>
    </div>
    
    <!-- Поисковая строка -->
    <div class="card mb-3 shadow-sm">
        <div class="card-body py-2">
            <form method="get" class="row g-2 align-items-center">
                <div class="col-auto flex-grow-1">
                    <input type="text" name="search" value="@search" 
                           placeholder="Поиск по названию типа или описанию..." 
                           class="form-control form-control-sm" />
                </div>
                <div class="col-auto">
                    <button type="submit" class="btn btn-primary btn-sm">Найти</button>
                    @if (!string.IsNullOrEmpty(search))
                    {
                        <a href="@Url.Action("Index")" class="btn btn-outline-secondary btn-sm">Сбросить</a>
                    }
                </div>
                <!-- Скрытые поля для сохранения сортировки -->
                <input type="hidden" name="sortBy" value="@sortBy" />
                <input type="hidden" name="sortDesc" value="@sortDesc.ToString()" />
            </form>
        </div>
    </div>
    
    @if (Model.Any())
    {
        <div class="mb-2 small text-muted">
            Всего типов: @Model.Count()
            @if (!string.IsNullOrEmpty(search))
            {
                <span> (по запросу: "@search")</span>
            }
        </div>

        <div class="table-responsive shadow-sm rounded">
            <table class="table table-sm table-hover table-striped align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>
                            <a href="@GetSortUrl("SensorTypeName")" class="text-decoration-none text-dark">
                                Название типа @GetSortArrow("SensorTypeName")
                            </a>
                        </th>
                        <th>
                            <a href="@GetSortUrl("Description")" class="text-decoration-none text-dark">
                                Описание @GetSortArrow("Description")
                            </a>
                        </th>
                        <th>
                            <a href="@GetSortUrl("Created")" class="text-decoration-none text-dark">
                                Создан @GetSortArrow("Created")
                            </a>
                        </th>
                        <th class="text-center">
                            <a href="@GetSortUrl("Sensors")" class="text-decoration-none text-dark">
                                Датчиков @GetSortArrow("Sensors")
                            </a>
                        </th>
                        <th class="text-end">Действия</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-bold small">@item.SensorTypeName</td>
                            <td class="text-truncate small" style="max-width: 300px;" title="@item.Description">
                                @(string.IsNullOrEmpty(item.Description) ? "—" : item.Description)
                            </td>
                            <td class="text-nowrap small">
                                @(item.CreatedAt?.ToString("dd.MM.yyyy HH:mm") ?? "—")
                            </td>
                            <td class="text-center small">
                                @if (item.Sensors?.Count > 0)
                                {
                                    <span>@item.Sensors.Count</span>
                                }
                                else
                                {
                                    <span class="text-muted">0</span>
                                }
                            </td>
                            <td class="text-end text-nowrap">
                                <div class="btn-group btn-group-sm">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-secondary" title="Редактировать">✏️</a>
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-secondary" title="Подробности">📄</a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="text-center py-5 border rounded bg-light shadow-sm">
            <div class="display-4 mb-3 text-muted">🔧</div>
            <h3 class="h5">@(string.IsNullOrEmpty(search) ? "Нет типов датчиков" : "Типы датчиков не найдены")</h3>
            <p class="text-muted small">@(string.IsNullOrEmpty(search) ? "Создайте первый тип датчика для классификации оборудования" : "Попробуйте изменить параметры поиска")</p>
            <div class="mt-3">
                <a asp-action="Create" class="btn btn-primary btn-sm">Создать тип</a>
                @if (!string.IsNullOrEmpty(search))
                {
                    <a href="@Url.Action("Index")" class="btn btn-outline-secondary btn-sm ms-2">Показать все</a>
                }
            </div>
        </div>
    }
</div>
