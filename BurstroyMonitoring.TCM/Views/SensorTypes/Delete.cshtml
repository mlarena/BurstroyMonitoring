@model BurstroyMonitoring.Data.Models.SensorType

@{
    ViewData["Title"] = "Удалить тип датчика";
}

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow-sm border-danger">
                <div class="card-header bg-danger text-white py-2">
                    <h1 class="h5 mb-0">Удалить тип датчика</h1>
                </div>
                <div class="card-body p-3 text-center">
                    <div class="display-4 text-danger mb-3">⚠️</div>
                    <h3 class="h5 mb-3">Вы уверены, что хотите удалить этот тип?</h3>
                    
                    <div class="bg-light p-3 rounded mb-3 text-start small">
                        <div class="row mb-1">
                            <div class="col-4 fw-bold">Название:</div>
                            <div class="col-8 fw-bold">@Model.SensorTypeName</div>
                        </div>
                        <div class="row mb-1">
                            <div class="col-4 fw-bold">Описание:</div>
                            <div class="col-8">@Model.Description</div>
                        </div>
                    </div>

                    @if (Model.Sensors?.Any() == true)
                    {
                        <div class="alert alert-danger py-2 small text-start">
                            <strong>Ошибка!</strong> Тип имеет связанные датчики (@Model.Sensors.Count шт.).
                            Удаление невозможно, пока датчики не будут удалены или переназначены.
                        </div>
                    }
                    
                    <form asp-action="Delete">
                        <input type="hidden" asp-for="Id" />
                        <div class="d-flex justify-content-between align-items-center pt-3 border-top">
                            <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Отмена</a>
                            @if (Model.Sensors?.Any() == true)
                            {
                                <button type="submit" class="btn btn-danger btn-sm px-4" disabled>Удалить</button>
                            }
                            else
                            {
                                <button type="submit" class="btn btn-danger btn-sm px-4">Удалить</button>
                            }
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>