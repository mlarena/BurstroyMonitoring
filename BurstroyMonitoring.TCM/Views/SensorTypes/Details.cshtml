@model BurstroyMonitoring.Data.Models.SensorType

@{
    ViewData["Title"] = "Подробности о типе датчика";
}

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-10 col-lg-8">
            <div class="card shadow-sm">
                <div class="card-header bg-info text-white py-2 d-flex justify-content-between align-items-center">
                    <h1 class="h5 mb-0">Подробности о типе датчика</h1>
                    <span class="badge bg-light text-dark">ID: @Model.Id</span>
                </div>
                <div class="card-body p-0">
                    <table class="table table-sm mb-0">
                        <tbody>
                            <tr>
                                <th class="bg-light ps-3" style="width: 35%;">Название типа</th>
                                <td class="ps-3 fw-bold">@Html.DisplayFor(model => model.SensorTypeName)</td>
                            </tr>
                            <tr>
                                <th class="bg-light ps-3">Описание</th>
                                <td class="ps-3">
                                    <div class="small">@Html.DisplayFor(model => model.Description)</div>
                                </td>
                            </tr>
                            <tr>
                                <th class="bg-light ps-3">Создан</th>
                                <td class="ps-3 small text-muted">
                                    @(Model.CreatedAt?.ToString("dd.MM.yyyy HH:mm") ?? "—")
                                </td>
                            </tr>
                            <tr>
                                <th class="bg-light ps-3">Датчики</th>
                                <td class="ps-3">
                                    @if (ViewBag.Sensors != null && ((List<BurstroyMonitoring.Data.Models.Sensor>)ViewBag.Sensors).Any())
                                    {
                                        <div class="mb-2">
                                            <span class="badge bg-primary rounded-pill">@ViewBag.TotalSensorCount</span>
                                            <a href="@Url.Action("Index", "Sensors", new { sensorTypeId = Model.Id })" 
                                               class="btn btn-link btn-sm p-0 ms-2 text-decoration-none">
                                                Просмотреть все
                                            </a>
                                        </div>
                                        
                                        <ul class="list-group list-group-flush border rounded small">
                                            @foreach (var sensor in (List<BurstroyMonitoring.Data.Models.Sensor>)ViewBag.Sensors)
                                            {
                                                <li class="list-group-item py-1 d-flex justify-content-between align-items-center">
                                                    <div>
                                                        <a href="@Url.Action("Details", "Sensors", new { id = sensor.Id })" class="text-decoration-none">
                                                            @sensor.SerialNumber - @sensor.EndPointsName
                                                        </a>
                                                        @if (sensor.MonitoringPost != null)
                                                        {
                                                            <span class="text-muted ms-2" style="font-size: 0.7rem;">(@sensor.MonitoringPost.Name)</span>
                                                        }
                                                    </div>
                                                    @if (sensor.IsActive)
                                                    {
                                                        <span class="badge bg-success p-1">✓</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge bg-danger p-1">✗</span>
                                                    }
                                                </li>
                                            }
                                            @if (ViewBag.TotalSensorCount > 10)
                                            {
                                                <li class="list-group-item py-1 text-center text-muted bg-light" style="font-size: 0.7rem;">
                                                    ... и еще @(ViewBag.TotalSensorCount - 10) датчиков
                                                </li>
                                            }
                                        </ul>
                                    }
                                    else
                                    {
                                        <div class="d-flex align-items-center gap-2">
                                            <span class="text-muted small">Нет датчиков этого типа</span>
                                            <a href="@Url.Action("Create", "Sensors", new { sensorTypeId = Model.Id })" 
                                               class="btn btn-outline-primary btn-sm py-0 px-2" style="font-size: 0.75rem;">
                                                + Добавить
                                            </a>
                                        </div>
                                    }
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
                <div class="card-footer bg-light d-flex justify-content-between py-2">
                    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Назад к списку</a>
                    <div class="btn-group btn-group-sm">
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Редактировать</a>
                        <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger">Удалить</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>